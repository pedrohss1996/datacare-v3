# Dependências do Node (Pesado, não deve subir)
node_modules/

# Ambiente virtual Python (guia-ocr)
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.pyc

# Variáveis de Ambiente e Segredos (CRÍTICO: Não suba isso!)
.env
.env.local
