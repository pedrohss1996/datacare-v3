<div id="modal-acesso" class="relative z-50 hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity"></div>

    <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
        <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
            <div class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-2xl transition-all sm:my-8 sm:w-full sm:max-w-lg border border-slate-100">
                
                <div class="bg-white px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
                    <div class="sm:flex sm:items-start">
                        <div class="mx-auto flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-blue-100 sm:mx-0 sm:h-10 sm:w-10">
                            <svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                            </svg>
                        </div>
                        <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left w-full">
                            <h3 class="text-lg font-semibold leading-6 text-slate-900" id="modal-title">Configurar Acesso</h3>
                            <div class="mt-4 space-y-4">
                                <div>
                                    <label class="block text-sm font-medium text-slate-700">Login (nm_usuario)</label>
                                    <input type="text" id="input_usuario" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" placeholder="ex: m.braga">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-slate-700">Senha Provisória</label>
                                    <input type="password" id="input_senha" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-slate-700">Perfil de Permissão</label>
                                    <select id="input_perfil" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm">
                                        <option value="1">1 - Básico / Consulta</option>
                                        <option value="2">2 - Médico / Assistencial</option>
                                        <option value="3">3 - Recepção / Administrativo</option>
                                        <option value="99">99 - TI / Administrador</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-slate-50 px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6 gap-2">
                    <button type="button" id="btn-confirmar" class="inline-flex w-full justify-center rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 sm:ml-3 sm:w-auto">Confirmar Dados</button>
                    <button type="button" id="btn-cancelar" class="mt-3 inline-flex w-full justify-center rounded-lg bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 sm:mt-0 sm:w-auto">Cancelar</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Lógica para abrir/fechar e transferir dados
    const chkUsuario = document.getElementById('chk-usuario');
    const modal = document.getElementById('modal-acesso');
    
    // Inputs do Modal
    const inputUser = document.getElementById('input_usuario');
    const inputPass = document.getElementById('input_senha');
    const inputRole = document.getElementById('input_perfil');

    // Inputs Ocultos do Form Principal
    const hiddenUser = document.getElementById('hidden_usuario');
    const hiddenPass = document.getElementById('hidden_senha');
    const hiddenRole = document.getElementById('hidden_perfil');

    // Abrir Modal ao marcar checkbox
    if(chkUsuario) {
        chkUsuario.addEventListener('change', function() {
            if (this.checked) {
                modal.classList.remove('hidden');
                setTimeout(() => inputUser.focus(), 100);
            } else {
                // Limpa dados se desmarcar
                hiddenUser.value = '';
                hiddenPass.value = '';
                hiddenRole.value = '';
            }
        });
    }

    // Botão Confirmar
    const btnConfirmar = document.getElementById('btn-confirmar');
    if(btnConfirmar) {
        btnConfirmar.addEventListener('click', function() {
            if(!inputUser.value || !inputPass.value) {
                alert('Por favor, preencha Usuário e Senha.');
                return;
            }
            // Transfere dados para os campos ocultos do form
            hiddenUser.value = inputUser.value;
            hiddenPass.value = inputPass.value;
            hiddenRole.value = inputRole.value;
            
            modal.classList.add('hidden');
        });
    }

    // Botão Cancelar
    const btnCancelar = document.getElementById('btn-cancelar');
    if(btnCancelar) {
        btnCancelar.addEventListener('click', function() {
            if(chkUsuario) chkUsuario.checked = false; // Desmarca o checkbox
            modal.classList.add('hidden');
        });
    }
</script>