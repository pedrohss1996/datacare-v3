<%
    // --- LÓGICA GLOBAL DE PREPARAÇÃO DO USUÁRIO (HEADER) ---
    
    // 1. Função para deixar o nome bonito (Ex: marlon.braga -> Marlon Braga)
    function formatarNomeGlobal(texto) {
        if (!texto) return 'Usuário';
        
        let str = String(texto).trim();
        
        // Remove pontos se houver (comum em logins)
        if (str.includes('.')) str = str.replace(/\./g, ' ');

        // Exceções que devem ficar minúsculas
        const excecoes = ['de', 'da', 'do', 'dos', 'das', 'e'];

        return str.toLowerCase().split(' ').map((palavra, index) => {
            // Se for preposição e não for a primeira palavra, mantém minúsculo
            if (excecoes.includes(palavra) && index !== 0) return palavra;
            // Capitaliza a primeira letra
            return palavra.charAt(0).toUpperCase() + palavra.slice(1);
        }).join(' ');
    }

    // 2. Tenta pegar o objeto user da sessão/middleware
    const uGlobal = (typeof user !== 'undefined' && user) ? user : {};
    
    // 3. Define qual nome usar (Prioridade: Sessão > Banco > Login > Visitante)
    const rawName = uGlobal.name || uGlobal.ds_usuario || uGlobal.nm_usuario || uGlobal.username || 'Visitante';
    
    // 4. Gera as variáveis finais para usar no HTML
    const nomeExibicao = formatarNomeGlobal(rawName);
    const inicialNome = nomeExibicao.charAt(0).toUpperCase();
%>
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'DataCare System' %></title>
    
    <!-- TailwindCSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Font Awesome 6.4.0 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; overflow-x: hidden; transition: background 0.4s ease, color 0.3s ease; }
        /* Dark Mode Futurista (Glassmorphism) */
        body.theme-dark-futurista {
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 35%, #0f172a 70%, #1e3a5f 100%);
            background-attachment: fixed;
            color: #e2e8f0;
        }
        body.theme-dark-futurista::before {
            content: '';
            position: fixed;
            inset: 0;
            background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(34, 211, 238, 0.15), transparent),
                        radial-gradient(ellipse 60% 40% at 100% 50%, rgba(139, 92, 246, 0.1), transparent),
                        radial-gradient(ellipse 50% 30% at 0% 80%, rgba(6, 182, 212, 0.08), transparent);
            pointer-events: none !important;
            z-index: -1;
        }
        body.theme-dark-futurista header {
            background: rgba(15, 23, 42, 0.7) !important;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(34, 211, 238, 0.2);
            box-shadow: 0 4px 30px rgba(0,0,0,0.3);
        }
        body.theme-dark-futurista main { position: relative; z-index: 1; }
        body.theme-dark-futurista .from-slate-50 { background: transparent !important; }
        body.theme-dark-futurista .glass-panel.from-indigo-600,
        body.theme-dark-futurista header.glass-panel {
            background: rgba(30, 58, 95, 0.5) !important;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-color: rgba(34, 211, 238, 0.25) !important;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.05);
        }
        body.theme-dark-futurista .bg-blue-100 { background: rgba(34, 211, 238, 0.2) !important; color: #67e8f9 !important; }
        .theme-dark-futurista .glass-panel {
            background: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(34, 211, 238, 0.25);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.05);
        }
        .theme-dark-futurista .glass-card {
            background: rgba(30, 41, 59, 0.35);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(34, 211, 238, 0.2);
            box-shadow: 0 4px 24px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.04);
            pointer-events: auto;
            cursor: pointer;
        }
        .theme-dark-futurista .glass-card:hover {
            border-color: rgba(34, 211, 238, 0.45);
            box-shadow: 0 8px 32px rgba(34, 211, 238, 0.15), 0 0 20px rgba(34, 211, 238, 0.05);
        }
        .theme-dark-futurista .text-slate-800 { color: #e2e8f0 !important; }
        .theme-dark-futurista .text-slate-500 { color: #94a3b8 !important; }
        .theme-dark-futurista .text-slate-600 { color: #cbd5e1 !important; }
        .theme-dark-futurista .text-slate-400 { color: #94a3b8 !important; }
        .theme-dark-futurista .bg-slate-50 { background: transparent !important; }
        .theme-dark-futurista .bg-white { background: rgba(30, 41, 59, 0.35) !important; backdrop-filter: blur(16px); border-color: rgba(34, 211, 238, 0.2) !important; }
        .theme-dark-futurista .bg-slate-100 { background: rgba(51, 65, 85, 0.5) !important; }
        .theme-dark-futurista .border-slate-200 { border-color: rgba(34, 211, 238, 0.15) !important; }
        .theme-dark-futurista .border-slate-400 { border-color: rgba(34, 211, 238, 0.35) !important; }
        .theme-dark-futurista .ring-cyan-500\/20 { --tw-ring-color: rgba(34, 211, 238, 0.3); }
        .theme-dark-futurista a.text-slate-600 { color: #94a3b8 !important; }
        .theme-dark-futurista a.text-slate-600:hover { color: #22d3ee !important; }
        .theme-dark-futurista .text-blue-700 { color: #67e8f9 !important; }
        .theme-dark-futurista .theme-toggle-btn {
            background: rgba(30, 41, 59, 0.6);
            border: 1px solid rgba(34, 211, 238, 0.3);
            color: #22d3ee;
            backdrop-filter: blur(8px);
        }
        .theme-dark-futurista .theme-toggle-btn:hover { background: rgba(34, 211, 238, 0.2); }
        body:not(.theme-dark-futurista) .theme-toggle-btn { color: #64748b; border: 1px solid #e2e8f0; }
        /* Garantir que links, botões e cards sejam clicáveis */
        a[href], button { cursor: pointer; position: relative; z-index: 2; pointer-events: auto !important; }
        /* Logo com fundo transparente – mantém cores originais em ambos os temas */
        .header-logo { background: transparent !important; }
    </style>
</head>
<body class="bg-slate-50 flex flex-col h-screen overflow-hidden" id="body-theme">
    <script>
        (function() {
            const saved = localStorage.getItem('datacare-theme');
            if (saved === 'dark-futurista') document.getElementById('body-theme').classList.add('theme-dark-futurista');
        })();
    </script>

    <header class="bg-white border-b border-slate-200 z-50 shadow-sm flex-shrink-0">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-12">
                <div class="flex items-center gap-3">
                    <a href="/" class="flex items-center">
                        <div class="logo-container">
                            <img src="/img/Logotipo.png" 
                                alt="Logo DataCare" 
                                class="w-28 h-auto header-logo"> 
                        </div>
                    </a>
                </div>

                <div class="flex items-center gap-4">
                    <button type="button" id="theme-toggle" class="theme-toggle-btn p-2 rounded-lg transition-all" title="Alternar tema futurista (Dark Mode)">
                        <i class="fas fa-moon text-sm" id="theme-icon-light"></i>
                        <i class="fas fa-sun text-sm hidden" id="theme-icon-dark"></i>
                    </button>
                    <% if (typeof user !== 'undefined' && user && (user.cd_perfil_inicial === 3 || (user.grupo_id === 1))) { %>
                    <a href="/admin" class="text-sm font-medium text-slate-600 hover:text-blue-600 transition" title="Administração">
                        <i class="fas fa-cog mr-1"></i>Admin
                    </a>
                    <% } %>
                    <div class="hidden md:flex flex-col items-end mr-2">
                        <span class="text-sm font-semibold text-slate-700">
                             <%= nomeExibicao %>
                        </span>
                    </div>

                    <div class="h-9 w-9 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-bold border border-blue-200 shadow-sm">
                        <%= inicialNome %>
                    </div>
                    
                    <% if (typeof user !== 'undefined' && user) { %>
                        <a href="/logout" class="text-slate-400 hover:text-red-500 transition-colors ml-2" title="Sair">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                            </svg>
                        </a>
                    <% } else { %>
                        <a href="/login" class="text-sm font-medium text-blue-600 hover:text-blue-800">Entrar</a>
                    <% } %>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-1 w-full overflow-y-auto">
        <%- body %>
    </main>

    <script>
        (function() {
            const btn = document.getElementById('theme-toggle');
            const body = document.getElementById('body-theme');
            const iconLight = document.getElementById('theme-icon-light');
            const iconDark = document.getElementById('theme-icon-dark');
            if (!btn || !body) return;
            function updateIcons() {
                const isDark = body.classList.contains('theme-dark-futurista');
                iconLight.classList.toggle('hidden', isDark);
                iconDark.classList.toggle('hidden', !isDark);
            }
            updateIcons();
            btn.addEventListener('click', function() {
                body.classList.toggle('theme-dark-futurista');
                localStorage.setItem('datacare-theme', body.classList.contains('theme-dark-futurista') ? 'dark-futurista' : 'light');
                updateIcons();
            });
        })();
    </script>
</body>
</html>