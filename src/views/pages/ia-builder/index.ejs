<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="flex h-[calc(100vh-64px)] overflow-hidden bg-slate-100">

    <aside class="w-[350px] bg-white border-r border-slate-200 flex flex-col z-20 shadow-lg">
        
        <div class="p-4 border-b border-slate-100 flex items-center gap-3 bg-slate-50">
            <div class="w-8 h-8 rounded-lg bg-indigo-600 text-white flex items-center justify-center shadow-indigo-200 shadow-md">
                <i class="fa-solid fa-wand-magic-sparkles"></i>
            </div>
            <div>
                <h2 class="font-bold text-slate-800 text-sm">IA Page Builder</h2>
                <p class="text-xs text-slate-500">Geração Dinâmica de UI</p>
            </div>
        </div>

        <div class="px-4 pt-4 pb-2 bg-slate-50 border-b border-slate-100">
            <label class="block text-xs font-bold text-slate-500 mb-1 uppercase tracking-wider">Fonte de Dados (Contexto)</label>
            <div class="relative">
                <select id="datasetSelector" class="w-full text-sm border-slate-200 rounded-lg p-2.5 pr-8 bg-white focus:ring-indigo-500 focus:border-indigo-500 shadow-sm cursor-pointer appearance-none text-slate-700 font-medium">
                    <option value="">🤖 Automático (IA Escolhe)</option>
                    
                    <% if (typeof datasets !== 'undefined' && datasets.length > 0) { %>
                        <optgroup label="Meus Datasets Cadastrados">
                            <% datasets.forEach(d => { %>
                                <option value="<%= d.id %>">📂 <%= d.titulo %></option>
                            <% }) %>
                        </optgroup>
                    <% } %>
                
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-slate-500">
                    <i class="fa-solid fa-chevron-down text-xs"></i>
                </div>
            </div>
        </div>

        <div id="chatHistory" class="flex-1 overflow-y-auto p-4 space-y-4 bg-slate-50/50">
            <div class="flex gap-3">
                <div class="w-8 h-8 rounded-full bg-indigo-100 flex-shrink-0 flex items-center justify-center text-indigo-600 text-xs">
                    <i class="fa-solid fa-robot"></i>
                </div>
                <div class="bg-white border border-slate-200 p-3 rounded-2xl rounded-tl-none shadow-sm text-sm text-slate-600 max-w-[90%]">
                    Selecione uma fonte de dados acima (ou deixe no automático) e me diga o que você precisa visualizar.
                </div>
            </div>
        </div>

        <div class="p-4 bg-white border-t border-slate-200">
            <div class="relative">
                <textarea id="promptInput" rows="3" 
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 resize-none pr-10 scrollbar-hide shadow-inner"
                    placeholder="Ex: Dashboard de faturamento por convênio..."
                    onkeydown="verificarEnter(event)"></textarea>
                <button onclick="enviarMensagem()" id="btnEnviar" class="absolute bottom-2 right-2 p-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 shadow-sm transition-all hover:scale-105">
                    <i class="fa-solid fa-paper-plane text-xs"></i>
                </button>
            </div>
        </div>
    </aside>

    <main class="flex-1 flex flex-col relative overflow-hidden">
        
        <div id="pageLoading" class="hidden absolute inset-0 bg-white/90 z-50 flex-col items-center justify-center backdrop-blur-sm transition-opacity">
            <div class="w-16 h-16 border-4 border-indigo-200 border-t-indigo-600 rounded-full animate-spin mb-4"></div>
            <h3 class="text-lg font-bold text-slate-700">Construindo Layout...</h3>
            <p class="text-sm text-slate-400" id="loadingStep">Consultando IA</p>
        </div>

        <div id="dynamicCanvas" class="flex-1 overflow-y-auto p-8 scroll-smooth">
            <div class="h-full flex flex-col items-center justify-center text-slate-400 opacity-60">
                <i class="fa-solid fa-layer-group text-6xl mb-4 text-slate-300"></i>
                <p class="text-lg font-medium">Sua página aparecerá aqui</p>
            </div>
        </div>
    </main>
</div>

<script>
    let myChart = null;
    const chatHistory = document.getElementById('chatHistory');

    function verificarEnter(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            enviarMensagem();
        }
    }

    // Adiciona bolha ao chat
    function addChatBubble(text, isUser = false) {
        const div = document.createElement('div');
        div.className = 'flex gap-3 ' + (isUser ? 'flex-row-reverse' : 'fade-in');
        div.innerHTML = `
            <div class="w-8 h-8 rounded-full ${isUser ? 'bg-slate-200' : 'bg-indigo-100 text-indigo-600'} flex-shrink-0 flex items-center justify-center text-xs">
                <i class="fa-solid ${isUser ? 'fa-user' : 'fa-robot'}"></i>
            </div>
            <div class="${isUser ? 'bg-indigo-600 text-white' : 'bg-white border border-slate-200 text-slate-700'} p-3 rounded-2xl ${isUser ? 'rounded-tr-none' : 'rounded-tl-none'} shadow-sm text-sm max-w-[90%]">
                ${text}
            </div>
        `;
        chatHistory.appendChild(div);
        chatHistory.scrollTop = chatHistory.scrollHeight;
    }

    async function enviarMensagem() {
        const input = document.getElementById('promptInput');
        const datasetSelect = document.getElementById('datasetSelector'); // <--- CAPTURA O SELECT

        const text = input.value.trim();
        const queryId = datasetSelect.value; // <--- CAPTURA O VALOR (ID DA QUERY)

        if(!text) return;

        addChatBubble(text, true);
        input.value = '';

        // UI Loading
        const loader = document.getElementById('pageLoading');
        const stepText = document.getElementById('loadingStep');
        loader.classList.remove('hidden');
        loader.classList.add('flex');
        
        try {
            stepText.innerText = "1/2 Projetando Interface (IA)...";
            
            // 1. IA gera SQL e Layout (AGORA ENVIANDO O queryId)
            const resIA = await fetch('/ia-builder/gerar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    promptUsuario: text,
                    queryId: queryId // <--- ENVIA PARA O BACKEND
                })
            });
            const jsonIA = await resIA.json();
            if(!jsonIA.success) throw new Error('Falha na IA');
            const { sql, layout } = jsonIA.data;

            stepText.innerText = "2/2 Buscando dados no Oracle...";

            // 2. Executa SQL no Banco
            const resBanco = await fetch('/ia-builder/testar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sql: sql })
            });
            const jsonBanco = await resBanco.json();
            
            if(!jsonBanco.success) throw new Error("Erro Oracle: " + jsonBanco.error);

            // 3. Renderiza a Página Completa
            construirPagina(layout, jsonBanco.dados);
            
            // Mensagem de sucesso mais detalhada
            const datasetNome = queryId ? datasetSelect.options[datasetSelect.selectedIndex].text : 'automático';
            addChatBubble(`✅ Página criada usando dataset <b>${datasetNome}</b>! Visualização: <b>${layout.tipoGrafico}</b>.`);

        } catch (error) {
            console.error(error);
            addChatBubble(`❌ Erro: ${error.message}`);
        } finally {
            loader.classList.add('hidden');
            loader.classList.remove('flex');
        }
    }

    // =========================================================================
    // O CONSTRUTOR DE PÁGINAS (ENGINE DE RENDERIZAÇÃO)
    // =========================================================================
    function construirPagina(layout, dados) {
        const canvas = document.getElementById('dynamicCanvas');
        
        // 1. Calcula totais (KPIs) via JS
        const totalValue = dados.reduce((acc, curr) => acc + (parseFloat(curr.value || curr.VALUE) || 0), 0);
        const totalCount = dados.length;

        // 2. Monta o HTML dinâmico
        let html = `
            <div class="mb-8 fade-in">
                <div class="flex justify-between items-start">
                    <div>
                        <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight">${layout.tituloPagina}</h1>
                        <p class="text-slate-500 mt-1">${layout.descricao || 'Relatório gerado automaticamente via IA'}</p>
                    </div>
                    <div class="flex gap-2">
                        <button class="bg-white border border-slate-300 text-slate-600 px-3 py-2 rounded-lg text-xs font-bold hover:bg-slate-50 transition"><i class="fa-solid fa-print mr-2"></i> PDF</button>
                        <button class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-xs font-bold hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition"><i class="fa-solid fa-save mr-2"></i> Salvar</button>
                    </div>
                </div>
            </div>

            <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm mb-8 flex flex-wrap gap-4 items-end fade-in" style="animation-delay: 0.1s">
                ${layout.filtrosSugeridos.includes('periodo') ? `
                <div class="flex-1 min-w-[200px]">
                    <label class="block text-xs font-bold text-slate-400 uppercase mb-1">Período</label>
                    <div class="flex items-center gap-2 border border-slate-200 rounded-lg p-1 bg-slate-50">
                        <input type="date" class="bg-transparent border-none text-sm w-full focus:ring-0">
                        <span class="text-slate-400">-</span>
                        <input type="date" class="bg-transparent border-none text-sm w-full focus:ring-0">
                    </div>
                </div>` : ''}
                
                ${layout.filtrosSugeridos.map(f => f !== 'periodo' ? `
                <div class="flex-1 min-w-[150px]">
                    <label class="block text-xs font-bold text-slate-400 uppercase mb-1">${f}</label>
                    <select class="w-full text-sm border-slate-200 rounded-lg bg-slate-50 focus:ring-indigo-500">
                        <option>Todos</option>
                    </select>
                </div>` : '').join('')}
                
                <button class="px-4 py-2.5 bg-slate-800 text-white rounded-lg text-sm font-medium hover:bg-slate-700 transition">
                    <i class="fa-solid fa-filter mr-2"></i> Filtrar
                </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8 fade-in" style="animation-delay: 0.2s">
                <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm relative overflow-hidden group hover:shadow-md transition">
                    <div class="absolute right-0 top-0 p-4 opacity-10 group-hover:opacity-20 transition text-indigo-600">
                        <i class="fa-solid fa-chart-pie text-6xl"></i>
                    </div>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">${layout.tituloKpi || 'Total Geral'}</p>
                    <h3 class="text-4xl font-extrabold text-slate-800">${totalValue.toLocaleString('pt-BR')}</h3>
                    <p class="text-xs text-green-500 mt-2 font-medium flex items-center"><i class="fa-solid fa-arrow-up mr-1"></i> Calculado agora</p>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Registros Encontrados</p>
                    <h3 class="text-4xl font-extrabold text-slate-800">${totalCount}</h3>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 fade-in" style="animation-delay: 0.3s">
                <div class="lg:col-span-2 bg-white p-6 rounded-2xl border border-slate-100 shadow-sm flex flex-col">
                    <h3 class="font-bold text-slate-700 mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-chart-column text-indigo-500"></i> Visualização Gráfica
                    </h3>
                    <div class="relative flex-1 min-h-[300px]">
                        <canvas id="pageChart"></canvas>
                    </div>
                </div>

                <div class="bg-white rounded-2xl border border-slate-100 shadow-sm flex flex-col overflow-hidden">
                    <div class="p-4 border-b border-slate-50 bg-slate-50/50">
                        <h3 class="font-bold text-slate-700 text-sm">Detalhamento (Top 10)</h3>
                    </div>
                    <div class="overflow-y-auto flex-1 max-h-[350px]">
                        <table class="w-full text-sm text-left">
                            <tbody class="divide-y divide-slate-50">
                                ${dados.slice(0, 10).map(row => `
                                <tr class="hover:bg-indigo-50/50 transition">
                                    <td class="px-4 py-3 font-medium text-slate-700">${row.label || row.LABEL || Object.values(row)[0]}</td>
                                    <td class="px-4 py-3 text-right text-slate-500 font-mono">${(row.value || row.VALUE || Object.values(row)[1]).toLocaleString()}</td>
                                </tr>`).join('')}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        `;

        // 3. Injeta no DOM
        canvas.innerHTML = html;

        // 4. Renderiza o Chart.js
        renderChart(layout.tipoGrafico, dados, layout.tituloPagina);
    }

    function renderChart(tipo, dados, titulo) {
        const ctx = document.getElementById('pageChart').getContext('2d');
        if(myChart) myChart.destroy();

        const labels = dados.map(d => d.label || d.LABEL || Object.values(d)[0]);
        const values = dados.map(d => d.value || d.VALUE || Object.values(d)[1]);

        myChart = new Chart(ctx, {
            type: tipo === 'table' ? 'bar' : tipo,
            data: {
                labels: labels,
                datasets: [{
                    label: titulo,
                    data: values,
                    backgroundColor: tipo === 'pie' ? 
                        ['#6366f1', '#8b5cf6', '#ec4899', '#10b981', '#f59e0b'] : 
                        '#6366f1',
                    borderRadius: 6,
                    borderWidth: 0,
                    hoverOffset: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: tipo === 'pie', position: 'bottom' }
                },
                scales: {
                    x: { grid: { display: false } },
                    y: { grid: { color: '#f1f5f9' }, beginAtZero: true }
                }
            }
        });
    }
</script>

<style>
    .fade-in { animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; transform: translateY(10px); }
    @keyframes fadeIn { to { opacity: 1; transform: translateY(0); } }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
</style>