<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="flex h-[calc(100vh-64px)] overflow-hidden bg-slate-100">

    <aside class="w-[350px] bg-white border-r border-slate-200 flex flex-col z-20 shadow-lg">
        <div class="p-4 border-b border-slate-100 flex items-center gap-3 bg-slate-50">
            <div class="w-8 h-8 rounded-lg bg-indigo-600 text-white flex items-center justify-center shadow-indigo-200 shadow-md">
                <i class="fa-solid fa-code"></i>
            </div>
            <div>
                <h2 class="font-bold text-slate-800 text-sm">IA Page Generator</h2>
                <p class="text-xs text-slate-500">Full Code Generation</p>
            </div>
        </div>

        <div class="px-4 pt-4 pb-2 bg-slate-50 border-b border-slate-100">
            <label class="block text-xs font-bold text-slate-500 mb-1 uppercase tracking-wider">Dataset</label>
            <div class="relative">
                <select id="datasetSelector" class="w-full text-sm border-slate-200 rounded-lg p-2.5 bg-white focus:ring-indigo-500 cursor-pointer">
                    <option value="">🤖 Automático</option>
                    <% if (typeof datasets !== 'undefined') { %>
                        <% datasets.forEach(d => { %>
                            <option value="<%= d.id %>">📂 <%= d.titulo %></option>
                        <% }) %>
                    <% } %>
                </select>
            </div>
        </div>

        <div id="chatHistory" class="flex-1 overflow-y-auto p-4 space-y-4 bg-slate-50/50">
            <div class="flex gap-3">
                <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center text-xs"><i class="fa-solid fa-robot"></i></div>
                <div class="bg-white border p-3 rounded-2xl rounded-tl-none text-sm text-slate-600 shadow-sm">
                    Modo Dev ativado. Vou gerar o SQL e o Código HTML completo da página para você. O que deseja criar?
                </div>
            </div>
        </div>

        <div class="p-4 bg-white border-t border-slate-200">
            <div class="relative">
                <textarea id="promptInput" rows="3" class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-sm resize-none pr-10" placeholder="Ex: Painel de pendências financeiras..."></textarea>
                <button onclick="enviarMensagem()" class="absolute bottom-2 right-2 p-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 shadow-sm"><i class="fa-solid fa-paper-plane text-xs"></i></button>
            </div>
        </div>
    </aside>

    <main class="flex-1 flex flex-col relative bg-slate-200">
        
        <div id="pageLoading" class="hidden absolute inset-0 bg-slate-900/50 z-50 flex-col items-center justify-center backdrop-blur-sm">
            <div class="bg-white p-6 rounded-2xl shadow-2xl flex flex-col items-center">
                <div class="w-12 h-12 border-4 border-indigo-200 border-t-indigo-600 rounded-full animate-spin mb-4"></div>
                <h3 class="text-lg font-bold text-slate-800">Gerando Aplicação...</h3>
                <p class="text-sm text-slate-500" id="loadingStep">Escrevendo código HTML...</p>
            </div>
        </div>

        <div class="flex-1 p-4 h-full">
            <div class="w-full h-full bg-white rounded-xl shadow-lg overflow-hidden border border-slate-300 relative">
                
                <div id="emptyState" class="absolute inset-0 flex flex-col items-center justify-center text-slate-400">
                    <i class="fa-solid fa-laptop-code text-6xl mb-4 text-slate-300"></i>
                    <p class="font-medium">Sua página gerada aparecerá aqui</p>
                </div>

                <iframe id="previewFrame" class="w-full h-full border-none bg-white hidden"></iframe>
            </div>
        </div>
    </main>
</div>

<script>
    const chatHistory = document.getElementById('chatHistory');

    function addChatBubble(text, isUser = false) {
        const div = document.createElement('div');
        div.className = 'flex gap-3 ' + (isUser ? 'flex-row-reverse' : '');
        div.innerHTML = `
            <div class="w-8 h-8 rounded-full ${isUser ? 'bg-slate-200' : 'bg-indigo-100 text-indigo-600'} flex-shrink-0 flex items-center justify-center text-xs">
                <i class="fa-solid ${isUser ? 'fa-user' : 'fa-robot'}"></i>
            </div>
            <div class="${isUser ? 'bg-indigo-600 text-white' : 'bg-white border border-slate-200 text-slate-700'} p-3 rounded-2xl ${isUser ? 'rounded-tr-none' : 'rounded-tl-none'} shadow-sm text-sm max-w-[90%]">
                ${text}
            </div>
        `;
        chatHistory.appendChild(div);
        chatHistory.scrollTop = chatHistory.scrollHeight;
    }

    async function enviarMensagem() {
        const input = document.getElementById('promptInput');
        const datasetSelect = document.getElementById('datasetSelector');
        const text = input.value.trim();
        const queryId = datasetSelect.value;

        if(!text) return;

        addChatBubble(text, true);
        input.value = '';

        const loader = document.getElementById('pageLoading');
        const stepText = document.getElementById('loadingStep');
        loader.classList.remove('hidden'); loader.classList.add('flex');
        
        try {
            stepText.innerText = "1/2 IA Escrevendo Código...";
            
            // 1. Pede o HTML e o SQL para a IA
            const resIA = await fetch('/ia-builder/gerar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ promptUsuario: text, queryId: queryId })
            });
            const jsonIA = await resIA.json();
            
            if(!jsonIA.success) throw new Error(jsonIA.error || 'Erro na IA');
            const { sql, html } = jsonIA.data;

            stepText.innerText = "2/2 Consultando Oracle...";

            // 2. Executa o SQL para pegar os dados reais
            const resBanco = await fetch('/ia-builder/testar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sql: sql })
            });
            const jsonBanco = await resBanco.json();
            
            if(!jsonBanco.success) throw new Error("Erro SQL: " + jsonBanco.error);

            // 3. Renderiza a Página
            renderizarNoIframe(html, jsonBanco.dados);
            
            addChatBubble(`✅ Aplicação Gerada! Usei <b>${jsonBanco.dados.length}</b> registros do banco.`);

        } catch (error) {
            console.error(error);
            addChatBubble(`❌ Erro: ${error.message}`);
        } finally {
            loader.classList.add('hidden'); loader.classList.remove('flex');
        }
    }

    function renderizarNoIframe(htmlCode, dadosReais) {
        const iframe = document.getElementById('previewFrame');
        const emptyState = document.getElementById('emptyState');
        
        emptyState.classList.add('hidden');
        iframe.classList.remove('hidden');

        // A MÁGICA: Injetamos os dados como uma variável global no topo do HTML
        const scriptDados = `
            <script>
                // DADOS INJETADOS PELO BACKEND DO SISTEMA
                window.DADOS_DB = ${JSON.stringify(dadosReais)};
                console.log('Dados carregados:', window.DADOS_DB.length, 'registros');
            <\/script>
        `;

        // Inserimos o script de dados logo após o <head> ou no começo do body
        let htmlFinal = htmlCode;
        if (htmlFinal.includes('<head>')) {
            htmlFinal = htmlFinal.replace('<head>', '<head>' + scriptDados);
        } else {
            htmlFinal = scriptDados + htmlFinal;
        }

        // Escreve no Iframe
        const doc = iframe.contentWindow.document;
        doc.open();
        doc.write(htmlFinal);
        doc.close();
    }
</script>