<div class="h-[calc(100vh-140px)] flex flex-col lg:flex-row gap-6">

    <div class="w-full lg:w-1/3 flex flex-col gap-4">
        
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 flex-grow flex flex-col">
            <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                Instruções para IA
            </h2>
            
            <div class="flex justify-between items-end mb-2">
                <label class="text-sm text-slate-500">Descreva o componente:</label>
                
                <button onclick="toggleDictation()" id="btnMic" 
                    class="group flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-100 hover:bg-red-50 text-slate-600 hover:text-red-600 border border-slate-200 transition-all text-xs font-semibold cursor-pointer">
                    <svg id="micIcon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
                    <span id="micText">Usar Voz</span>
                    <span id="micPulse" class="hidden flex h-2 w-2 relative">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
                    </span>
                </button>
            </div>

            <textarea id="promptInput" 
                class="w-full flex-grow p-4 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none resize-none text-slate-700 transition-colors"
                placeholder="Ex: Crie um atestado médico para o paciente João da Silva, com 3 dias de afastamento..."></textarea>
            
            <button onclick="generateComponent()" id="btnGenerate"
                class="mt-4 w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-lg transition-all flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                <span>Gerar Componente</span>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
            </button>
        </div>

        <div class="bg-slate-900 rounded-xl p-4 overflow-hidden h-48 relative group">
            <span class="text-xs text-slate-400 absolute top-2 left-4">HTML Gerado</span>
            <pre id="codeOutput" class="text-xs text-green-400 font-mono h-full overflow-auto pt-6 p-2">...</pre>
            <button onclick="copyCode()" class="absolute top-2 right-2 p-1 bg-slate-700 text-white text-xs rounded opacity-0 group-hover:opacity-100 transition-opacity">Copiar</button>
        </div>
    </div>

    <div class="w-full lg:w-2/3 bg-slate-100 rounded-xl border border-slate-200 flex flex-col overflow-hidden relative">
        
        <div class="bg-white border-b border-slate-200 px-4 py-2 flex justify-between items-center">
            <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Preview em Tempo Real</span>
            
            <div class="flex items-center gap-4">
                <button onclick="printComponent()" class="text-slate-400 hover:text-blue-600 transition-colors" title="Imprimir Documento">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
                </button>

                <div class="h-4 w-px bg-slate-200"></div>

                <div class="flex gap-1.5">
                    <div class="w-3 h-3 rounded-full bg-red-400"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                    <div class="w-3 h-3 rounded-full bg-green-400"></div>
                </div>
            </div>
        </div>
        
        <div id="previewArea" class="flex-grow p-8 overflow-auto flex items-center justify-center bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]">
            <div class="text-slate-400 text-center">
                <p>O componente gerado aparecerá aqui.</p>
            </div>
        </div>

        <div id="loadingOverlay" class="absolute inset-0 bg-white/80 backdrop-blur-sm flex items-center justify-center hidden z-10">
            <div class="flex flex-col items-center">
                <svg class="animate-spin h-10 w-10 text-blue-600 mb-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span class="text-blue-800 font-semibold animate-pulse">A IA está pensando...</span>
            </div>
        </div>
    </div>

</div>

<script>
    // --- VARIÁVEIS GLOBAIS ---
    let recognition = null;
    let isListening = false;
    let finalTranscript = ""; // Texto final confirmado (sessão atual)
    let initialText = "";     // Texto que já estava no textarea antes de começar

    // Verifica suporte do navegador
    if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        const SpeechAPI = window.SpeechRecognition || window.webkitSpeechRecognition;
        recognition = new SpeechAPI();
        
        recognition.lang = 'pt-BR';
        
        // --- AQUI ESTÁ A MÁGICA DA VELOCIDADE ---
        recognition.continuous = true;     // NÃO PARA DE OUVIR (Fluxo contínuo)
        recognition.interimResults = true; // MOSTRA O RESULTADO NA HORA (Streaming)

        recognition.onstart = function() {
            isListening = true;
            updateMicUI(true);
            
            // Trava o texto atual como ponto de partida
            const textArea = document.getElementById('promptInput');
            initialText = textArea.value;
            // Se já tiver texto e não terminar com espaço, adiciona um
            if (initialText.length > 0 && !initialText.endsWith(' ')) {
                initialText += " ";
            }
            finalTranscript = ""; // Reseta a sessão de fala atual
        };

        recognition.onend = function() {
            // Se o usuário parou de falar mas o botão ainda diz "Ouvindo" (caiu conexão), reinicia
            if (isListening) {
                recognition.start(); 
            } else {
                updateMicUI(false);
            }
        };

        recognition.onresult = function(event) {
            let interimTranscript = ''; // Texto provisório (sendo formado agora)

            // Loop inteligente: Pega tudo que o Google já entendeu nessa sessão
            for (let i = event.resultIndex; i < event.results.length; ++i) {
                if (event.results[i].isFinal) {
                    finalTranscript += event.results[i][0].transcript;
                } else {
                    interimTranscript += event.results[i][0].transcript;
                }
            }

            // Atualiza a tela: (Texto Antigo) + (Texto Confirmado Agora) + (Texto Sendo Falado)
            const textArea = document.getElementById('promptInput');
            textArea.value = initialText + finalTranscript + interimTranscript;
            
            // Mantém a rolagem sempre no final para acompanhar a fala
            textArea.scrollTop = textArea.scrollHeight;
        };

        recognition.onerror = function(event) {
            console.error("Erro voz:", event.error);
            // Ignora erros de "no-speech" (silêncio), só para se for erro real
            if (event.error !== 'no-speech') {
                isListening = false;
                updateMicUI(false);
            }
        };
    } else {
        const btnMic = document.getElementById('btnMic');
        if(btnMic) btnMic.style.display = 'none';
    }

    // --- FUNÇÕES DE CONTROLE ---
    function toggleDictation() {
        if (!recognition) return alert("Seu navegador não suporta voz.");
        
        if (isListening) {
            isListening = false; // Sinaliza que é para parar de verdade
            recognition.stop();
        } else {
            recognition.start();
        }
    }

    function updateMicUI(listening) {
        const btn = document.getElementById('btnMic');
        const text = document.getElementById('micText');
        const pulse = document.getElementById('micPulse');

        if (listening) {
            text.innerText = "Parar Ditado"; // Feedback claro
            pulse.classList.remove('hidden');
            btn.classList.add('bg-red-50', 'text-red-600', 'border-red-200');
            btn.classList.remove('bg-slate-100', 'text-slate-600', 'border-slate-200');
        } else {
            text.innerText = "Usar Voz";
            pulse.classList.add('hidden');
            btn.classList.remove('bg-red-50', 'text-red-600', 'border-red-200');
            btn.classList.add('bg-slate-100', 'text-slate-600', 'border-slate-200');
        }
    }

    // --- FUNÇÃO DE IMPRESSÃO (Mantida) ---
    function printComponent() {
        const content = document.getElementById('previewArea').innerHTML;
        if (!content || content.includes('O componente gerado aparecerá aqui')) {
            return alert('Gere um conteúdo antes de imprimir!');
        }
        const printWindow = window.open('', '', 'height=800,width=800');
        printWindow.document.write('<html><head><title>Imprimir - Hospital Core</title>');
        printWindow.document.write('<link rel="stylesheet" href="/css/style.css">'); // Tailwind
        printWindow.document.write('</head><body class="bg-white p-8">');
        printWindow.document.write(content);
        printWindow.document.write('</body></html>');
        printWindow.document.close();
        printWindow.focus();
        setTimeout(() => {
            printWindow.print();
            printWindow.close();
        }, 500);
    }

    // --- LÓGICA DE GERAÇÃO DA IA (Mantida) ---
    async function generateComponent() {
        const prompt = document.getElementById('promptInput').value;
        const btn = document.getElementById('btnGenerate');
        const overlay = document.getElementById('loadingOverlay');
        const preview = document.getElementById('previewArea');
        const codeOut = document.getElementById('codeOutput');

        if (!prompt.trim()) return alert('Digite algo para a IA!');

        // Se estiver ditando, para o microfone antes de gerar
        if (isListening) {
            isListening = false;
            recognition.stop();
        }

        btn.disabled = true;
        overlay.classList.remove('hidden');

        try {
            const response = await fetch('/page-builder/generate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ prompt })
            });

            const data = await response.json();

            if (data.success) {
                preview.innerHTML = data.html;
                if(codeOut) codeOut.textContent = data.html;
            } else {
                alert('Erro: ' + data.error);
            }

        } catch (err) {
            console.error(err);
            alert('Erro ao conectar com o servidor.');
        } finally {
            btn.disabled = false;
            overlay.classList.add('hidden');
        }
    }

    function copyCode() {
        const code = document.getElementById('codeOutput').textContent;
        navigator.clipboard.writeText(code);
        alert('Código HTML copiado!');
    }
</script>