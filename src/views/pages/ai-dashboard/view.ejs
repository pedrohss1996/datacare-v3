<div class="max-w-7xl mx-auto px-4 py-6">
  <div class="flex justify-between items-center mb-6 flex-wrap gap-2">
    <h1 class="text-2xl font-bold text-slate-800" id="dashboardTitle">Dashboard</h1>
    <div class="flex items-center gap-2">
      <a href="/ai-dashboards" class="px-3 py-1.5 border border-slate-200 rounded-lg text-sm text-slate-600 hover:bg-slate-50">Voltar</a>
    </div>
  </div>
  <div id="dashboard-renderer" class="min-h-[600px] bg-slate-50 rounded-xl border border-slate-200 overflow-hidden">
    <div class="flex items-center justify-center text-slate-400 py-12">
      <i class="fas fa-circle-notch fa-spin text-blue-500 text-2xl mr-3"></i>
      Carregando dashboard...
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script>
/* Renderer nativo para dashboards salvos — usa o Chart.js já carregado no layout */
(function() {
  var dashboardId = '<%= dashboardId %>';
  var API = '/api/ai-dashboard';
  var container = document.getElementById('dashboard-renderer');

  /* ── DashboardRenderer inline (mesmo do unified.ejs) ── */
  var DR = (function() {
    var _charts={}, _allData=[], _filtered=[], _config=null, _container=null;
    var _page=1, _pageSize=15, _sortCol=null, _sortDir=1, _activeFilters={};
    var COLORS=['#3b82f6','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#f97316','#ec4899','#14b8a6','#a855f7'];
    var KPI_COLORS=['#3b82f6','#10b981','#8b5cf6','#f59e0b','#ef4444','#06b6d4'];
    var KPI_BGS=['#eff6ff','#f0fdf4','#faf5ff','#fffbeb','#fff1f2','#ecfeff'];
    var KPI_ICONS=['📊','📈','📉','🏷️','🔺','🔹'];
    function _fmt(n){if(n==null)return'-';if(typeof n==='number'){if(Math.abs(n)>=1e6)return(n/1e6).toFixed(1)+'M';if(Math.abs(n)>=1e3)return(n/1e3).toFixed(1)+'K';return n%1?n.toFixed(2):n.toLocaleString('pt-BR');}return String(n);}
    function _fmtFull(n){if(n==null)return'—';if(typeof n==='number')return n.toLocaleString('pt-BR',{maximumFractionDigits:2});return String(n);}
    function _esc(s){if(s==null)return'';return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
    function _q(sel){return _container?_container.querySelector(sel):null;}
    function _qa(sel){return _container?Array.from(_container.querySelectorAll(sel)):[];}
    function _agg(data,col){var m={};data.forEach(function(r){var k=r[col]!=null?String(r[col]):'(vazio)';m[k]=(m[k]||0)+1;});return m;}
    function _aggNum(data,catCol,numCol){var m={};data.forEach(function(r){var k=r[catCol]!=null?String(r[catCol]):'(vazio)';m[k]=(m[k]||0)+(parseFloat(r[numCol])||0);});return m;}
    function _topN(map,n){return Object.keys(map).sort(function(a,b){return map[b]-map[a];}).slice(0,n);}
    function _kpiValue(kpi){switch(kpi.type){case 'total':return _fmt(_filtered.length);case 'sum':{var s=_filtered.reduce(function(a,r){return a+(parseFloat(r[kpi.col])||0);},0);return _fmt(s);}case 'avg':{var s2=_filtered.reduce(function(a,r){return a+(parseFloat(r[kpi.col])||0);},0);return _fmt(s2/(_filtered.length||1));}case 'unique':return String(new Set(_filtered.map(function(r){return r[kpi.col];})).size);case 'max':{var vs=_filtered.map(function(r){return parseFloat(r[kpi.col]);}).filter(function(v){return !isNaN(v);});return vs.length?_fmt(Math.max.apply(null,vs)):'-';}case 'min':{var vs2=_filtered.map(function(r){return parseFloat(r[kpi.col]);}).filter(function(v){return !isNaN(v);});return vs2.length?_fmt(Math.min.apply(null,vs2)):'-';}}return'-';}
    function _buildChartCfg(def,data){var font={size:11,family:'Inter,-apple-system,sans-serif'},gc='#f1f5f9';if(def.type==='scatter'&&def.numCol&&def.numCol2){return{type:'scatter',data:{datasets:[{label:def.numCol+' x '+def.numCol2,data:data.slice(0,300).map(function(r){return{x:parseFloat(r[def.numCol])||0,y:parseFloat(r[def.numCol2])||0};}),backgroundColor:COLORS[0]+'88',pointRadius:4,pointHoverRadius:6}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{title:{display:true,text:def.numCol,font:font},ticks:{font:font},grid:{color:gc}},y:{title:{display:true,text:def.numCol2,font:font},ticks:{font:font,callback:function(v){return _fmt(v);}},grid:{color:gc}}}}};}if(def.catCol){var map=def.numCol?_aggNum(data,def.catCol,def.numCol):_agg(data,def.catCol);var keys=_topN(map,10),vals=keys.map(function(k){return map[k];});if(def.type==='bar'){return{type:'bar',data:{labels:keys,datasets:[{data:vals,backgroundColor:COLORS,borderRadius:6,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:function(c){return ' '+_fmtFull(c.parsed.y);}}}},scales:{x:{grid:{display:false},ticks:{font:font,maxRotation:30}},y:{grid:{color:gc},ticks:{font:font,callback:function(v){return _fmt(v);}}}}}};}else if(def.type==='horizontalBar'){return{type:'bar',data:{labels:keys,datasets:[{data:vals,backgroundColor:COLORS,borderRadius:4,borderSkipped:false}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:function(c){return ' '+_fmtFull(c.parsed.x);}}}},scales:{x:{grid:{color:gc},ticks:{font:font,callback:function(v){return _fmt(v);}}},y:{grid:{display:false},ticks:{font:font}}}}};}else if(def.type==='doughnut'){return{type:'doughnut',data:{labels:keys,datasets:[{data:vals,backgroundColor:COLORS,borderWidth:2,borderColor:'white',hoverOffset:8}]},options:{cutout:'65%',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:true,position:'bottom',labels:{font:font,padding:10,boxWidth:12}},tooltip:{callbacks:{label:function(c){return ' '+c.label+': '+_fmtFull(c.parsed);}}}}}}}else if(def.type==='polarArea'){return{type:'polarArea',data:{labels:keys,datasets:[{data:vals,backgroundColor:COLORS.map(function(c){return c+'aa';}),borderColor:COLORS,borderWidth:1}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:true,position:'bottom',labels:{font:font,padding:10,boxWidth:12}}}}};}}return null;}
    function _buildLayout(){var cols=(_config.columns||[]).length;_container.innerHTML='<style>@keyframes drFI{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}</style><div style="padding:20px 24px;max-width:1600px;margin:0 auto;font-family:Inter,-apple-system,sans-serif;"><div style="margin-bottom:20px;"><h2 style="font-size:20px;font-weight:700;color:#0f172a;margin:0 0 4px;">'+_esc(_config.title||'Dashboard')+'</h2><p id="dr-desc" style="color:#64748b;font-size:13px;margin:0;"></p></div><div id="dr-kpis" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:14px;margin-bottom:20px;"></div><div id="dr-filters" style="display:none;background:white;border-radius:12px;padding:14px 18px;box-shadow:0 1px 4px rgba(0,0,0,.07);border:1px solid #e2e8f0;margin-bottom:20px;"><div style="font-size:11px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px;">🔍 Filtros</div><div id="dr-filter-row" style="display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end;"></div></div><div id="dr-charts" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(380px,1fr));gap:16px;margin-bottom:20px;"></div><div style="background:white;border-radius:12px;padding:18px 20px;box-shadow:0 1px 4px rgba(0,0,0,.07);border:1px solid #e2e8f0;"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;flex-wrap:wrap;gap:10px;"><span style="font-size:13px;font-weight:600;color:#374151;">📋 Dados Completos</span><input id="dr-search" type="text" placeholder="🔍 Pesquisar..." style="padding:7px 12px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;width:210px;outline:none;color:#1e293b;"></div><div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:13px;"><thead id="dr-thead"></thead><tbody id="dr-tbody"></tbody></table></div><div style="display:flex;align-items:center;justify-content:space-between;margin-top:14px;flex-wrap:wrap;gap:10px;"><span id="dr-page-info" style="font-size:13px;color:#64748b;"></span><div id="dr-page-btns" style="display:flex;gap:5px;flex-wrap:wrap;"></div></div></div></div>';var desc=_q('#dr-desc');if(desc)desc.textContent=_allData.length.toLocaleString('pt-BR')+' registros · '+cols+' colunas · Atualizado agora';var search=_q('#dr-search');if(search)search.addEventListener('input',function(){_page=1;_renderTable();});}
    function _renderKPIs(){var grid=_q('#dr-kpis');if(!grid)return;grid.innerHTML='';(_config.kpis||[]).slice(0,6).forEach(function(kpi,i){var color=KPI_COLORS[i]||'#3b82f6',bg=KPI_BGS[i]||'#eff6ff',icon=KPI_ICONS[i]||'📊';var card=document.createElement('div');card.style.cssText='background:white;border-radius:12px;padding:18px;box-shadow:0 1px 4px rgba(0,0,0,.07);border:1px solid #e2e8f0;border-top:4px solid '+color+';animation:drFI .4s ease '+(i*0.07)+'s both;';card.innerHTML='<div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#64748b;margin-bottom:8px;">'+icon+' '+_esc(kpi.label)+'</div><div class="dr-kv-'+i+'" style="font-size:28px;font-weight:700;color:#0f172a;line-height:1;">'+_kpiValue(kpi)+'</div><div style="font-size:12px;color:#94a3b8;margin-top:5px;">'+_esc(kpi.sub)+'</div>';grid.appendChild(card);});}
    function _updateKPIs(){(_config.kpis||[]).slice(0,6).forEach(function(kpi,i){var el=_container?_container.querySelector('.dr-kv-'+i):null;if(el)el.textContent=_kpiValue(kpi);});}
    function _buildFilters(){var filterDefs=_config.filters||[];if(!filterDefs.length)return;var row=_q('#dr-filter-row');if(!row)return;_q('#dr-filters').style.display='';filterDefs.forEach(function(f){if(f.type==='select'){var uniqVals=Array.from(new Set(_allData.map(function(r){return r[f.col];}).filter(function(v){return v!=null;}))).sort(function(a,b){return String(a).localeCompare(String(b));});if(uniqVals.length<2||uniqVals.length>80)return;var wrap=document.createElement('div');wrap.style.cssText='display:flex;flex-direction:column;gap:4px;min-width:140px;flex:1;max-width:210px;';var lbl=document.createElement('label');lbl.style.cssText='font-size:12px;font-weight:600;color:#475569;';lbl.textContent=f.col;var sel=document.createElement('select');sel.style.cssText='padding:7px 10px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;color:#1e293b;background:#f8fafc;outline:none;cursor:pointer;';sel.innerHTML='<option value="">Todos</option>';uniqVals.forEach(function(v){sel.innerHTML+='<option>'+_esc(String(v))+'</option>';});(function(col,s){s.addEventListener('change',function(){_activeFilters[col]=s.value;_applyFilters();});})(f.col,sel);wrap.appendChild(lbl);wrap.appendChild(sel);row.appendChild(wrap);}else if(f.type==='daterange'){['De','Até'].forEach(function(label,idx){var wrap=document.createElement('div');wrap.style.cssText='display:flex;flex-direction:column;gap:4px;min-width:130px;flex:1;max-width:170px;';var l=document.createElement('label');l.style.cssText='font-size:12px;font-weight:600;color:#475569;';l.textContent=label+' ('+f.col+')';var inp=document.createElement('input');inp.type='date';inp.id='dr-df-'+(idx?'end':'start');inp.style.cssText='padding:7px 10px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;color:#1e293b;background:#f8fafc;outline:none;';(function(col){inp.addEventListener('change',function(){_activeFilters['__dc']=col;var s=_container.querySelector('#dr-df-start'),e=_container.querySelector('#dr-df-end');_activeFilters['__ds']=s?s.value:'';_activeFilters['__de']=e?e.value:'';_applyFilters();});})(f.col);wrap.appendChild(l);wrap.appendChild(inp);row.appendChild(wrap);});}});var btnClr=document.createElement('button');btnClr.style.cssText='padding:7px 16px;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;cursor:pointer;color:#475569;font-weight:600;align-self:flex-end;white-space:nowrap;';btnClr.textContent='✕ Limpar';btnClr.addEventListener('click',function(){_qa('select').forEach(function(s){s.value='';});_qa('input[type=date]').forEach(function(i){i.value='';});_activeFilters={};_applyFilters();});row.appendChild(btnClr);}
    function _applyFilters(){_filtered=_allData.filter(function(row){for(var k in _activeFilters){if(k==='__dc'||k==='__ds'||k==='__de')continue;if(_activeFilters[k]&&String(row[k])!==_activeFilters[k])return false;}if(_activeFilters['__dc']&&(_activeFilters['__ds']||_activeFilters['__de'])){var v=row[_activeFilters['__dc']];if(v){var d=new Date(v);if(_activeFilters['__ds']&&d<new Date(_activeFilters['__ds']))return false;if(_activeFilters['__de']&&d>new Date(_activeFilters['__de']+'T23:59:59'))return false;}}return true;});_page=1;_updateKPIs();_renderCharts();_renderTable();}
    function _buildCharts(){var grid=_q('#dr-charts');if(!grid)return;grid.innerHTML='';(_config.charts||[]).slice(0,4).forEach(function(def,i){var card=document.createElement('div');card.style.cssText='background:white;border-radius:12px;padding:18px 20px;box-shadow:0 1px 4px rgba(0,0,0,.07);border:1px solid #e2e8f0;animation:drFI .5s ease '+(i*0.1+0.1)+'s both;';card.innerHTML='<div style="font-size:13px;font-weight:600;color:#374151;margin-bottom:14px;display:flex;align-items:center;gap:8px;"><span style="width:28px;height:28px;border-radius:8px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;">'+_esc(def.icon||'📊')+'</span>'+_esc(def.title||'Gráfico')+'</div><div style="position:relative;height:240px;"><canvas id="'+_esc(def.id)+'"></canvas></div>';grid.appendChild(card);});setTimeout(function(){_renderCharts();},60);}
    function _renderCharts(){(_config.charts||[]).slice(0,4).forEach(function(def){var canvas=_q('#'+def.id);if(!canvas)return;if(_charts[def.id]){try{_charts[def.id].destroy();}catch(e){}delete _charts[def.id];}var cfg=_buildChartCfg(def,_filtered);if(cfg&&typeof Chart!=='undefined'){if(typeof Chart.defaults!=='undefined')Chart.defaults.font.family='Inter,-apple-system,sans-serif';_charts[def.id]=new Chart(canvas.getContext('2d'),cfg);}});}
    function _renderTable(){var searchEl=_q('#dr-search');var searchVal=searchEl?(searchEl.value||'').toLowerCase():'';var cols=(_config.columns||[]);var display=_filtered;if(searchVal)display=_filtered.filter(function(r){return cols.some(function(c){var v=r[c.name];return v!=null&&String(v).toLowerCase().includes(searchVal);});});if(_sortCol){display=display.slice().sort(function(a,b){var va=a[_sortCol],vb=b[_sortCol],na=parseFloat(va),nb=parseFloat(vb);if(!isNaN(na)&&!isNaN(nb))return(na-nb)*_sortDir;return String(va||'').localeCompare(String(vb||''))*_sortDir;});}var total=display.length,start=(_page-1)*_pageSize,end=Math.min(start+_pageSize,total);var pageData=display.slice(start,end);var thead=_q('#dr-thead'),tbody=_q('#dr-tbody');if(!thead||!tbody)return;thead.innerHTML='';var tr=document.createElement('tr');cols.forEach(function(col){var th=document.createElement('th');var arrow=col.name===_sortCol?(_sortDir===1?' ↑':' ↓'):'';th.style.cssText='background:#f8fafc;padding:9px 12px;text-align:left;font-weight:600;border-bottom:2px solid #e2e8f0;white-space:nowrap;cursor:pointer;user-select:none;font-size:12px;position:sticky;top:0;z-index:1;color:'+(col.name===_sortCol?'#3b82f6':'#374151')+';';th.textContent=col.name+arrow;(function(cn){th.addEventListener('click',function(){if(_sortCol===cn)_sortDir*=-1;else{_sortCol=cn;_sortDir=1;}_page=1;_renderTable();});})(col.name);tr.appendChild(th);});thead.appendChild(tr);tbody.innerHTML='';pageData.forEach(function(row,ri){var tr2=document.createElement('tr');tr2.style.cssText='border-bottom:1px solid #f1f5f9;'+(ri%2?'background:#fafafa;':'');tr2.addEventListener('mouseenter',function(){tr2.style.background='#f0f9ff';});tr2.addEventListener('mouseleave',function(){tr2.style.background=ri%2?'#fafafa':'';});cols.forEach(function(col){var td=document.createElement('td');td.style.cssText='padding:8px 12px;color:#475569;white-space:nowrap;max-width:200px;overflow:hidden;text-overflow:ellipsis;font-size:13px;';var val=row[col.name];if(val==null){td.textContent='—';td.style.color='#cbd5e1';}else{var t=(col.type||'').toLowerCase();var isNum=t.includes('int')||t.includes('float')||t.includes('double')||t.includes('decimal')||t.includes('numeric');if(isNum&&!isNaN(parseFloat(val))){td.textContent=_fmtFull(parseFloat(val));td.style.textAlign='right';td.style.fontVariantNumeric='tabular-nums';td.style.color='#1e293b';}else td.textContent=String(val);}tr2.appendChild(td);});tbody.appendChild(tr2);});var pi=_q('#dr-page-info');if(pi)pi.textContent='Mostrando '+(total?start+1:0)+'–'+end+' de '+total.toLocaleString('pt-BR')+' registros';var btns=_q('#dr-page-btns');if(!btns)return;btns.innerHTML='';var totalPages=Math.ceil(total/_pageSize);var bS='padding:5px 10px;border:1px solid #e2e8f0;border-radius:6px;font-size:13px;cursor:pointer;background:white;color:#374151;font-family:Inter,sans-serif;';var bD='padding:5px 10px;border:1px solid #f1f5f9;border-radius:6px;font-size:13px;cursor:default;background:#f8fafc;color:#cbd5e1;font-family:Inter,sans-serif;';var bA='padding:5px 10px;border:1px solid #3b82f6;border-radius:6px;font-size:13px;cursor:pointer;background:#3b82f6;color:white;font-weight:600;font-family:Inter,sans-serif;';function mkBtn(text,pg,style,disabled){var b=document.createElement('button');b.textContent=text;b.style.cssText=style;b.disabled=disabled;if(!disabled&&pg!==null)b.addEventListener('click',function(){_page=pg;_renderTable();});btns.appendChild(b);}mkBtn('← Ant.',_page>1?_page-1:1,_page>1?bS:bD,_page<=1);var sp=Math.max(1,_page-2),ep=Math.min(totalPages,_page+2);for(var p=sp;p<=ep;p++)mkBtn(String(p),p,p===_page?bA:bS,false);mkBtn('Próx. →',_page<totalPages?_page+1:_page,_page<totalPages?bS:bD,_page>=totalPages);}
    function init(cont,cfg,data){destroy();_container=cont;_config=cfg;_allData=data||[];_filtered=_allData.slice();_page=1;_sortCol=null;_sortDir=1;_activeFilters={};_buildLayout();_renderKPIs();_buildFilters();_buildCharts();_renderTable();}
    function destroy(){Object.keys(_charts).forEach(function(k){try{_charts[k].destroy();}catch(e){}});_charts={};if(_container)_container.innerHTML='';_container=null;_config=null;_allData=[];_filtered=[];_page=1;_sortCol=null;_sortDir=1;_activeFilters={};}
    return{init:init,destroy:destroy};
  })();

  /* ── Carrega dashboard ── */
  Promise.all([
    axios.get(API + '/dashboards/' + dashboardId),
    axios.get(API + '/dashboards/' + dashboardId + '/data')
  ]).then(function(res) {
    var meta = res[0].data.data;
    var data = res[1].data.data || [];
    document.getElementById('dashboardTitle').textContent = meta.name || 'Dashboard';

    var configJson = meta.config_json;
    if (configJson && typeof configJson === 'object' && configJson.version === 2) {
      /* Novo formato — renderização nativa */
      container.innerHTML = '';
      container.style.background = '#f1f5f9';
      DR.init(container, configJson, data);
    } else if (meta.html_content && meta.html_content.trim()) {
      /* Formato legado — iframe com CDN (backward compat) */
      var html = meta.html_content.trim();
      var bodyStart = html.indexOf('<body');
      var bodyEnd = html.lastIndexOf('</body>');
      var bodyContent = (bodyStart >= 0 && bodyEnd > bodyStart)
        ? html.slice(html.indexOf('>', bodyStart) + 1, bodyEnd).trim()
        : html;
      var openScripts = (bodyContent.match(/<script[\s>]/gi) || []).length;
      var closeScripts = bodyContent.split('</' + 'script>').length - 1;
      if (openScripts > closeScripts) bodyContent += '</' + 'script>';
      var sc = '<' + '/script>';
      var dataStr = JSON.stringify(data);
      var headLibs = '<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">' +
        '<script src="https://cdn.tailwindcss.com">' + sc +
        '<script src="https://cdn.jsdelivr.net/npm/chart.js">' + sc +
        '<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">';
      var fullDoc = '<!DOCTYPE html><html lang="pt-BR"><head>' + headLibs +
        '</head><body><script>window.DASHBOARD_DATA = ' + dataStr + ';' + sc +
        bodyContent + '</body></html>';
      container.innerHTML = '';
      var iframe = document.createElement('iframe');
      iframe.setAttribute('title', 'Dashboard');
      iframe.style.cssText = 'width:100%;height:800px;border:none;';
      container.appendChild(iframe);
      try {
        var doc = iframe.contentDocument || iframe.contentWindow.document;
        doc.open(); doc.write(fullDoc); doc.close();
      } catch (e) {
        container.innerHTML = '<p class="p-6 text-red-500">Erro ao renderizar: ' + e.message + '</p>';
      }
    } else {
      container.innerHTML = '<div class="p-8 text-center text-slate-500"><i class="fas fa-chart-bar text-4xl mb-3 opacity-30"></i><p>Este dashboard não tem conteúdo. Gere um novo em <a href="/ai-dashboards" class="text-blue-600 hover:underline">AI Dashboards</a>.</p></div>';
    }
  }).catch(function(e) {
    container.innerHTML = '<p class="p-6 text-red-500">Erro: ' + (e.response && e.response.data && e.response.data.message || e.message) + '</p>';
  });
})();
</script>
