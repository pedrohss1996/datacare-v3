<div class="max-w-4xl mx-auto px-4 py-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-slate-800">Escalas de cor</h1>
    <div class="flex items-center gap-2">
      <a href="/ai-dashboards" class="px-3 py-1.5 border border-slate-200 rounded-lg text-sm text-slate-600 hover:bg-slate-50">Dashboards</a>
      <button type="button" id="btnNewScale" class="px-4 py-1.5 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700">Nova escala</button>
    </div>
  </div>
  <p class="text-slate-600 mb-6">Crie e salve paletas de cores para usar nos dashboards. As cores são aplicadas aos gráficos (barras, linhas, área, pizza, rosca).</p>

  <div id="scalesList" class="space-y-4">
    <p class="text-slate-500 text-sm">Carregando...</p>
  </div>
</div>

<!-- Modal Nova/Editar Escala -->
<div id="modalScale" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50" onclick="if(event.target===this)closeScaleModal()">
  <div class="bg-white rounded-xl shadow-xl w-full max-w-md" onclick="event.stopPropagation()">
    <div class="px-4 py-3 border-b flex justify-between items-center">
      <h3 class="font-semibold text-slate-800" id="modalScaleTitle">Nova escala de cor</h3>
      <button type="button" onclick="closeScaleModal()" class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
    </div>
    <div class="p-4 space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Nome</label>
        <input type="text" id="scaleName" placeholder="Ex: Verde hospitalar" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-2">Cores (hex, ex: #0d9488)</label>
        <div id="scaleColorsContainer" class="flex flex-wrap gap-2">
          <input type="text" class="scale-color-input w-24 border border-slate-200 rounded px-2 py-1.5 text-sm" placeholder="#hex" maxlength="7">
        </div>
        <button type="button" id="btnAddColor" class="mt-2 text-sm text-blue-600 hover:underline">+ Adicionar cor</button>
      </div>
    </div>
    <div class="px-4 py-3 border-t flex justify-end gap-2">
      <button type="button" onclick="closeScaleModal()" class="px-3 py-1.5 border border-slate-200 rounded-lg text-sm">Cancelar</button>
      <button type="button" id="btnSaveScale" class="px-4 py-1.5 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700">Salvar</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script>
(function() {
  const API = '/api/ai-dashboard';
  let editingId = null;

  function loadScales() {
    axios.get(API + '/color-scales').then(function(r) {
      var list = r.data.data || [];
      var el = document.getElementById('scalesList');
      if (!list.length) {
        el.innerHTML = '<p class="text-slate-500 text-sm">Nenhuma escala. Clique em <b>Nova escala</b> para criar.</p>';
        return;
      }
      el.innerHTML = list.map(function(s) {
        var swatches = (s.colors || []).slice(0, 8).map(function(c) {
          return '<span class="inline-block w-6 h-6 rounded border border-slate-200" style="background:' + c + '" title="' + c + '"></span>';
        }).join('');
        return '<div class="bg-white border border-slate-200 rounded-xl p-4 flex items-center justify-between">' +
          '<div class="flex items-center gap-3">' +
          '<div class="flex gap-0.5">' + swatches + '</div>' +
          '<span class="font-medium text-slate-800">' + (s.name || 'Sem nome') + '</span>' +
          '</div>' +
          '<div class="flex gap-2">' +
          '<button type="button" class="btn-edit-scale px-2 py-1 text-sm text-blue-600 hover:bg-blue-50 rounded" data-id="' + s.id + '">Editar</button>' +
          '<button type="button" class="btn-delete-scale px-2 py-1 text-sm text-red-600 hover:bg-red-50 rounded" data-id="' + s.id + '">Excluir</button>' +
          '</div></div>';
      }).join('');
      el.querySelectorAll('.btn-edit-scale').forEach(function(btn) {
        btn.onclick = function() { openScaleModal(btn.getAttribute('data-id')); };
      });
      el.querySelectorAll('.btn-delete-scale').forEach(function(btn) {
        btn.onclick = function() {
          if (!confirm('Excluir esta escala?')) return;
          axios.delete(API + '/color-scales/' + btn.getAttribute('data-id')).then(function() { loadScales(); }).catch(function(e) { alert(e.response?.data?.message || e.message); });
        };
      });
    }).catch(function() {
      document.getElementById('scalesList').innerHTML = '<p class="text-red-500 text-sm">Erro ao carregar.</p>';
    });
  }

  function openScaleModal(id) {
    editingId = id || null;
    document.getElementById('modalScaleTitle').textContent = editingId ? 'Editar escala' : 'Nova escala de cor';
    document.getElementById('scaleName').value = '';
    var container = document.getElementById('scaleColorsContainer');
    container.innerHTML = '<input type="text" class="scale-color-input w-24 border border-slate-200 rounded px-2 py-1.5 text-sm" placeholder="#hex" maxlength="7">';
    if (editingId) {
      axios.get(API + '/color-scales/' + editingId).then(function(r) {
        var s = r.data.data;
        document.getElementById('scaleName').value = s.name || '';
        var colors = s.colors || [];
        if (colors.length) {
          container.innerHTML = colors.map(function(c) {
            return '<input type="text" class="scale-color-input w-24 border border-slate-200 rounded px-2 py-1.5 text-sm" placeholder="#hex" maxlength="7" value="' + (c || '').replace(/"/g, '&quot;') + '">';
          }).join('');
        }
      }).catch(function() {});
    }
    document.getElementById('modalScale').classList.remove('hidden');
  }

  function closeScaleModal() {
    document.getElementById('modalScale').classList.add('hidden');
    editingId = null;
  }

  function getColorInputs() {
    return Array.from(document.querySelectorAll('#scaleColorsContainer .scale-color-input'))
      .map(function(inp) { return (inp.value || '').trim(); })
      .filter(function(v) { return /^#[0-9A-Fa-f]{6}$/.test(v); });
  }

  document.getElementById('btnNewScale').onclick = function() { openScaleModal(); };

  document.getElementById('btnAddColor').onclick = function() {
    var container = document.getElementById('scaleColorsContainer');
    var inp = document.createElement('input');
    inp.type = 'text';
    inp.className = 'scale-color-input w-24 border border-slate-200 rounded px-2 py-1.5 text-sm';
    inp.placeholder = '#hex';
    inp.maxLength = 7;
    container.appendChild(inp);
  };

  document.getElementById('btnSaveScale').onclick = function() {
    var name = (document.getElementById('scaleName').value || '').trim();
    var colors = getColorInputs();
    if (!name) { alert('Informe o nome da escala.'); return; }
    if (!colors.length) { alert('Informe pelo menos uma cor em hex (ex: #0d9488).'); return; }
    if (editingId) {
      axios.put(API + '/color-scales/' + editingId, { name: name, colors: colors })
        .then(function() { closeScaleModal(); loadScales(); })
        .catch(function(e) { alert(e.response?.data?.message || e.message); });
    } else {
      axios.post(API + '/color-scales', { name: name, colors: colors })
        .then(function() { closeScaleModal(); loadScales(); })
        .catch(function(e) { alert(e.response?.data?.message || e.message); });
    }
  };

  loadScales();
})();
</script>
