<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="h-full bg-slate-50 py-8 overflow-y-auto">
    <div class="max-w-[1600px] mx-auto px-6">
        
        <!-- HEADER -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 mb-6">
            <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4">
                
                <!-- Título e Breadcrumb -->
                <div>
                    <div class="flex items-center gap-2 text-xs text-slate-500 mb-2">
                        <a href="/" class="hover:text-blue-600 transition">Início</a>
                        <i class="fas fa-chevron-right text-[8px]"></i>
                        <a href="/analytics" class="hover:text-blue-600 transition">Construtor IA</a>
                        <i class="fas fa-chevron-right text-[8px]"></i>
                        <span class="text-slate-700 font-medium">Meus Dashboards</span>
                    </div>
                    
                    <div class="flex items-center gap-3">
                        <div class="p-2.5 bg-blue-50 rounded-xl border border-blue-100">
                            <i class="fas fa-chart-line text-xl text-blue-600"></i>
                        </div>
                        <div>
                            <h1 class="text-2xl font-bold text-slate-800">Meus Dashboards</h1>
                            <p class="text-sm text-slate-500">Gerencie seus dashboards criados com IA</p>
                        </div>
                    </div>
                </div>

                <!-- Botão Criar Novo -->
                <a href="/analytics" 
                   class="inline-flex items-center gap-2 px-5 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold shadow-sm hover:shadow-md transition-all">
                    <i class="fas fa-plus-circle"></i>
                    Criar Novo Dashboard
                </a>
            </div>
        </div>

        <!-- ESTATÍSTICAS RÁPIDAS -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
            
            <!-- Card: Total de Dashboards -->
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-slate-500 font-medium uppercase tracking-wide mb-1">
                            Total
                        </p>
                        <p class="text-3xl font-bold text-slate-800">
                            <%= dashboards.length %>
                        </p>
                        <p class="text-xs text-slate-400 mt-1">
                            Dashboard<%= dashboards.length !== 1 ? 's' : '' %>
                        </p>
                    </div>
                    <div class="p-4 bg-blue-50 text-blue-600 rounded-xl">
                        <i class="fas fa-chart-bar text-2xl"></i>
                    </div>
                </div>
            </div>

            <!-- Card: Dashboards Ativos -->
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-slate-500 font-medium uppercase tracking-wide mb-1">
                            Ativos
                        </p>
                        <p class="text-3xl font-bold text-green-600">
                            <%= dashboards.filter(d => d.ativo).length %>
                        </p>
                        <p class="text-xs text-slate-400 mt-1">
                            Em uso
                        </p>
                    </div>
                    <div class="p-4 bg-green-50 text-green-600 rounded-xl">
                        <i class="fas fa-check-circle text-2xl"></i>
                    </div>
                </div>
            </div>

            <!-- Card: Criados com IA -->
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs text-slate-500 font-medium uppercase tracking-wide mb-1">
                            IA Gemini
                        </p>
                        <p class="text-3xl font-bold text-purple-600">
                            <%= dashboards.filter(d => d.grupo_modulo === 'Analytics IA').length %>
                        </p>
                        <p class="text-xs text-slate-400 mt-1">
                            Gerados por IA
                        </p>
                    </div>
                    <div class="p-4 bg-purple-50 text-purple-600 rounded-xl">
                        <i class="fas fa-robot text-2xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- FILTROS E BUSCA -->
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 mb-6">
            <div class="flex flex-col lg:flex-row gap-3">
                
                <!-- Campo de Busca -->
                <div class="flex-1">
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-search text-slate-400"></i>
                        </div>
                        <input 
                            type="text" 
                            id="searchInput" 
                            onkeyup="filterDashboards()"
                            placeholder="Buscar por título ou descrição..."
                            class="w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:bg-white outline-none transition-all text-sm"
                        >
                    </div>
                </div>

                <!-- Filtro por Tipo -->
                <select id="filterTipo" 
                        onchange="filterDashboards()" 
                        class="px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-sm font-medium text-slate-700">
                    <option value="">Todos os Tipos</option>
                    <option value="bar">📊 Gráfico de Barras</option>
                    <option value="line">📈 Gráfico de Linha</option>
                    <option value="pie">🥧 Gráfico de Pizza</option>
                    <option value="area">📉 Gráfico de Área</option>
                    <option value="mixed">🎛️ Dashboard Misto</option>
                </select>

                <!-- Filtro por Grupo -->
                <select id="filterGrupo" 
                        onchange="filterDashboards()" 
                        class="px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-sm font-medium text-slate-700">
                    <option value="">Todos os Grupos</option>
                    <option value="Analytics IA">🤖 Analytics IA</option>
                    <option value="Geral">📁 Geral</option>
                    <option value="Financeiro">💰 Financeiro</option>
                    <option value="Operacional">⚙️ Operacional</option>
                </select>

                <!-- Botão Limpar Filtros -->
                <button onclick="clearFilters()" 
                        class="px-4 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-medium transition-all text-sm border border-slate-200">
                    <i class="fas fa-times-circle mr-1"></i>
                    Limpar
                </button>
            </div>
        </div>

        <!-- GRID DE DASHBOARDS -->
        <div id="dashboardsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            
            <% if (!dashboards || dashboards.length === 0) { %>
                <!-- Estado Vazio -->
                <div class="col-span-full flex flex-col items-center justify-center py-20 bg-white rounded-2xl shadow-sm border-2 border-dashed border-slate-200">
                    <div class="w-20 h-20 bg-slate-50 rounded-2xl flex items-center justify-center mb-4">
                        <i class="fas fa-chart-line text-3xl text-slate-300"></i>
                    </div>
                    <p class="text-slate-600 font-semibold text-lg mb-2">Nenhum dashboard criado ainda</p>
                    <p class="text-slate-400 text-sm mb-6">Crie seu primeiro dashboard com ajuda da IA</p>
                    <a href="/analytics" 
                       class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold shadow-sm hover:shadow-md transition-all">
                        <i class="fas fa-plus-circle"></i>
                        Criar Primeiro Dashboard
                    </a>
                </div>
            <% } %>

            <!-- Cards de Dashboards -->
            <% dashboards.forEach(function(dash) { %>
                <div class="dashboard-card group bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1" 
                     data-titulo="<%= dash.titulo.toLowerCase() %>" 
                     data-descricao="<%= (dash.descricao || '').toLowerCase() %>"
                     data-tipo="<%= dash.tipo_grafico %>"
                     data-grupo="<%= dash.grupo_modulo %>">
                    
                    <!-- Header do Card com Ícone Grande -->
                    <div class="relative bg-gradient-to-br from-slate-50 to-white p-5 border-b border-slate-100">
                        <% 
                        let iconMap = {
                            'bar': 'fa-chart-bar',
                            'line': 'fa-chart-line',
                            'pie': 'fa-chart-pie',
                            'area': 'fa-chart-area',
                            'mixed': 'fa-layer-group'
                        };
                        let colorMap = {
                            'bar': { text: 'text-blue-600', bg: 'bg-blue-50' },
                            'line': { text: 'text-green-600', bg: 'bg-green-50' },
                            'pie': { text: 'text-purple-600', bg: 'bg-purple-50' },
                            'area': { text: 'text-orange-600', bg: 'bg-orange-50' },
                            'mixed': { text: 'text-indigo-600', bg: 'bg-indigo-50' }
                        };
                        let icon = iconMap[dash.tipo_grafico] || 'fa-chart-bar';
                        let colors = colorMap[dash.tipo_grafico] || { text: 'text-slate-600', bg: 'bg-slate-50' };
                        %>
                        
                        <!-- Ícone Grande de Fundo -->
                        <i class="fas <%= icon %> text-5xl <%= colors.text %> opacity-10 absolute right-4 top-1/2 -translate-y-1/2"></i>
                        
                        <div class="relative z-10 flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <div class="p-2.5 <%= colors.bg %> rounded-lg">
                                    <i class="fas <%= icon %> text-lg <%= colors.text %>"></i>
                                </div>
                                <div>
                                    <span class="text-xs font-bold uppercase tracking-wider text-slate-600">
                                        <%= dash.tipo_grafico || 'Dashboard' %>
                                    </span>
                                </div>
                            </div>
                            
                            <!-- Badge IA -->
                            <% if (dash.grupo_modulo === 'Analytics IA') { %>
                                <div class="px-2.5 py-1 bg-gradient-to-r from-purple-500 to-pink-500 text-white rounded-lg shadow-sm text-[10px] font-bold flex items-center gap-1">
                                    <i class="fas fa-robot"></i>
                                    IA
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Conteúdo do Card -->
                    <div class="p-5">
                        <h3 class="text-lg font-bold text-slate-800 mb-2 line-clamp-2 group-hover:text-blue-600 transition-colors">
                            <%= dash.titulo %>
                        </h3>
                        
                        <p class="text-xs text-slate-500 mb-4 line-clamp-3 leading-relaxed">
                            <%= dash.descricao || 'Dashboard sem descrição' %>
                        </p>

                        <!-- Pasta -->
                        <% if (dash.pasta_nome) { %>
                            <div class="mb-3 inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-semibold" style="background-color: <%= dash.pasta_cor || '#6366f1' %>20; color: <%= dash.pasta_cor || '#6366f1' %>; border: 1px solid <%= dash.pasta_cor || '#6366f1' %>40;">
                                <i class="<%= dash.pasta_icone || 'fa-folder' %>"></i>
                                <%= dash.pasta_nome %>
                            </div>
                        <% } else { %>
                            <div class="mb-3 inline-flex items-center gap-2 px-3 py-1.5 bg-slate-100 text-slate-500 rounded-lg text-xs font-semibold border border-slate-200">
                                <i class="fas fa-folder-open"></i>
                                Sem pasta
                            </div>
                        <% } %>
                        
                        <!-- Metadados -->
                        <div class="flex items-center justify-between text-xs mb-4 pb-4 border-b border-slate-100">
                            <span class="flex items-center gap-1.5 text-slate-400">
                                <i class="far fa-calendar"></i>
                                <%= new Date(dash.created_at).toLocaleDateString('pt-BR') %>
                            </span>
                            <span class="px-2.5 py-1 rounded-full font-medium <%= dash.ativo ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-red-50 text-red-700 border border-red-200' %>">
                                <i class="fas fa-circle text-[6px] mr-1"></i>
                                <%= dash.ativo ? 'Ativo' : 'Inativo' %>
                            </span>
                        </div>

                        <!-- Botões de Ação -->
                        <div class="flex gap-2">
                            <button onclick="window.open('/api/analytics/view/<%= dash.slug ? encodeURIComponent(dash.slug) : dash.id %>', '_blank')" 
                               class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold transition-all shadow-sm hover:shadow-md text-sm cursor-pointer">
                                <i class="fas fa-eye"></i>
                                Visualizar
                            </button>
                            
                            <button onclick="deleteDashboard(<%= dash.id %>, '<%= dash.titulo.replace(/'/g, "\\'") %>')" 
                                    class="px-4 py-2.5 bg-red-50 hover:bg-red-100 text-red-600 rounded-lg font-semibold transition-all border border-red-200 text-sm"
                                    title="Excluir Dashboard">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

        <!-- MENSAGEM: Nenhum Resultado Encontrado -->
        <div id="noResults" class="hidden">
            <div class="flex flex-col items-center justify-center py-20 bg-white rounded-2xl shadow-sm border border-slate-200">
                <div class="w-20 h-20 bg-slate-50 rounded-2xl flex items-center justify-center mb-4">
                    <i class="fas fa-search text-3xl text-slate-300"></i>
                </div>
                <p class="text-slate-600 font-semibold text-lg mb-2">Nenhum dashboard encontrado</p>
                <p class="text-slate-400 text-sm mb-6">Tente ajustar os filtros de busca</p>
                <button onclick="clearFilters()" 
                        class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-semibold transition-all">
                    <i class="fas fa-times-circle"></i>
                    Limpar Filtros
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function filterDashboards() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
        const tipoFilter = document.getElementById('filterTipo').value.toLowerCase();
        const grupoFilter = document.getElementById('filterGrupo').value.toLowerCase();
        
        const cards = document.querySelectorAll('.dashboard-card');
        let visibleCount = 0;

        cards.forEach(card => {
            const titulo = card.dataset.titulo;
            const descricao = card.dataset.descricao;
            const tipo = card.dataset.tipo;
            const grupo = card.dataset.grupo.toLowerCase();

            const matchSearch = !searchTerm || titulo.includes(searchTerm) || descricao.includes(searchTerm);
            const matchTipo = !tipoFilter || tipo === tipoFilter;
            const matchGrupo = !grupoFilter || grupo === grupoFilter;

            if (matchSearch && matchTipo && matchGrupo) {
                card.classList.remove('hidden');
                visibleCount++;
            } else {
                card.classList.add('hidden');
            }
        });

        // Mostra/esconde mensagem de "nenhum resultado"
        const gridContainer = document.getElementById('dashboardsGrid');
        const noResultsMsg = document.getElementById('noResults');
        
        if (visibleCount === 0) {
            gridContainer.classList.add('hidden');
            noResultsMsg.classList.remove('hidden');
        } else {
            gridContainer.classList.remove('hidden');
            noResultsMsg.classList.add('hidden');
        }
    }

    function clearFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('filterTipo').value = '';
        document.getElementById('filterGrupo').value = '';
        filterDashboards();
    }

    async function deleteDashboard(id, titulo) {
        // Confirmação com SweetAlert2
        const result = await Swal.fire({
            icon: 'warning',
            title: 'Confirmar Exclusão',
            html: `
                <p class="mb-2">Você está prestes a excluir o dashboard:</p>
                <p class="font-bold text-lg mb-2">"${titulo}"</p>
                <p class="text-sm text-red-600">Esta ação é PERMANENTE e não pode ser desfeita.</p>
            `,
            showCancelButton: true,
            confirmButtonColor: '#dc2626',
            cancelButtonColor: '#64748b',
            confirmButtonText: '<i class="fas fa-trash-alt mr-2"></i>Sim, excluir',
            cancelButtonText: 'Cancelar',
            focusCancel: true
        });

        if (!result.isConfirmed) return;

        // Mostra loading
        Swal.fire({
            title: 'Excluindo...',
            html: 'Por favor, aguarde...',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        try {
            const response = await fetch(`/api/analytics/delete/${id}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            const data = await response.json();

            if (data.success) {
                // Feedback positivo
                await Swal.fire({
                    icon: 'success',
                    title: 'Excluído!',
                    text: 'Dashboard excluído com sucesso!',
                    timer: 1500,
                    showConfirmButton: false
                });
                
                // Remove o card visualmente com animação
                const card = document.querySelector(`.dashboard-card[data-titulo*="${titulo.toLowerCase().substring(0, 20)}"]`);
                if (card) {
                    card.style.opacity = '0';
                    card.style.transform = 'scale(0.9)';
                    setTimeout(() => {
                        window.location.reload();
                    }, 300);
                } else {
                    window.location.reload();
                }
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Erro ao Excluir',
                    text: data.message || 'Erro desconhecido',
                    confirmButtonColor: '#3b82f6'
                });
            }
        } catch (error) {
            console.error('Erro ao deletar dashboard:', error);
            Swal.fire({
                icon: 'error',
                title: 'Erro de Conexão',
                text: error.message,
                confirmButtonColor: '#3b82f6'
            });
        }
    }

    // Atalho de teclado para busca (Ctrl+K ou Cmd+K)
    document.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault();
            document.getElementById('searchInput').focus();
        }
    });
</script>

<style>
    /* Line clamp para textos */
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Animação suave para cards */
    .dashboard-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Scrollbar customizada */
    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }
    
    ::-webkit-scrollbar-track {
        background: #f1f5f9;
        border-radius: 4px;
    }
    
    ::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 4px;
    }
    
    ::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
    }
</style>
