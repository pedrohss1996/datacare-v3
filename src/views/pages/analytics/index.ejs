<!-- Construtor IA - Layout Full-Screen, Assistant Compacto, Visualização Ampliada -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="https://cdn.sheetjs.com/xlsx-0.20.0/package/dist/xlsx.full.min.js" crossorigin="anonymous"></script>
<script src="/js/DataCareAutoDiscovery.js"></script>
<script src="/js/DataCareBI.js"></script>
<script src="/js/DataCareRenderer.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>

<div class="h-screen flex flex-col bg-slate-100 overflow-hidden">
    <!-- Header minimalista -->
    <header class="flex-shrink-0 bg-white border-b border-slate-200 px-4 py-2 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
            <h1 class="text-lg font-bold text-slate-800">Construtor IA</h1>
            <span id="queryBadge" class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-500 hidden">
                <i class="fas fa-database mr-1"></i><span id="lblQueryName">-</span>
            </span>
        </div>
        <div class="flex items-center gap-2">
            <button onclick="openQueryManager()" class="px-3 py-1.5 text-sm border border-slate-200 rounded-lg hover:bg-slate-50 transition">
                <i class="fas fa-database mr-1"></i>Queries
            </button>
            <button onclick="openTemplatesModal()" class="px-3 py-1.5 text-sm border border-purple-200 rounded-lg text-purple-600 bg-purple-50 hover:bg-purple-100 transition">
                <i class="fas fa-magic mr-1"></i>Templates
            </button>
            <button onclick="saveCurrentPage()" class="px-4 py-1.5 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition">
                <i class="fas fa-save mr-1"></i>Salvar
            </button>
        </div>
    </header>

    <!-- Corpo principal: Assistant (estreito) | Visualização (ampliada) -->
    <div class="flex-1 flex min-h-0">
        <!-- Painel Assistant - Compacto, colapsável -->
        <aside id="assistantPanel" class="flex-shrink-0 w-72 bg-white border-r border-slate-200 flex flex-col overflow-hidden transition-all duration-300">
            <div class="p-3 border-b border-slate-100 space-y-2">
                <select id="api_model_construtor" class="w-full text-sm border border-slate-200 rounded-lg px-2.5 py-2 bg-white">
                    <option value="gemini-3-flash-preview" selected>Gemini 3 Flash</option>
                    <option value="gemini-2.5-flash">Gemini 2.5 Flash</option>
                    <option value="gemini-1.5-pro">Gemini 1.5 Pro</option>
                    <option value="gemini-1.5-flash">Gemini 1.5 Flash</option>
                    <option value="gemini-2.0-flash">Gemini 2.0 Flash</option>
                </select>
                <label class="flex items-center gap-2 text-xs text-slate-600 cursor-pointer">
                    <input type="checkbox" id="use_auto_discovery" class="rounded">
                    Auto-Discovery (instantâneo)
                </label>
                <label class="flex items-center gap-2 text-xs text-slate-600 cursor-pointer" title="Por padrão gera página HTML completa. Marque para usar JSON/DataCareBI.">
                    <input type="checkbox" id="chkJsonMode" class="rounded">
                    Modo JSON (DataCareBI)
                </label>
            </div>
            <input id="indicatorNameInput" type="text" placeholder="Nome do indicador" class="mx-3 mt-2 text-sm border border-slate-200 rounded-lg px-2.5 py-2 w-[calc(100%-24px)]">
            <div id="chatHistory" class="flex-1 overflow-y-auto p-2 space-y-2 text-xs"></div>
            <div class="p-3 border-t border-slate-100">
                <textarea id="promptInput" rows="2" placeholder="Ex: Adicione filtro de data / Mude cor do 1º card / Crie dashboard..." class="w-full text-sm border border-slate-200 rounded-lg p-2.5 resize-none focus:ring-2 focus:ring-blue-500"></textarea>
                <button onclick="sendMessage()" class="mt-2 w-full py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium flex items-center justify-center gap-2">
                    <i class="fas fa-paper-plane"></i> Enviar
                </button>
            </div>
        </aside>
        <button id="btnToggleAssistant" onclick="toggleAssistant()" class="flex-shrink-0 w-6 bg-slate-100 hover:bg-slate-200 border-r border-slate-200 flex items-center justify-center text-slate-500 cursor-pointer" title="Ocultar/Mostrar assistant">
            <i class="fas fa-chevron-left text-xs"></i>
        </button>

        <!-- Área de Visualização - Dominante -->
        <main class="flex-1 flex flex-col min-w-0 min-h-0">
            <div class="flex-shrink-0 px-4 py-2 bg-white border-b border-slate-200 flex items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <span id="dashboardTitle" class="font-semibold text-slate-700">Dashboard</span>
                    <div class="flex gap-1">
                        <button id="btnViewDashboard" onclick="setViewMode('dashboard')" class="px-3 py-1.5 text-sm rounded-lg font-medium bg-blue-100 text-blue-700 border border-blue-200">
                            <i class="fas fa-chart-line mr-1"></i>Visualização
                        </button>
                        <button id="btnViewCode" onclick="showHtmlCode()" class="px-3 py-1.5 text-sm rounded-lg font-medium text-slate-600 hover:bg-slate-100 border border-transparent">
                            <i class="fas fa-code mr-1"></i>Código
                        </button>
                    </div>
                    <label class="flex items-center gap-2 text-sm cursor-pointer">
                        <input type="checkbox" id="chkEditMode" onchange="toggleEditMode(this.checked)">
                        <span class="text-slate-600">Editar widgets</span>
                    </label>
                </div>
            </div>
            <div class="flex-1 relative overflow-hidden bg-slate-50">
                <!-- Vista Dashboard -->
                <div id="dashboardContainer" class="absolute inset-0 overflow-y-auto">
                    <div id="dashboard-inner" class="min-h-full flex flex-col items-center justify-center text-slate-400 p-8">
                        <i class="fas fa-chart-pie text-6xl opacity-30 mb-4"></i>
                        <p class="text-sm">Selecione uma query e envie um comando no chat</p>
                        <p class="text-xs mt-1">Por padrão: página HTML completa com KPIs, gráficos e tabela</p>
                    </div>
                </div>
                <!-- Vista Código HTML -->
                <div id="codeViewContainer" class="hidden absolute inset-0 flex flex-col bg-[#282c34]">
                    <div class="flex-shrink-0 px-4 py-2 bg-slate-800 flex justify-between items-center">
                        <span class="text-white text-sm font-medium">Código HTML</span>
                        <div class="flex gap-2">
                            <button id="btnCodeCopy" class="px-3 py-1.5 bg-indigo-600 hover:bg-indigo-500 text-white rounded text-xs">Copiar</button>
                            <button onclick="setViewMode('dashboard')" class="px-3 py-1.5 bg-slate-600 hover:bg-slate-500 text-white rounded text-xs">Voltar</button>
                        </div>
                    </div>
                    <pre class="flex-1 m-0 p-6 overflow-auto text-sm bg-[#282c34]"><code id="codeViewContent" class="language-html text-slate-100"></code></pre>
                    <textarea id="codeViewRaw" class="hidden"></textarea>
                </div>
                <div id="loadingOverlay" class="hidden absolute inset-0 bg-white/90 flex flex-col items-center justify-center z-50">
                    <div class="animate-spin w-12 h-12 border-4 border-blue-100 border-t-blue-600 rounded-full"></div>
                    <p class="mt-4 text-slate-600 font-medium">Processando com Gemini...</p>
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Modal Queries - Layout amplo, editor central -->
<div id="queryModal" class="hidden fixed inset-0 z-50 flex flex-col bg-slate-900" onclick="if(event.target===this)closeQueryManager()">
    <div class="flex-1 flex min-h-0 w-full max-w-[100vw]">
        <!-- Sidebar de queries - compacta -->
        <aside class="w-72 flex-shrink-0 bg-slate-800 border-r border-slate-700 flex flex-col">
            <div class="p-3 border-b border-slate-700 flex items-center justify-between">
                <h3 class="font-semibold text-white text-sm">Queries</h3>
                <button onclick="closeQueryManager()" class="text-slate-400 hover:text-white w-8 h-8 flex items-center justify-center rounded-lg hover:bg-slate-700 transition">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <button onclick="resetEditor()" class="m-3 py-2.5 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm font-medium flex items-center justify-center gap-2 transition">
                <i class="fas fa-plus"></i> Nova Query
            </button>
            <div id="savedQueriesList" class="flex-1 overflow-y-auto p-2 space-y-1">
                <% if (savedWidgets && savedWidgets.length > 0) { %>
                    <% savedWidgets.forEach(widget => { %>
                        <div class="query-item flex items-center gap-2 p-2.5 rounded-lg hover:bg-slate-700/50 cursor-pointer transition group border-l-2 border-l-transparent"
                             data-id="<%= widget.id %>">
                            <i class="fas fa-file-code text-slate-500 text-xs flex-shrink-0 w-4"></i>
                            <span class="font-medium text-slate-200 text-sm truncate flex-1 min-w-0"><%= widget.title %></span>
                            <button onclick="deleteQuery('<%= widget.id %>', event)" class="opacity-0 group-hover:opacity-100 text-slate-400 hover:text-red-400 p-1 rounded flex-shrink-0 transition" title="Excluir">
                                <i class="fas fa-trash-alt text-xs"></i>
                            </button>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="text-center py-8 text-slate-500 text-sm">Nenhuma query salva</div>
                <% } %>
            </div>
        </aside>
        <!-- Editor principal - domina o espaço -->
        <main class="flex-1 flex flex-col min-w-0">
            <div class="flex-shrink-0 bg-slate-800 border-b border-slate-700 px-4 py-2 flex items-center gap-3">
                <input type="hidden" id="editingQueryId">
                <input id="queryNameInput" type="text" placeholder="Nome da query..." class="flex-1 min-w-0 bg-slate-700/50 border border-slate-600 text-white placeholder-slate-400 px-3 py-2 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                <button onclick="runTestInModal()" class="px-4 py-2 bg-amber-600 hover:bg-amber-500 text-white rounded-lg text-sm font-medium flex items-center gap-2 transition shrink-0">
                    <i class="fas fa-play"></i> Testar
                </button>
                <button onclick="saveQueryToLibrary()" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg text-sm font-medium flex items-center gap-2 transition shrink-0">
                    <i class="fas fa-save"></i> Salvar
                </button>
                <button id="btnApply" disabled onclick="openApplyOptionsModal()" class="px-5 py-2 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm font-semibold flex items-center gap-2 transition shrink-0 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-blue-600">
                    <i class="fas fa-check"></i> Usar Esta Query
                </button>
            </div>
            <div class="flex-1 flex flex-col min-h-0">
                <textarea id="modalSqlInput" class="flex-1 w-full bg-slate-900 text-emerald-400 font-mono text-[13px] leading-relaxed p-5 resize-none focus:outline-none focus:ring-0 placeholder-slate-500" placeholder="-- Digite sua query SQL aqui&#10;SELECT * FROM ..." spellcheck="false"></textarea>
                <div id="modalStatusArea" class="flex-shrink-0 h-9 px-4 py-1.5 bg-slate-950 border-t border-slate-800 text-xs text-slate-500 font-mono flex items-center">
                    <i class="fas fa-info-circle mr-2 text-slate-600"></i><span id="modalStatusText">Selecione uma query ou crie uma nova</span>
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Modal Templates -->
<div id="templatesModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center" onclick="if(event.target===this)closeTemplatesModal()">
    <div class="bg-white rounded-xl shadow-2xl w-[90vw] max-w-4xl max-h-[85vh] flex flex-col overflow-hidden">
        <div class="px-6 py-4 border-b flex justify-between">
            <h3 class="font-bold text-slate-800">Templates</h3>
            <button onclick="closeTemplatesModal()" class="text-slate-400 hover:text-red-500"><i class="fas fa-times"></i></button>
        </div>
        <div id="templatesGrid" class="flex-1 overflow-y-auto p-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"></div>
    </div>
</div>

<script>
window.__SAVED_QUERIES__ = <%- (typeof savedWidgets !== 'undefined' && savedWidgets) ? JSON.stringify(savedWidgets.map(w => ({ id: w.id, title: w.title || '', sql: (w.oracle_sql_query || w.query_sql || '').toString() }))).replace(/<\//g, '<\\/') : '[]' %>;
window.__PASTAS__ = <%- (typeof pastas !== 'undefined' && pastas) ? JSON.stringify(pastas) : '[]' %>;
(function() {
    let activeSql = '';
    let activeQueryName = '';
    let currentHtmlCode = '';
    let lastBiConfig = null;
    let lastRawData = null;
    let editMode = false;
    let viewMode = 'dashboard';
    let assistantCollapsed = false;

    function toggleAssistant() {
        assistantCollapsed = !assistantCollapsed;
        const panel = document.getElementById('assistantPanel');
        const btn = document.getElementById('btnToggleAssistant');
        if (assistantCollapsed) {
            panel.classList.add('hidden');
            btn.querySelector('i').className = 'fas fa-chevron-right text-xs';
        } else {
            panel.classList.remove('hidden');
            btn.querySelector('i').className = 'fas fa-chevron-left text-xs';
        }
    }

    function setViewMode(mode) {
        viewMode = mode;
        document.getElementById('dashboardContainer').classList.toggle('hidden', mode === 'code');
        document.getElementById('codeViewContainer').classList.toggle('hidden', mode !== 'code');
        document.getElementById('btnViewDashboard').className = mode === 'dashboard' ? 'px-3 py-1.5 text-sm rounded-lg font-medium bg-blue-100 text-blue-700 border border-blue-200' : 'px-3 py-1.5 text-sm rounded-lg font-medium text-slate-600 hover:bg-slate-100 border border-transparent';
        document.getElementById('btnViewCode').className = mode === 'code' ? 'px-3 py-1.5 text-sm rounded-lg font-medium bg-blue-100 text-blue-700 border border-blue-200' : 'px-3 py-1.5 text-sm rounded-lg font-medium text-slate-600 hover:bg-slate-100 border border-transparent';
    }

    function toggleEditMode(on) {
        editMode = on;
        document.querySelectorAll('[data-widget-id]').forEach(el => {
            const ctrl = el.querySelector('.bi-widget-ctrl');
            if (ctrl) ctrl.classList.toggle('hidden', !on);
        });
    }

    function addMessage(text, type) {
        const history = document.getElementById('chatHistory');
        const isUser = type === 'user';
        const div = document.createElement('div');
        div.className = 'flex gap-2 ' + (isUser ? 'justify-end' : '');
        div.innerHTML = (isUser ? '' : '<div class="w-6 h-6 rounded bg-blue-100 flex items-center justify-center flex-shrink-0"><i class="fas fa-robot text-blue-600 text-[10px]"></i></div>') +
            '<div class="max-w-[90%] p-2 rounded-lg ' + (isUser ? 'bg-blue-600 text-white' : 'bg-slate-100 text-slate-700') + ' text-xs">' + text + '</div>' +
            (isUser ? '<div class="w-6 h-6 rounded bg-slate-200 flex items-center justify-center flex-shrink-0"><i class="fas fa-user text-slate-600 text-[10px]"></i></div>' : '');
        history.appendChild(div);
        history.scrollTop = history.scrollHeight;
    }

    function botReply(t) { addMessage(t, 'bot'); }

    async function sendMessage() {
        const prompt = document.getElementById('promptInput').value.trim();
        if (!prompt) return;
        if (!activeSql) {
            botReply('Selecione uma query em <b>Queries</b> primeiro.');
            return;
        }
        addMessage(prompt, 'user');
        document.getElementById('promptInput').value = '';

        // Padrão: página HTML completa. Marcar "Modo JSON" usa DataCareBI.
        const useJsonMode = document.getElementById('chkJsonMode')?.checked;
        const model = document.getElementById('api_model_construtor')?.value || 'gemini-3-flash-preview';

        if (!useJsonMode) {
            document.getElementById('loadingOverlay').classList.remove('hidden');
            try {
                const payload = {
                    prompt,
                    sqlQuery: activeSql,
                    model,
                    contexto: activeQueryName || undefined
                };
                if (currentHtmlCode && currentHtmlCode !== '<!-- biConfig -->') {
                    payload.currentHtml = currentHtmlCode;
                    payload.modifyExisting = true;
                }
                const res = await fetch('/api/analytics/preview', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                if (data.success && data.previewHtml) {
                    currentHtmlCode = data.previewHtml;
                    lastRawData = data.rawResult || lastRawData;
                    
                    // Validação e logs
                    console.log('📊 [Frontend] Resposta recebida do backend:');
                    console.log('  - previewHtml:', data.previewHtml ? `${data.previewHtml.length} caracteres` : 'vazio');
                    console.log('  - rawResult:', data.rawResult ? (Array.isArray(data.rawResult) ? `${data.rawResult.length} registros` : typeof data.rawResult) : 'null/undefined');
                    console.log('  - metadata:', data.metadata);
                    
                    if (!data.rawResult || !Array.isArray(data.rawResult) || data.rawResult.length === 0) {
                        console.warn('⚠️ [Frontend] ATENÇÃO: rawResult está vazio ou inválido!');
                        console.warn('⚠️ [Frontend] rawResult recebido:', data.rawResult);
                    }
                    
                    renderDashboardHtml(data.previewHtml, data.rawResult);
                    botReply('Dashboard atualizado!');
                } else botReply('Erro: ' + (data.message || 'Falha'));
            } catch (e) { botReply('Erro: ' + e.message); }
            finally { document.getElementById('loadingOverlay').classList.add('hidden'); }
            return;
        }
        await initSmartDashboard({ prompt, sqlQuery: activeSql, model });
    }

    function renderDashboardHtml(html, rawData) {
        try {
            const inner = document.getElementById('dashboard-inner');
            if (!inner) return;
            
            // Valida e injeta dados primeiro
            console.log('📊 [Dashboard] Recebendo dados para renderização...');
            console.log('📊 [Dashboard] rawData:', rawData ? (Array.isArray(rawData) ? `${rawData.length} registros` : typeof rawData) : 'null/undefined');
            
            if (rawData && Array.isArray(rawData)) {
                window.DB_DATA = rawData;
                console.log('✅ [Dashboard] window.DB_DATA definido com', rawData.length, 'registros');
                if (rawData.length > 0) {
                    console.log('📋 [Dashboard] Primeiro registro:', rawData[0]);
                }
            } else {
                console.warn('⚠️ [Dashboard] rawData inválido ou vazio:', rawData);
                window.DB_DATA = [];
            }
            
            // Verifica se há dados limitados (vem do backend via metadata)
            // Isso será definido pelo script injetado no HTML
            
            const wrap = document.getElementById('dashboardContainer');
            if (!wrap) {
                console.error('❌ [Dashboard] Container não encontrado');
                return;
            }
            
            // Limpa scripts antigos do dashboard
            document.querySelectorAll('script[data-dashboard-script]').forEach(s => s.remove());
            
            // Cria container
            wrap.innerHTML = '<div id="dashboard-container" class="p-6 w-full overflow-y-auto"></div>';
            const container = document.getElementById('dashboard-container');
            
            if (!container) {
                console.error('❌ [Dashboard] Container interno não criado');
                return;
            }
            
            // Valida HTML antes de injetar
            if (!html || typeof html !== 'string' || html.trim().length === 0) {
                console.error('❌ [Dashboard] HTML inválido ou vazio');
                container.innerHTML = '<div class="text-center p-8 text-red-600"><i class="fas fa-exclamation-triangle text-4xl mb-4"></i><p>Erro: HTML gerado está vazio ou inválido</p></div>';
                return;
            }
            
            // INJEÇÃO PRIORITÁRIA: Define window.DB_DATA ANTES de injetar HTML
            // Isso garante que os dados estejam disponíveis quando os scripts do dashboard executarem
            if (rawData && Array.isArray(rawData) && rawData.length > 0) {
                window.DB_DATA = rawData;
                console.log('✅ [Dashboard] window.DB_DATA definido ANTES de injetar HTML:', rawData.length, 'registros');
            } else {
                console.warn('⚠️ [Dashboard] rawData inválido ou vazio, window.DB_DATA não será definido previamente');
            }
            
            // Injeta HTML
            try {
                container.innerHTML = html;
                
                // Verifica se window.DB_DATA foi definido pelo HTML injetado
                setTimeout(() => {
                    if (!window.DB_DATA || !Array.isArray(window.DB_DATA) || window.DB_DATA.length === 0) {
                        console.warn('⚠️ [Dashboard] window.DB_DATA não encontrado após injetar HTML. Tentando definir a partir de rawData...');
                        if (rawData && Array.isArray(rawData) && rawData.length > 0) {
                            window.DB_DATA = rawData;
                            console.log('✅ [Dashboard] window.DB_DATA definido a partir de rawData:', rawData.length, 'registros');
                        }
                    }
                }, 100);
            } catch (e) {
                console.error('❌ [Dashboard] Erro ao injetar HTML:', e);
                container.innerHTML = '<div class="text-center p-8 text-red-600"><i class="fas fa-exclamation-triangle text-4xl mb-4"></i><p>Erro ao renderizar dashboard: ' + e.message + '</p></div>';
                return;
            }
            
            // Processa scripts do dashboard
            const scripts = document.querySelectorAll('#dashboard-container script');
            scripts.forEach((s, index) => {
                try {
                    const n = document.createElement('script');
                    n.setAttribute('data-dashboard-script', 'true');
                    
                    if (s.src) {
                        n.src = s.src;
                        n.onerror = () => console.error('❌ [Dashboard] Erro ao carregar script externo:', s.src);
                        document.body.appendChild(n);
                    } else {
                        // Valida e corrige sintaxe JavaScript antes de executar
                        let scriptContent = s.innerHTML || s.textContent || '';
                        if (scriptContent.trim()) {
                            // Verifica se o script contém window.DB_DATA (pode estar cortado)
                            const hasDBData = scriptContent.includes('window.DB_DATA');
                            const hasIncompleteJSON = hasDBData && (
                                (scriptContent.match(/\[/g) || []).length !== (scriptContent.match(/\]/g) || []).length ||
                                (scriptContent.match(/\{/g) || []).length !== (scriptContent.match(/\}/g) || []).length
                            );
                            
                            if (hasIncompleteJSON) {
                                console.warn(`⚠️ [Dashboard] Script ${index + 1} contém JSON incompleto (window.DB_DATA). Tentando extrair código funcional...`);
                                console.warn('Script problemático (primeiros 500 chars):', scriptContent.substring(0, 500));
                                
                                // Tenta extrair apenas a parte funcional (após window.DB_DATA = [...])
                                // Procura por window.initDashboard ou outras funções importantes
                                if (scriptContent.includes('window.initDashboard') || scriptContent.includes('initDashboard')) {
                                    console.log('🔧 [Dashboard] Tentando extrair initDashboard do script cortado...');
                                    
                                    try {
                                        // Remove a parte do window.DB_DATA que está cortada
                                        // Procura pelo padrão: window.DB_DATA = [ ... (cortado)
                                        let cleanScript = scriptContent;
                                        
                                        // Tenta encontrar onde o JSON cortado termina e o código continua
                                        // Procura por padrões como: ]; ou }]; seguido de código
                                        const jsonEndMatch = cleanScript.match(/window\.DB_DATA\s*=\s*\[[^]*?(\];|window\.|function|const|let|var)/);
                                        
                                        if (jsonEndMatch) {
                                            // Encontra a posição onde o código funcional começa
                                            const cutPoint = cleanScript.indexOf('window.DB_DATA');
                                            const afterCut = cleanScript.substring(cutPoint);
                                            
                                            // Tenta encontrar onde o código funcional realmente começa (após o JSON)
                                            // Procura por padrões que indicam início de código funcional
                                            const functionalStart = afterCut.search(/(\]\s*;|window\.initDashboard|function|const|let|var)/);
                                            
                                            if (functionalStart > 0) {
                                                // Pula a parte do JSON cortado e pega o código funcional
                                                const jsonPart = afterCut.substring(0, functionalStart);
                                                const functionalPart = afterCut.substring(functionalStart);
                                                
                                                // Remove a linha com window.DB_DATA = [ (cortada) e mantém o resto
                                                cleanScript = cleanScript.substring(0, cutPoint) + 
                                                    '// window.DB_DATA já foi definido anteriormente\n' +
                                                    functionalPart.replace(/^\s*\]\s*;\s*/, '');
                                                
                                                console.log('🔧 [Dashboard] Código funcional extraído (primeiros 300 chars):', cleanScript.substring(0, 300));
                                                
                                                // Valida sintaxe
                                                try {
                                                    new Function(cleanScript);
                                                    console.log('✅ [Dashboard] Script limpo validado, executando...');
                                                    n.text = cleanScript;
                                                    document.body.appendChild(n);
                                                    return; // Script executado
                                                } catch (validateError) {
                                                    console.warn('⚠️ [Dashboard] Script limpo ainda tem erros:', validateError.message);
                                                }
                                            }
                                        }
                                        
                                        // Fallback: tenta remover apenas a linha problemática
                                        cleanScript = cleanScript.replace(/window\.DB_DATA\s*=\s*\[[^\]]*$/m, '// window.DB_DATA já definido');
                                        
                                        // Se ainda tiver window.DB_DATA, substitui por referência aos dados já definidos
                                        if (cleanScript.includes('window.DB_DATA') && !cleanScript.includes('window.DB_DATA =')) {
                                            // OK, apenas referências
                                        }
                                        
                                        // Tenta executar o script limpo
                                        new Function(cleanScript);
                                        console.log('✅ [Dashboard] Script limpo validado (fallback), executando...');
                                        n.text = cleanScript;
                                        document.body.appendChild(n);
                                        return; // Script executado
                                    } catch (extractError) {
                                        console.warn('⚠️ [Dashboard] Não foi possível extrair código funcional:', extractError.message);
                                    }
                                }
                                
                                // Se não conseguiu extrair, pula o script (dados já foram definidos)
                                console.log('✅ [Dashboard] Pulando script com JSON incompleto - dados já disponíveis em window.DB_DATA');
                                return;
                            }
                            
                            try {
                                // Tenta fazer parse para validar sintaxe
                                new Function(scriptContent);
                                n.text = scriptContent;
                                document.body.appendChild(n);
                            } catch (syntaxError) {
                                console.warn(`⚠️ [Dashboard] Erro de sintaxe no script ${index + 1}:`, syntaxError.message);
                                console.warn('Script problemático (primeiros 500 chars):', scriptContent.substring(0, 500));
                                
                                // Se o script contém window.DB_DATA e já temos dados definidos, pula
                                if (hasDBData && window.DB_DATA && Array.isArray(window.DB_DATA) && window.DB_DATA.length > 0) {
                                    console.log('✅ [Dashboard] Pulando script com erro - window.DB_DATA já está definido com', window.DB_DATA.length, 'registros');
                                    return;
                                }
                                
                                // Tenta corrigir erros comuns
                                let fixedScript = scriptContent;
                                
                                // Remove comentários HTML dentro do script (comum em templates)
                                fixedScript = fixedScript.replace(/<!--[\s\S]*?-->/g, '');
                                
                                // Tenta corrigir parênteses/chaves desbalanceados (básico)
                                const openParens = (fixedScript.match(/\(/g) || []).length;
                                const closeParens = (fixedScript.match(/\)/g) || []).length;
                                const openBraces = (fixedScript.match(/\{/g) || []).length;
                                const closeBraces = (fixedScript.match(/\}/g) || []).length;
                                
                                // Se houver desbalanceamento, tenta adicionar fechamentos
                                if (openParens > closeParens) {
                                    fixedScript += ')'.repeat(openParens - closeParens);
                                }
                                if (openBraces > closeBraces) {
                                    fixedScript += '}'.repeat(openBraces - closeBraces);
                                }
                                
                                // Tenta executar versão corrigida
                                try {
                                    new Function(fixedScript);
                                    console.log('✅ [Dashboard] Script corrigido automaticamente');
                                    n.text = fixedScript;
                                    document.body.appendChild(n);
                                } catch (fixError) {
                                    console.error('❌ [Dashboard] Não foi possível corrigir o script:', fixError.message);
                                    // Se já temos window.DB_DATA definido, não precisa executar este script
                                    if (window.DB_DATA && Array.isArray(window.DB_DATA) && window.DB_DATA.length > 0) {
                                        console.log('✅ [Dashboard] Script com erro ignorado - dados já disponíveis em window.DB_DATA');
                                        return;
                                    }
                                    // Último recurso: tenta executar mesmo com erro
                                    console.warn('⚠️ [Dashboard] Tentando executar script mesmo com erro de sintaxe...');
                                    try {
                                        n.text = scriptContent;
                                        document.body.appendChild(n);
                                    } catch (finalError) {
                                        console.error('❌ [Dashboard] Script rejeitado completamente:', finalError.message);
                                    }
                                }
                            }
                        }
                    }
                } catch (scriptError) {
                    console.error(`❌ [Dashboard] Erro ao processar script ${index + 1}:`, scriptError);
                }
            });
            
            // Garante que DB_DATA está disponível (dupla verificação)
            if (rawData && Array.isArray(rawData) && rawData.length > 0) {
                window.DB_DATA = rawData;
                console.log('✅ [Dashboard] window.DB_DATA confirmado:', window.DB_DATA.length, 'registros');
                console.log('📊 [Dashboard] Primeiro registro confirmado:', window.DB_DATA[0]);
            } else if (rawData && Array.isArray(rawData) && rawData.length === 0) {
                window.DB_DATA = [];
                console.warn('⚠️ [Dashboard] rawData é um array vazio!');
            } else if (!window.DB_DATA || !Array.isArray(window.DB_DATA) || window.DB_DATA.length === 0) {
                // Tenta aguardar um pouco para ver se o script injetado define window.DB_DATA
                setTimeout(() => {
                    if (!window.DB_DATA || !Array.isArray(window.DB_DATA) || window.DB_DATA.length === 0) {
                        window.DB_DATA = [];
                        console.error('❌ [Dashboard] window.DB_DATA não foi definido após 500ms. Dados não disponíveis.');
                        console.error('❌ [Dashboard] rawData recebido:', rawData);
                    }
                }, 500);
            }
            
            // Log final para debug
            console.log('📊 [Dashboard] Estado final - window.DB_DATA:', window.DB_DATA ? (Array.isArray(window.DB_DATA) ? `${window.DB_DATA.length} registros` : typeof window.DB_DATA) : 'undefined');
            
            // Funções auxiliares obrigatórias (fallback se não existirem)
            if (typeof window.toggleFilters === 'undefined') {
                window.toggleFilters = function() {
                    const container = document.getElementById('filters-container');
                    if (container) {
                        container.classList.toggle('hidden');
                    } else {
                        console.warn('⚠️ [Dashboard] Elemento filters-container não encontrado');
                    }
                };
                console.log('✅ [Dashboard] Função toggleFilters criada (fallback)');
            }
            
            // Verifica se window.DB_DATA foi definido após scripts executarem
            setTimeout(function() {
                // Verifica dados - PRIORIDADE: usar rawData se window.DB_DATA não estiver disponível
                if (!window.DB_DATA || !Array.isArray(window.DB_DATA) || window.DB_DATA.length === 0) {
                    console.warn('⚠️ [Dashboard] window.DB_DATA não está disponível após scripts executarem!');
                    console.warn('⚠️ [Dashboard] Tipo:', typeof window.DB_DATA);
                    console.warn('⚠️ [Dashboard] Valor:', window.DB_DATA);
                    
                    // Tenta definir novamente a partir do rawData (FONTE PRIMÁRIA)
                    if (rawData && Array.isArray(rawData) && rawData.length > 0) {
                        window.DB_DATA = rawData;
                        console.log('✅ [Dashboard] window.DB_DATA definido a partir de rawData:', rawData.length, 'registros');
                    } else {
                        console.error('❌ [Dashboard] rawData também está vazio ou inválido!');
                        console.error('❌ [Dashboard] rawData:', rawData);
                    }
                } else {
                    console.log('✅ [Dashboard] window.DB_DATA confirmado:', window.DB_DATA.length, 'registros');
                }
                
                // Verifica se initDashboard foi definida pelos scripts (pode estar em script cortado)
                // Tenta extrair e executar initDashboard dos scripts que falharam
                if (typeof window.initDashboard === 'undefined') {
                    console.warn('⚠️ [Dashboard] initDashboard() não foi definida pelo código gerado. Tentando extrair de scripts...');
                    
                    // Procura por definições de initDashboard nos scripts do container
                    const containerScripts = document.querySelectorAll('#dashboard-container script');
                    let foundInitDashboard = false;
                    
                    containerScripts.forEach((script, idx) => {
                        const content = script.innerHTML || script.textContent || '';
                        // Procura por padrões como: window.initDashboard = function, initDashboard = function, function initDashboard
                        if (content.includes('initDashboard') && !foundInitDashboard) {
                            console.log(`🔍 [Dashboard] Script ${idx} contém referência a initDashboard, tentando executar...`);
                            try {
                                // Tenta executar o script completo (pode ter erro mas pode definir a função)
                                const scriptEl = document.createElement('script');
                                scriptEl.textContent = content;
                                document.body.appendChild(scriptEl);
                                // Remove após tentar executar
                                setTimeout(() => scriptEl.remove(), 100);
                                
                                if (typeof window.initDashboard === 'function') {
                                    foundInitDashboard = true;
                                    console.log('✅ [Dashboard] initDashboard encontrada e definida a partir do script!');
                                }
                            } catch (e) {
                                console.warn(`⚠️ [Dashboard] Erro ao executar script ${idx}:`, e.message);
                            }
                        }
                    });
                }
                
                // Função initDashboard fallback básica (se ainda não existir)
                if (typeof window.initDashboard === 'undefined') {
                    window.initDashboard = function() {
                        console.warn('⚠️ [Dashboard] Usando fallback initDashboard - renderizando dados básicos.');
                        
                        // Garante que window.DB_DATA existe antes de usar
                        if (!window.DB_DATA || !Array.isArray(window.DB_DATA) || window.DB_DATA.length === 0) {
                            if (rawData && Array.isArray(rawData) && rawData.length > 0) {
                                window.DB_DATA = rawData;
                                console.log('✅ [Dashboard] window.DB_DATA definido a partir de rawData no initDashboard');
                            } else {
                                console.error('❌ [Dashboard] Nenhum dado disponível para renderizar!');
                                return;
                            }
                        }
                        
                        const dados = window.DB_DATA;
                        console.log('✅ [Dashboard] Fallback initDashboard executado com', dados.length, 'registros');
                        
                        // Tenta renderizar KPIs básicos se existirem elementos
                        try {
                            const kpiElements = document.querySelectorAll('#dashboard-container [id^="kpi-"], #dashboard-container .kpi-card, #dashboard-container [class*="kpi"], #dashboard-container [id*="kpi"]');
                            if (kpiElements.length > 0) {
                                console.log('📊 [Dashboard] Encontrados', kpiElements.length, 'elementos KPI para atualizar');
                                
                                // Tenta atualizar valores dos KPIs com dados reais
                                kpiElements.forEach((kpiEl, idx) => {
                                    try {
                                        // Procura por elementos de valor dentro do KPI
                                        const valueEl = kpiEl.querySelector('[class*="text-3xl"], [class*="text-4xl"], [id*="value"], .kpi-value, .value, [class*="font-bold"]');
                                        if (valueEl && dados.length > 0) {
                                            // Tenta calcular um valor básico baseado nos dados
                                            const kpiText = (kpiEl.textContent || '').toLowerCase();
                                            const kpiTitle = (kpiEl.querySelector('h3, h4, .title, [class*="title"]')?.textContent || '').toLowerCase();
                                            const allText = (kpiText + ' ' + kpiTitle).toLowerCase();
                                            
                                            let calculatedValue = null;
                                            
                                            // Detecta tipo de KPI pelo texto
                                            if (allText.includes('total') || allText.includes('registros') || allText.includes('quantidade')) {
                                                calculatedValue = dados.length.toLocaleString('pt-BR');
                                            } else if (allText.includes('média') || allText.includes('media') || allText.includes('avg')) {
                                                // Tenta calcular média de algum campo numérico
                                                const numericFields = Object.keys(dados[0]).filter(k => 
                                                    typeof dados[0][k] === 'number' && !isNaN(dados[0][k])
                                                );
                                                if (numericFields.length > 0) {
                                                    const field = numericFields[0];
                                                    const sum = dados.reduce((acc, r) => acc + (r[field] || 0), 0);
                                                    const avg = (sum / dados.length).toFixed(2);
                                                    calculatedValue = avg;
                                                }
                                            } else if (allText.includes('soma') || allText.includes('sum') || allText.includes('total valor')) {
                                                const numericFields = Object.keys(dados[0]).filter(k => 
                                                    typeof dados[0][k] === 'number' && !isNaN(dados[0][k])
                                                );
                                                if (numericFields.length > 0) {
                                                    const field = numericFields[0];
                                                    const sum = dados.reduce((acc, r) => acc + (r[field] || 0), 0);
                                                    calculatedValue = sum.toLocaleString('pt-BR');
                                                }
                                            }
                                            
                                            if (calculatedValue !== null) {
                                                valueEl.textContent = calculatedValue;
                                                console.log(`✅ [Dashboard] KPI ${idx} atualizado:`, calculatedValue);
                                            } else {
                                                // Fallback: mostra total de registros
                                                valueEl.textContent = dados.length.toLocaleString('pt-BR');
                                            }
                                        }
                                    } catch (e) {
                                        console.warn(`⚠️ [Dashboard] Erro ao atualizar KPI ${idx}:`, e);
                                    }
                                });
                            }
                            
                            // Tenta atualizar gráficos se existirem (Chart.js precisa ser inicializado pelo código da IA)
                            const chartElements = document.querySelectorAll('#dashboard-container canvas, #dashboard-container [id*="chart"], #dashboard-container [class*="chart"]');
                            if (chartElements.length > 0) {
                                console.log('📊 [Dashboard] Encontrados', chartElements.length, 'elementos de gráfico');
                                console.log('ℹ️ [Dashboard] Gráficos Chart.js precisam ser inicializados pelo código gerado pela IA');
                            }
                            
                            // Tenta atualizar tabelas se existirem
                            const tableBodies = document.querySelectorAll('#dashboard-container tbody');
                            if (tableBodies.length > 0 && dados.length > 0) {
                                console.log('📊 [Dashboard] Encontradas', tableBodies.length, 'tabelas para atualizar');
                                // Nota: Tabelas precisam ser renderizadas pelo código da IA com estrutura específica
                            }
                        } catch (e) {
                            console.warn('⚠️ [Dashboard] Erro ao tentar atualizar elementos:', e);
                        }
                    };
                    console.log('✅ [Dashboard] Função initDashboard criada (fallback básico)');
                }
                
                // Tenta executar initDashboard
                if (typeof window.initDashboard === 'function') {
                    try {
                        window.initDashboard();
                    } catch (initError) {
                        console.error('❌ [Dashboard] Erro ao executar initDashboard:', initError);
                        console.error('Stack:', initError.stack);
                    }
                } else {
                    console.error('❌ [Dashboard] initDashboard() não encontrada mesmo após fallback');
                }
            }, 500);
            
        } catch (error) {
            console.error('❌ [Dashboard] Erro geral ao renderizar:', error);
            const wrap = document.getElementById('dashboardContainer');
            if (wrap) {
                wrap.innerHTML = '<div class="text-center p-8 text-red-600"><i class="fas fa-exclamation-triangle text-4xl mb-4"></i><p>Erro ao renderizar dashboard: ' + error.message + '</p></div>';
            }
        }
    }

