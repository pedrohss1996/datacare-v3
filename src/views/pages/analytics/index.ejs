<!-- Construtor IA - Layout Full-Screen, Assistant Compacto, Visualização Ampliada -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="https://cdn.sheetjs.com/xlsx-0.20.0/package/dist/xlsx.full.min.js" crossorigin="anonymous"></script>
<script src="/js/DataCareAutoDiscovery.js"></script>
<script src="/js/DataCareBI.js"></script>
<script src="/js/DataCareRenderer.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>

<div class="h-screen flex flex-col bg-slate-100 overflow-hidden">
    <!-- Header minimalista -->
    <header class="flex-shrink-0 bg-white border-b border-slate-200 px-4 py-2 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
            <h1 class="text-lg font-bold text-slate-800">Construtor IA</h1>
            <span id="queryBadge" class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-500 hidden">
                <i class="fas fa-database mr-1"></i><span id="lblQueryName">-</span>
            </span>
        </div>
        <div class="flex items-center gap-2">
            <button onclick="openQueryManager()" class="px-3 py-1.5 text-sm border border-slate-200 rounded-lg hover:bg-slate-50 transition">
                <i class="fas fa-database mr-1"></i>Queries
            </button>
            <button onclick="openTemplatesModal()" class="px-3 py-1.5 text-sm border border-purple-200 rounded-lg text-purple-600 bg-purple-50 hover:bg-purple-100 transition">
                <i class="fas fa-magic mr-1"></i>Templates
            </button>
            <button onclick="saveCurrentPage()" class="px-4 py-1.5 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition">
                <i class="fas fa-save mr-1"></i>Salvar
            </button>
        </div>
    </header>

    <!-- Corpo principal: Assistant (estreito) | Visualização (ampliada) -->
    <div class="flex-1 flex min-h-0">
        <!-- Painel Assistant - Compacto, colapsável -->
        <aside id="assistantPanel" class="flex-shrink-0 w-72 bg-white border-r border-slate-200 flex flex-col overflow-hidden transition-all duration-300">
            <div class="p-3 border-b border-slate-100 space-y-2">
                <select id="api_model_construtor" class="w-full text-sm border border-slate-200 rounded-lg px-2.5 py-2 bg-white">
                    <option value="gemini-3-flash-preview" selected>Gemini 3 Flash</option>
                    <option value="gemini-2.5-flash">Gemini 2.5 Flash</option>
                    <option value="gemini-1.5-pro">Gemini 1.5 Pro</option>
                    <option value="gemini-1.5-flash">Gemini 1.5 Flash</option>
                    <option value="gemini-2.0-flash">Gemini 2.0 Flash</option>
                </select>
                <label class="flex items-center gap-2 text-xs text-slate-600 cursor-pointer">
                    <input type="checkbox" id="use_auto_discovery" class="rounded">
                    Auto-Discovery (instantâneo)
                </label>
                <label class="flex items-center gap-2 text-xs text-slate-600 cursor-pointer" title="Por padrão gera página HTML completa. Marque para usar JSON/DataCareBI.">
                    <input type="checkbox" id="chkJsonMode" class="rounded">
                    Modo JSON (DataCareBI)
                </label>
            </div>
            <input id="indicatorNameInput" type="text" placeholder="Nome do indicador" class="mx-3 mt-2 text-sm border border-slate-200 rounded-lg px-2.5 py-2 w-[calc(100%-24px)]">
            <div id="chatHistory" class="flex-1 overflow-y-auto p-2 space-y-2 text-xs"></div>
            <div class="p-3 border-t border-slate-100">
                <textarea id="promptInput" rows="2" placeholder="Ex: Adicione filtro de data / Mude cor do 1º card / Crie dashboard..." class="w-full text-sm border border-slate-200 rounded-lg p-2.5 resize-none focus:ring-2 focus:ring-blue-500"></textarea>
                <button onclick="sendMessage()" class="mt-2 w-full py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium flex items-center justify-center gap-2">
                    <i class="fas fa-paper-plane"></i> Enviar
                </button>
            </div>
        </aside>
        <button id="btnToggleAssistant" onclick="toggleAssistant()" class="flex-shrink-0 w-6 bg-slate-100 hover:bg-slate-200 border-r border-slate-200 flex items-center justify-center text-slate-500 cursor-pointer" title="Ocultar/Mostrar assistant">
            <i class="fas fa-chevron-left text-xs"></i>
        </button>

        <!-- Área de Visualização - Dominante -->
        <main class="flex-1 flex flex-col min-w-0 min-h-0">
            <div class="flex-shrink-0 px-4 py-2 bg-white border-b border-slate-200 flex items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <span id="dashboardTitle" class="font-semibold text-slate-700">Dashboard</span>
                    <div class="flex gap-1">
                        <button id="btnViewDashboard" onclick="setViewMode('dashboard')" class="px-3 py-1.5 text-sm rounded-lg font-medium bg-blue-100 text-blue-700 border border-blue-200">
                            <i class="fas fa-chart-line mr-1"></i>Visualização
                        </button>
                        <button id="btnViewCode" onclick="showHtmlCode()" class="px-3 py-1.5 text-sm rounded-lg font-medium text-slate-600 hover:bg-slate-100 border border-transparent">
                            <i class="fas fa-code mr-1"></i>Código
                        </button>
                    </div>
                    <label class="flex items-center gap-2 text-sm cursor-pointer">
                        <input type="checkbox" id="chkEditMode" onchange="toggleEditMode(this.checked)">
                        <span class="text-slate-600">Editar widgets</span>
                    </label>
                </div>
            </div>
            <div class="flex-1 relative overflow-hidden bg-slate-50">
                <!-- Vista Dashboard -->
                <div id="dashboardContainer" class="absolute inset-0 overflow-y-auto">
                    <div id="dashboard-inner" class="min-h-full flex flex-col items-center justify-center text-slate-400 p-8">
                        <i class="fas fa-chart-pie text-6xl opacity-30 mb-4"></i>
                        <p class="text-sm">Selecione uma query e envie um comando no chat</p>
                        <p class="text-xs mt-1">Por padrão: página HTML completa com KPIs, gráficos e tabela</p>
                    </div>
                </div>
                <!-- Vista Código HTML -->
                <div id="codeViewContainer" class="hidden absolute inset-0 flex flex-col bg-[#282c34]">
                    <div class="flex-shrink-0 px-4 py-2 bg-slate-800 flex justify-between items-center">
                        <span class="text-white text-sm font-medium">Código HTML</span>
                        <div class="flex gap-2">
                            <button id="btnCodeCopy" class="px-3 py-1.5 bg-indigo-600 hover:bg-indigo-500 text-white rounded text-xs">Copiar</button>
                            <button onclick="setViewMode('dashboard')" class="px-3 py-1.5 bg-slate-600 hover:bg-slate-500 text-white rounded text-xs">Voltar</button>
                        </div>
                    </div>
                    <pre class="flex-1 m-0 p-6 overflow-auto text-sm"><code id="codeViewContent" class="language-html"></code></pre>
                    <textarea id="codeViewRaw" class="hidden"></textarea>
                </div>
                <div id="loadingOverlay" class="hidden absolute inset-0 bg-white/90 flex flex-col items-center justify-center z-50">
                    <div class="animate-spin w-12 h-12 border-4 border-blue-100 border-t-blue-600 rounded-full"></div>
                    <p class="mt-4 text-slate-600 font-medium">Processando com Gemini...</p>
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Modal Queries - Layout amplo, editor central -->
<div id="queryModal" class="hidden fixed inset-0 z-50 flex flex-col bg-slate-900" onclick="if(event.target===this)closeQueryManager()">
    <div class="flex-1 flex min-h-0 w-full max-w-[100vw]">
        <!-- Sidebar de queries - compacta -->
        <aside class="w-72 flex-shrink-0 bg-slate-800 border-r border-slate-700 flex flex-col">
            <div class="p-3 border-b border-slate-700 flex items-center justify-between">
                <h3 class="font-semibold text-white text-sm">Queries</h3>
                <button onclick="closeQueryManager()" class="text-slate-400 hover:text-white w-8 h-8 flex items-center justify-center rounded-lg hover:bg-slate-700 transition">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <button onclick="resetEditor()" class="m-3 py-2.5 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm font-medium flex items-center justify-center gap-2 transition">
                <i class="fas fa-plus"></i> Nova Query
            </button>
            <div id="savedQueriesList" class="flex-1 overflow-y-auto p-2 space-y-1">
                <% if (savedWidgets && savedWidgets.length > 0) { %>
                    <% savedWidgets.forEach(widget => { %>
                        <div class="query-item flex items-center gap-2 p-2.5 rounded-lg hover:bg-slate-700/50 cursor-pointer transition group border-l-2 border-l-transparent"
                             data-id="<%= widget.id %>">
                            <i class="fas fa-file-code text-slate-500 text-xs flex-shrink-0 w-4"></i>
                            <span class="font-medium text-slate-200 text-sm truncate flex-1 min-w-0"><%= widget.title %></span>
                            <button onclick="deleteQuery('<%= widget.id %>', event)" class="opacity-0 group-hover:opacity-100 text-slate-400 hover:text-red-400 p-1 rounded flex-shrink-0 transition" title="Excluir">
                                <i class="fas fa-trash-alt text-xs"></i>
                            </button>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="text-center py-8 text-slate-500 text-sm">Nenhuma query salva</div>
                <% } %>
            </div>
        </aside>
        <!-- Editor principal - domina o espaço -->
        <main class="flex-1 flex flex-col min-w-0">
            <div class="flex-shrink-0 bg-slate-800 border-b border-slate-700 px-4 py-2 flex items-center gap-3">
                <input type="hidden" id="editingQueryId">
                <input id="queryNameInput" type="text" placeholder="Nome da query..." class="flex-1 min-w-0 bg-slate-700/50 border border-slate-600 text-white placeholder-slate-400 px-3 py-2 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                <button onclick="runTestInModal()" class="px-4 py-2 bg-amber-600 hover:bg-amber-500 text-white rounded-lg text-sm font-medium flex items-center gap-2 transition shrink-0">
                    <i class="fas fa-play"></i> Testar
                </button>
                <button onclick="saveQueryToLibrary()" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg text-sm font-medium flex items-center gap-2 transition shrink-0">
                    <i class="fas fa-save"></i> Salvar
                </button>
                <button id="btnApply" disabled onclick="openApplyOptionsModal()" class="px-5 py-2 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm font-semibold flex items-center gap-2 transition shrink-0 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-blue-600">
                    <i class="fas fa-check"></i> Usar Esta Query
                </button>
            </div>
            <div class="flex-1 flex flex-col min-h-0">
                <textarea id="modalSqlInput" class="flex-1 w-full bg-slate-900 text-emerald-400 font-mono text-[13px] leading-relaxed p-5 resize-none focus:outline-none focus:ring-0 placeholder-slate-500" placeholder="-- Digite sua query SQL aqui&#10;SELECT * FROM ..." spellcheck="false"></textarea>
                <div id="modalStatusArea" class="flex-shrink-0 h-9 px-4 py-1.5 bg-slate-950 border-t border-slate-800 text-xs text-slate-500 font-mono flex items-center">
                    <i class="fas fa-info-circle mr-2 text-slate-600"></i><span id="modalStatusText">Selecione uma query ou crie uma nova</span>
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Modal Templates -->
<div id="templatesModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center" onclick="if(event.target===this)closeTemplatesModal()">
    <div class="bg-white rounded-xl shadow-2xl w-[90vw] max-w-4xl max-h-[85vh] flex flex-col overflow-hidden">
        <div class="px-6 py-4 border-b flex justify-between">
            <h3 class="font-bold text-slate-800">Templates</h3>
            <button onclick="closeTemplatesModal()" class="text-slate-400 hover:text-red-500"><i class="fas fa-times"></i></button>
        </div>
        <div id="templatesGrid" class="flex-1 overflow-y-auto p-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"></div>
    </div>
</div>

<script>
window.__SAVED_QUERIES__ = <%- (typeof savedWidgets !== 'undefined' && savedWidgets) ? JSON.stringify(savedWidgets.map(w => ({ id: w.id, title: w.title || '', sql: (w.oracle_sql_query || w.query_sql || '').toString() }))).replace(/<\//g, '<\\/') : '[]' %>;
window.__PASTAS__ = <%- (typeof pastas !== 'undefined' && pastas) ? JSON.stringify(pastas) : '[]' %>;
(function() {
    let activeSql = '';
    let activeQueryName = '';
    let currentHtmlCode = '';
    let lastBiConfig = null;
    let lastRawData = null;
    let editMode = false;
    let viewMode = 'dashboard';
    let assistantCollapsed = false;

    function toggleAssistant() {
        assistantCollapsed = !assistantCollapsed;
        const panel = document.getElementById('assistantPanel');
        const btn = document.getElementById('btnToggleAssistant');
        if (assistantCollapsed) {
            panel.classList.add('hidden');
            btn.querySelector('i').className = 'fas fa-chevron-right text-xs';
        } else {
            panel.classList.remove('hidden');
            btn.querySelector('i').className = 'fas fa-chevron-left text-xs';
        }
    }

    function setViewMode(mode) {
        viewMode = mode;
        document.getElementById('dashboardContainer').classList.toggle('hidden', mode === 'code');
        document.getElementById('codeViewContainer').classList.toggle('hidden', mode !== 'code');
        document.getElementById('btnViewDashboard').className = mode === 'dashboard' ? 'px-3 py-1.5 text-sm rounded-lg font-medium bg-blue-100 text-blue-700 border border-blue-200' : 'px-3 py-1.5 text-sm rounded-lg font-medium text-slate-600 hover:bg-slate-100 border border-transparent';
        document.getElementById('btnViewCode').className = mode === 'code' ? 'px-3 py-1.5 text-sm rounded-lg font-medium bg-blue-100 text-blue-700 border border-blue-200' : 'px-3 py-1.5 text-sm rounded-lg font-medium text-slate-600 hover:bg-slate-100 border border-transparent';
    }

    function toggleEditMode(on) {
        editMode = on;
        document.querySelectorAll('[data-widget-id]').forEach(el => {
            const ctrl = el.querySelector('.bi-widget-ctrl');
            if (ctrl) ctrl.classList.toggle('hidden', !on);
        });
    }

    function addMessage(text, type) {
        const history = document.getElementById('chatHistory');
        const isUser = type === 'user';
        const div = document.createElement('div');
        div.className = 'flex gap-2 ' + (isUser ? 'justify-end' : '');
        div.innerHTML = (isUser ? '' : '<div class="w-6 h-6 rounded bg-blue-100 flex items-center justify-center flex-shrink-0"><i class="fas fa-robot text-blue-600 text-[10px]"></i></div>') +
            '<div class="max-w-[90%] p-2 rounded-lg ' + (isUser ? 'bg-blue-600 text-white' : 'bg-slate-100 text-slate-700') + ' text-xs">' + text + '</div>' +
            (isUser ? '<div class="w-6 h-6 rounded bg-slate-200 flex items-center justify-center flex-shrink-0"><i class="fas fa-user text-slate-600 text-[10px]"></i></div>' : '');
        history.appendChild(div);
        history.scrollTop = history.scrollHeight;
    }

    function botReply(t) { addMessage(t, 'bot'); }

    async function sendMessage() {
        const prompt = document.getElementById('promptInput').value.trim();
        if (!prompt) return;
        if (!activeSql) {
            botReply('Selecione uma query em <b>Queries</b> primeiro.');
            return;
        }
        addMessage(prompt, 'user');
        document.getElementById('promptInput').value = '';

        // Padrão: página HTML completa. Marcar "Modo JSON" usa DataCareBI.
        const useJsonMode = document.getElementById('chkJsonMode')?.checked;
        const model = document.getElementById('api_model_construtor')?.value || 'gemini-3-flash-preview';

        if (!useJsonMode) {
            document.getElementById('loadingOverlay').classList.remove('hidden');
            try {
                const payload = {
                    prompt,
                    sqlQuery: activeSql,
                    model,
                    contexto: activeQueryName || undefined
                };
                if (currentHtmlCode && currentHtmlCode !== '<!-- biConfig -->') {
                    payload.currentHtml = currentHtmlCode;
                    payload.modifyExisting = true;
                }
                const res = await fetch('/api/analytics/preview', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                if (data.success && data.previewHtml) {
                    currentHtmlCode = data.previewHtml;
                    lastRawData = data.rawResult || lastRawData;
                    renderDashboardHtml(data.previewHtml, data.rawResult);
                    botReply('Dashboard atualizado!');
                } else botReply('Erro: ' + (data.message || 'Falha'));
            } catch (e) { botReply('Erro: ' + e.message); }
            finally { document.getElementById('loadingOverlay').classList.add('hidden'); }
            return;
        }
        await initSmartDashboard({ prompt, sqlQuery: activeSql, model });
    }

    function renderDashboardHtml(html, rawData) {
        const inner = document.getElementById('dashboard-inner');
        if (!inner) return;
        if (rawData && Array.isArray(rawData)) {
            window.DB_DATA = rawData;
        }
        const wrap = document.getElementById('dashboardContainer');
        wrap.innerHTML = '<div id="dashboard-container" class="p-6 w-full overflow-y-auto"></div>';
        document.getElementById('dashboard-container').innerHTML = html;
        [].slice.call(document.querySelectorAll('#dashboard-container script')).forEach(s => {
            const n = document.createElement('script');
            if (s.src) n.src = s.src; else n.text = s.innerHTML;
            document.body.appendChild(n);
        });
        if (rawData && Array.isArray(rawData)) window.DB_DATA = rawData;
        setTimeout(function() {
            if (typeof window.initDashboard === 'function') window.initDashboard();
        }, 150);
    }

    function renderSkeleton() {
        const wrap = document.getElementById('dashboardContainer');
        wrap.innerHTML = `<div id="dashboard-container" class="p-6 overflow-y-auto">
            <div class="h-8 bg-slate-200 rounded w-1/4 mb-6 animate-pulse"></div>
            <div class="grid grid-cols-4 gap-4 mb-6">
                <div class="h-28 bg-slate-200 rounded-xl animate-pulse"></div>
                <div class="h-28 bg-slate-200 rounded-xl animate-pulse"></div>
                <div class="h-28 bg-slate-200 rounded-xl animate-pulse"></div>
                <div class="h-28 bg-slate-200 rounded-xl animate-pulse"></div>
            </div>
            <div class="grid grid-cols-2 gap-6 mb-6">
                <div class="h-72 bg-slate-200 rounded-xl animate-pulse"></div>
                <div class="h-72 bg-slate-200 rounded-xl animate-pulse"></div>
            </div>
        </div>`;
    }

    async function initSmartDashboard(req) {
        renderSkeleton();
        botReply('Gerando dashboard...');
        document.getElementById('loadingOverlay').classList.remove('hidden');

        try {
            if (typeof DataCareRenderer !== 'undefined' && typeof DataCareBI !== 'undefined') {
                const result = await DataCareRenderer.renderEliteDashboard({
                    userPrompt: req.prompt,
                    prompt: req.prompt,
                    sqlQuery: req.sqlQuery,
                    model: req.model || document.getElementById('api_model_construtor')?.value,
                    okrContext: req.okrContext || '',
                    autoGenerateOKRs: req.autoGenerateOKRs,
                    useStream: false,
                    useAutoDiscovery: document.getElementById('use_auto_discovery')?.checked || false
                }, 'dashboard-container');
                document.getElementById('loadingOverlay').classList.add('hidden');
                if (result?.success) {
                    lastBiConfig = result.biConfig;
                    lastRawData = result.rawResult;
                    currentHtmlCode = '<!-- biConfig -->';
                    document.getElementById('dashboardTitle').textContent = lastBiConfig?.header?.title || activeQueryName || 'Dashboard';
                    botReply('Dashboard pronto!');
                    attachWidgetControls();
                } else botReply('Erro: ' + (result?.error || 'Falha'));
                return;
            }
            const res = await fetch('/api/analytics/init', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(req)
            });
            const data = await res.json().catch(() => ({}));
            document.getElementById('loadingOverlay').classList.add('hidden');
            if (!data.success) {
                botReply('Erro: ' + (data.message || 'Falha'));
                return;
            }
            lastBiConfig = data.biConfig;
            lastRawData = data.rawResult;
            if (typeof DataCareBI !== 'undefined') {
                DataCareBI.applyLayout(data.biConfig, 'dashboard-container');
                DataCareBI.updateWidgetsWithData(data.biConfig, data.rawResult, 'dashboard-container');
                DataCareBI.attachSmartActions?.(data.biConfig, 'dashboard-container');
            }
            document.getElementById('dashboardTitle').textContent = data.biConfig?.header?.title || activeQueryName || 'Dashboard';
            botReply('Dashboard pronto!');
            attachWidgetControls();
        } catch (e) {
            document.getElementById('loadingOverlay').classList.add('hidden');
            botReply('Erro: ' + e.message);
        }
    }

    function attachWidgetControls() {
        if (typeof DataCareBI !== 'undefined' && DataCareBI.setEditMode) {
            DataCareBI.setEditMode(editMode);
            DataCareBI.onWidgetRemove = removeWidget;
        }
    }

    function removeWidget(widgetId, widgetType) {
        if (!lastBiConfig?.widgets || !lastRawData) return;
        lastBiConfig.widgets = lastBiConfig.widgets.filter(w => w.id !== widgetId);
        if (typeof DataCareBI !== 'undefined') {
            DataCareBI.applyLayout(lastBiConfig, 'dashboard-container');
            DataCareBI.updateWidgetsWithData(lastBiConfig, lastRawData, 'dashboard-container');
            document.getElementById('chkEditMode').checked && DataCareBI.setEditMode(true);
        }
        botReply('Widget removido.');
    }

    async function showHtmlCode() {
        if (!lastBiConfig) {
            Swal.fire({ icon: 'warning', title: 'Gere um dashboard primeiro', confirmButtonColor: '#3b82f6' });
            return;
        }
        Swal.fire({ title: 'Gerando...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
        try {
            const res = await fetch('/api/analytics/generate-page', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ biConfig: lastBiConfig, queryCode: 'QUERY_ID', formCode: 'FORM_ACTION' })
            });
            const html = await res.text();
            Swal.close();
            if (res.ok) {
                document.getElementById('codeViewRaw').value = html;
                const codeEl = document.getElementById('codeViewContent');
                codeEl.textContent = html;
                if (window.hljs) hljs.highlightElement(codeEl);
                document.getElementById('btnCodeCopy').onclick = () => navigator.clipboard.writeText(html).then(() => Swal.fire({ icon: 'success', title: 'Copiado!', timer: 1000, showConfirmButton: false }));
                setViewMode('code');
            } else Swal.fire({ icon: 'error', text: 'Falha ao gerar' });
        } catch (e) { Swal.close(); Swal.fire({ icon: 'error', text: e.message }); }
    }

    function openQueryManager() { document.getElementById('queryModal').classList.remove('hidden'); }
    function closeQueryManager() { document.getElementById('queryModal').classList.add('hidden'); }
    function setModalStatus(txt) {
        const el = document.getElementById('modalStatusText');
        if (el) el.textContent = txt;
    }
    function resetEditor() {
        document.getElementById('editingQueryId').value = '';
        document.getElementById('modalSqlInput').value = '';
        document.getElementById('queryNameInput').value = '';
        setModalStatus('Pronto para nova query');
        document.getElementById('btnApply').disabled = true;
    }
    function loadQueryIntoEditor(id, sql, title) {
        document.getElementById('editingQueryId').value = id || '';
        document.getElementById('modalSqlInput').value = sql || '';
        document.getElementById('queryNameInput').value = title || '';
        setModalStatus('Carregada: ' + title);
        document.getElementById('btnApply').disabled = false;
        document.querySelectorAll('.query-item').forEach(el => {
            el.classList.remove('bg-blue-600/20', 'border-l-blue-500', 'border-l-transparent');
            if (String(el.dataset.id) === String(id)) {
                el.classList.add('bg-blue-600/20', 'border-l-2', 'border-l-blue-500');
            } else {
                el.classList.add('border-l-2', 'border-l-transparent');
            }
        });
    }
    document.getElementById('queryModal')?.addEventListener('click', function(e) {
        const item = e.target.closest('.query-item');
        if (item) {
            const id = item.getAttribute('data-id');
            const q = (window.__SAVED_QUERIES__ || []).find(x => String(x.id) === String(id));
            if (q) loadQueryIntoEditor(q.id, q.sql || '', q.title || '');
        }
    });
    function enableApplyButton(title) {
        document.getElementById('btnApply').disabled = false;
        setModalStatus('Pronto para usar: ' + (title || ''));
    }
    async function runTestInModal() {
        const sql = document.getElementById('modalSqlInput').value;
        if (!sql) { setModalStatus('Digite uma query primeiro'); return; }
        setModalStatus('Executando...');
        try {
            const res = await fetch('/api/analytics/preview', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sqlQuery: sql, prompt: 'Teste' }) });
            const data = await res.json();
            if (data.success && data.rawResult) {
                setModalStatus('✓ ' + data.rawResult.length + ' linhas retornadas');
                enableApplyButton(document.getElementById('queryNameInput').value);
            } else setModalStatus('✗ Erro: ' + (data.message || ''));
        } catch (e) { setModalStatus('✗ Erro de conexão'); }
    }
    async function deleteQuery(id, e) { e.stopPropagation(); if (!await Swal.fire({ icon: 'warning', title: 'Excluir?', showCancelButton: true, confirmButtonText: 'Sim' }).then(r => r.isConfirmed)) return; try { const res = await fetch('/api/analytics/delete-query/' + id, { method: 'POST' }); const d = await res.json(); if (d.success) { Swal.fire({ icon: 'success', timer: 1500, showConfirmButton: false }); location.reload(); } else Swal.fire({ icon: 'error', text: d.message }); } catch (e) { Swal.fire({ icon: 'error', text: e.message }); } }
    async function saveQueryToLibrary() {
        const id = document.getElementById('editingQueryId').value;
        const title = document.getElementById('queryNameInput').value.trim();
        const sql = document.getElementById('modalSqlInput').value.trim();
        if (!title || !sql) { Swal.fire({ icon: 'warning', text: 'Título e SQL obrigatórios' }); return; }
        Swal.fire({ title: 'Salvando...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
        try {
            const res = await fetch('/api/analytics/save-query', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: id || undefined, title, sqlQuery: sql }) });
            const d = await res.json();
            Swal.close();
            if (d.success) { document.getElementById('editingQueryId').value = d.id || id; Swal.fire({ icon: 'success', timer: 1500, showConfirmButton: false }); } else Swal.fire({ icon: 'error', text: d.message });
        } catch (e) { Swal.close(); Swal.fire({ icon: 'error', text: e.message }); }
    }
    function openApplyOptionsModal() {
        const sql = document.getElementById('modalSqlInput').value;
        const title = document.getElementById('queryNameInput').value || 'Consulta';
        if (!sql) return;
        Swal.fire({
            title: 'Usar esta query',
            html: '<p class="mb-3">Conectar dados apenas ou gerar indicadores com IA?</p><div class="flex gap-3"><button id="btnConnect" class="flex-1 p-4 border-2 rounded-xl border-blue-500 bg-blue-50 font-medium">Apenas conectar</button><button id="btnGenerate" class="flex-1 p-4 border-2 rounded-xl border-purple-500 bg-purple-50 font-medium">Gerar com IA</button></div>',
            showCancelButton: true,
            didOpen: () => {
                document.getElementById('btnConnect').onclick = () => { Swal.close(); applyQuery(sql, title, false); };
                document.getElementById('btnGenerate').onclick = () => { Swal.close(); applyQuery(sql, title, true); };
            }
        });
    }
    function applyQuery(sql, title, generate) {
        activeSql = sql;
        activeQueryName = title;
        document.getElementById('queryBadge').classList.remove('hidden');
        document.getElementById('lblQueryName').textContent = title;
        document.getElementById('dashboardTitle').textContent = title;
        var inp = document.getElementById('indicatorNameInput');
        if (inp && !inp.value.trim()) inp.value = title;
        closeQueryManager();
        botReply('Query <b>' + title + '</b> conectada.');
        if (generate) applyAndGenerate(sql, title);
    }
    async function applyAndGenerate(sql, title) {
        activeSql = sql;
        activeQueryName = title;
        document.getElementById('queryBadge').classList.remove('hidden');
        document.getElementById('lblQueryName').textContent = title;
        document.getElementById('dashboardTitle').textContent = title;
        var inp = document.getElementById('indicatorNameInput');
        if (inp && !inp.value.trim()) inp.value = title;
        closeQueryManager();
        botReply('Gerando indicadores...');
        const useJson = document.getElementById('chkJsonMode')?.checked;
        if (!useJson) {
            document.getElementById('loadingOverlay').classList.remove('hidden');
            try {
                const res = await fetch('/api/analytics/preview', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ prompt: 'Gere o dashboard completo com os melhores indicadores.', sqlQuery: sql, model: document.getElementById('api_model_construtor')?.value, contexto: activeQueryName || undefined, autoGenerateOKRs: true })
                });
                const data = await res.json();
                document.getElementById('loadingOverlay').classList.add('hidden');
                if (data.success && data.previewHtml) {
                    currentHtmlCode = data.previewHtml;
                    lastRawData = data.rawResult || lastRawData;
                    renderDashboardHtml(data.previewHtml, data.rawResult);
                    botReply('Dashboard com página HTML completa gerado!');
                } else {
                    botReply('Erro: ' + (data.message || 'Falha'));
                }
            } catch (e) {
                document.getElementById('loadingOverlay').classList.add('hidden');
                botReply('Erro: ' + e.message);
            }
        } else {
            await initSmartDashboard({ prompt: '', sqlQuery: sql, model: document.getElementById('api_model_construtor')?.value, autoGenerateOKRs: true });
        }
    }
    async function openTemplatesModal() {
        document.getElementById('templatesModal').classList.remove('hidden');
        if (document.getElementById('templatesGrid').children.length === 0) {
            try {
                const res = await fetch('/api/analytics/templates');
                const d = await res.json();
                if (d.success && d.templates) {
                    d.templates.forEach(t => {
                        const card = document.createElement('div');
                        card.className = 'p-4 border rounded-xl hover:border-purple-500 cursor-pointer';
                        card.innerHTML = '<h4 class="font-bold text-slate-800 mb-1">' + t.nome + '</h4><p class="text-sm text-slate-600">' + (t.descricao || '') + '</p>';
                        card.onclick = () => selectTemplate(t.id);
                        document.getElementById('templatesGrid').appendChild(card);
                    });
                }
            } catch (e) {}
        }
    }
    function closeTemplatesModal() { document.getElementById('templatesModal').classList.add('hidden'); }
    async function selectTemplate(id) {
        if (!activeSql) { closeTemplatesModal(); botReply('Selecione uma query primeiro.'); return; }
        closeTemplatesModal();
        botReply('Aplicando template...');
        document.getElementById('loadingOverlay').classList.remove('hidden');
        try {
            const res = await fetch('/api/analytics/apply-template', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ templateId: id, sqlQuery: activeSql, model: document.getElementById('api_model_construtor')?.value }) });
            const d = await res.json();
            if (d.success && d.previewHtml) { currentHtmlCode = d.previewHtml; lastRawData = d.rawResult || lastRawData; renderDashboardHtml(d.previewHtml, d.rawResult); botReply('Template aplicado!'); }
            else botReply('Erro: ' + (d.message || ''));
        } catch (e) { botReply('Erro: ' + e.message); }
        finally { document.getElementById('loadingOverlay').classList.add('hidden'); }
    }
    async function saveCurrentPage() {
        if (!activeSql && !lastBiConfig && !currentHtmlCode) {
            Swal.fire({ icon: 'warning', text: 'Gere um dashboard primeiro. Use Queries e Gerar indicadores.' });
            return;
        }
        const pastasList = window.__PASTAS__ || [];
        const pastasOpt = '<option value="">Selecione...</option>' + pastasList.map(p => '<option value="' + p.id + '">' + (p.nome || '') + '</option>').join('');
        const { value } = await Swal.fire({
            title: 'Salvar Dashboard',
            html: '<input id="swal-title" class="swal2-input" placeholder="Nome" value="' + (document.getElementById('indicatorNameInput')?.value || activeQueryName || '').replace(/"/g, '&quot;') + '"><select id="swal-pasta" class="swal2-input">' + pastasOpt + '</select><textarea id="swal-desc" class="swal2-textarea" placeholder="Descrição" rows="2"></textarea>',
            showCancelButton: true,
            preConfirm: () => ({ title: document.getElementById('swal-title').value, pasta_id: document.getElementById('swal-pasta').value, description: document.getElementById('swal-desc').value })
        });
        if (!value || !value.title || !value.pasta_id) return;
        Swal.fire({ title: 'Salvando...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
        try {
            const res = await fetch('/api/analytics/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title: value.title, pasta_id: value.pasta_id, prompt: value.description, sqlQuery: activeSql, htmlTemplate: currentHtmlCode, biConfig: lastBiConfig }) });
            const d = await res.json();
            Swal.close();
            if (d.success) {
                const r = await Swal.fire({ icon: 'success', title: 'Salvo!', showCancelButton: true, confirmButtonText: 'Abrir', cancelButtonText: 'Fechar' });
                if (r.isConfirmed) window.open((d.slug ? '/api/analytics/view/' + encodeURIComponent(d.slug) : '/api/analytics/view/' + d.id), '_blank');
            } else Swal.fire({ icon: 'error', text: d.message });
        } catch (e) { Swal.close(); Swal.fire({ icon: 'error', text: e.message }); }
    }

    document.getElementById('promptInput')?.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } });
    addMessage('Olá! Selecione uma <b>query</b> e envie "Gerar indicadores" ou descreva o que deseja.', 'bot');

    window.openQueryManager = openQueryManager;
    window.closeQueryManager = closeQueryManager;
    window.openTemplatesModal = openTemplatesModal;
    window.closeTemplatesModal = closeTemplatesModal;
    window.saveCurrentPage = saveCurrentPage;
    window.toggleAssistant = toggleAssistant;
    window.toggleEditMode = toggleEditMode;
    window.setViewMode = setViewMode;
    window.showHtmlCode = showHtmlCode;
    window.sendMessage = sendMessage;
    window.resetEditor = resetEditor;
    window.deleteQuery = deleteQuery;
    window.runTestInModal = runTestInModal;
    window.saveQueryToLibrary = saveQueryToLibrary;
    window.openApplyOptionsModal = openApplyOptionsModal;
})();
</script>
