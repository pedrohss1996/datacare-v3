<aside class="w-[480px] bg-white flex flex-col shadow-xl z-20 border-l border-slate-200 shrink-0 h-full transition-all duration-300" id="painel-agenda">
    
    <div class="h-14 bg-slate-800 text-white flex items-center px-4 gap-2 shadow-sm shrink-0 justify-between">
        <div class="flex items-center gap-2">
            <i class="fa-solid fa-hospital-user text-blue-400"></i>
            <h2 class="font-bold text-sm tracking-wide">Integração Agenda</h2>
        </div>
        <button onclick="verificarFluxoAgenda()" class="text-slate-400 hover:text-white transition" title="Recarregar Filtros">
            <i class="fa-solid fa-sync text-xs"></i>
        </button>
    </div>
    
    <div class="p-4 bg-slate-50 border-b border-slate-200 space-y-3 shrink-0 overflow-y-auto custom-scrollbar" style="max-height: 50%;">
        
        <div>
            <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">1. Tipo de Agenda</label>
            <select id="tasy-unidade" class="w-full text-xs border border-slate-300 rounded h-9 px-2 bg-white text-slate-700 focus:ring-1 focus:ring-blue-500 outline-none transition shadow-sm" onchange="verificarFluxoAgenda()">
                <option value="">Carregando...</option>
            </select>
        </div>

        <div id="container-especialidade" class="animate-in fade-in slide-in-from-top-1 duration-300 hidden">
            <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">2. Especialidade</label>
            <select id="tasy-especialidade" class="w-full text-xs border border-slate-300 rounded h-9 px-2 bg-white text-slate-700 focus:ring-1 focus:ring-blue-500 outline-none disabled:bg-slate-100 disabled:text-slate-400 transition shadow-sm" disabled onchange="carregarConvenios()">
                <option value="">Selecione o Tipo...</option>
            </select>
        </div>

        <div id="container-convenio" class="animate-in fade-in slide-in-from-top-2 duration-500 hidden">
            <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">3. Convênio</label>
            <select id="tasy-convenio" class="w-full text-xs border border-slate-300 rounded h-9 px-2 bg-white text-slate-700 focus:ring-1 focus:ring-blue-500 outline-none disabled:bg-slate-100 disabled:text-slate-400 transition shadow-sm" disabled onchange="carregarRecursos()">
                <option value="">Selecione a Especialidade...</option>
            </select>
        </div>

        <div class="animate-in fade-in slide-in-from-top-3 duration-700">
            <label id="label-recurso" class="block text-[10px] font-bold text-slate-500 uppercase mb-1">4. Profissional</label>
            <select id="tasy-recurso" class="w-full text-xs border border-slate-300 rounded h-9 px-2 bg-white text-slate-700 focus:ring-1 focus:ring-blue-500 outline-none disabled:bg-slate-100 disabled:text-slate-400 transition shadow-sm">
                <option value="">Aguardando filtros...</option>
            </select>
        </div>

        <div>
            <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">DATA</label>
            <div class="flex gap-2">
                <input type="date" id="tasy-data" class="flex-1 text-xs border border-slate-300 rounded h-9 px-2 text-slate-700 focus:ring-1 focus:ring-blue-500 outline-none shadow-sm">
                
                <button onclick="verOrientacao()" class="bg-slate-200 hover:bg-slate-300 text-slate-600 w-9 h-9 rounded flex items-center justify-center transition shadow-sm" title="Ver Orientações">
                    <i class="fa-solid fa-info"></i>
                </button>

                <button onclick="buscarAgenda()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 rounded h-9 text-xs font-bold flex items-center gap-2 transition shadow-sm active:scale-95">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
            </div>
        </div>
    </div>

    <div class="bg-slate-100 py-2 px-4 border-b border-slate-200 grid grid-cols-[64px_1fr_64px] text-xs font-bold text-slate-600">
        <div>Hora</div>
        <div>Paciente</div>
        <div class="text-right">Status</div>
    </div>

    <div class="flex-1 overflow-y-auto bg-white relative">
        <div id="lista-agenda" class="divide-y divide-slate-100">
            <div class="flex flex-col items-center justify-center h-48 text-slate-400 opacity-70">
                <i class="fa-regular fa-calendar text-3xl mb-2"></i>
                <span class="text-xs font-medium">Selecione os filtros acima</span>
            </div>
        </div>
    </div>
    
    <div class="bg-slate-50 py-1.5 px-4 border-t border-slate-200 text-center">
        <p class="text-[9px] text-slate-400"><i class="fa-solid fa-mouse-pointer mr-1"></i> Clique direito p/ ações</p>
    </div>
</aside>

<div id="context-menu" class="fixed hidden bg-white border border-slate-200 shadow-xl rounded-lg w-56 py-2 z-50 text-sm flex flex-col animate-in fade-in zoom-in duration-100">
    
    <button onclick="acaoAgenda('agendar')" class="text-left px-4 py-2 hover:bg-slate-50 text-slate-700 flex items-center gap-3 transition">
        <div class="w-5 text-center"><i class="fa-regular fa-calendar-plus text-blue-600"></i></div> 
        <span>Agendar</span>
    </button>

    <button onclick="acaoAgenda('encaixe')" class="text-left px-4 py-2 hover:bg-slate-50 text-slate-700 flex items-center gap-3 transition">
        <div class="w-5 text-center"><i class="fa-solid fa-user-plus text-purple-600"></i></div> 
        <span>Gerar Encaixe</span>
    </button>

    <div class="border-t border-slate-100 my-1"></div>

    <button onclick="acaoAgenda('confirmar')" class="text-left px-4 py-2 hover:bg-slate-50 text-slate-700 flex items-center gap-3 transition">
        <div class="w-5 text-center"><i class="fa-solid fa-check-double text-green-600"></i></div> 
        <span>Confirmar</span>
    </button>

    <button onclick="acaoAgenda('transferir')" class="text-left px-4 py-2 hover:bg-slate-50 text-slate-700 flex items-center gap-3 transition">
        <div class="w-5 text-center"><i class="fa-solid fa-arrow-right-arrow-left text-orange-500"></i></div> 
        <span>Transferir</span>
    </button>

    <div class="border-t border-slate-100 my-1"></div>

    <button onclick="acaoAgenda('bloquear')" class="text-left px-4 py-2 hover:bg-slate-50 text-slate-700 flex items-center gap-3 transition">
        <div class="w-5 text-center"><i class="fa-solid fa-ban text-red-500"></i></div> 
        <span>Bloquear</span>
    </button>

    <button onclick="acaoAgenda('cancelar')" class="text-left px-4 py-2 hover:bg-red-50 text-red-600 flex items-center gap-3 transition">
        <div class="w-5 text-center"><i class="fa-regular fa-calendar-xmark"></i></div> 
        <span>Cancelar</span>
    </button>

</div>

<div id="modal-agendamento" class="fixed inset-0 bg-black/50 hidden z-50 flex items-center justify-center backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-3xl overflow-hidden animate-in zoom-in-95 duration-200 flex flex-col max-h-[90vh]">
        
        <div class="bg-blue-600 px-6 py-3 flex justify-between items-center shrink-0">
            <h3 class="text-white font-bold text-lg"><i class="fa-solid fa-calendar-days mr-2"></i>Agendamento de Paciente</h3>
            <button onclick="fecharModalAgendamento()" class="text-white/80 hover:text-white transition"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>

        <div class="p-6 overflow-y-auto custom-scrollbar">
            <input type="hidden" id="agenda-id-hidden">
            <input type="hidden" id="agenda-tipo-hidden">
            <input type="hidden" id="paciente-id-selecionado">
            
            <div class="bg-slate-50 p-4 rounded-lg border border-slate-200 mb-6">
                <label class="block text-xs font-bold text-slate-600 mb-1">Localizar Paciente (Nome, CPF ou Prontuário)</label>
                <div class="flex gap-2 mb-3">
                    <input type="text" id="input-busca-paciente" onkeyup="buscarPacientes(this.value)" 
                           class="flex-1 border border-slate-300 rounded px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none" 
                           placeholder="Digite para buscar...">
                    <button onclick="buscarPacientes(document.getElementById('input-busca-paciente').value)" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded font-bold text-sm transition shadow-sm">
                        Filtrar
                    </button>
                </div>

                <div class="border border-slate-200 rounded bg-white overflow-hidden relative min-h-[100px]">
                    <div class="grid grid-cols-12 gap-2 bg-slate-100 px-4 py-2 border-b border-slate-200 text-xs font-bold text-slate-600">
                        <div class="col-span-6">Nome</div>
                        <div class="col-span-3">CPF</div>
                        <div class="col-span-3">Dt. Nasc</div>
                    </div>
                    
                    <div id="lista-resultados-paciente" class="max-h-32 overflow-y-auto">
                        <div class="p-8 text-center text-xs text-slate-400">
                            Nenhum paciente encontrado.
                        </div>
                    </div>
                    
                    </div>

                <div class="flex justify-end mt-3">
                    <button onclick="abrirModalCadastro()" class="bg-green-600 hover:bg-green-700 text-white px-4 py-1.5 rounded font-bold text-xs flex items-center gap-2 shadow-sm transition">
                        <i class="fa-solid fa-plus"></i> Novo Cadastro Completo
                    </button>
                </div>
            </div>

            <h4 class="text-blue-600 font-bold text-sm uppercase mb-3 border-b border-blue-100 pb-1">Dados do Agendamento</h4>
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4 mb-4">
                <div class="col-span-3">
                    <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Data</label>
                    <input type="date" id="ag-data" class="w-full bg-slate-100 border border-slate-300 text-slate-500 rounded px-3 py-1.5 text-sm cursor-not-allowed" readonly>
                </div>
                <div class="col-span-2">
                    <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Hora</label>
                    <input type="time" id="ag-hora" class="w-full bg-slate-100 border border-slate-300 text-slate-500 rounded px-3 py-1.5 text-sm font-bold cursor-not-allowed" readonly>
                </div>
                <div class="col-span-7">
                    <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Paciente Selecionado</label>
                    <input type="text" id="ag-paciente-display" class="w-full bg-blue-50 border border-blue-200 text-blue-800 font-bold rounded px-3 py-1.5 text-sm cursor-not-allowed" placeholder="Selecione na busca acima..." readonly>
                </div>

                <div class="col-span-4">
                    <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Convênio</label>
                    <select id="select-convenio-agenda" class="w-full border border-slate-300 rounded px-3 py-1.5 text-sm focus:border-blue-500 outline-none bg-white">
                        <option value="">Selecione...</option>
                        </select>
                </div>
                <div class="col-span-4">
                    <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Plano / Categoria</label>
                    <select id="select-plano-agenda" class="w-full border border-slate-300 rounded px-3 py-1.5 text-sm focus:border-blue-500 outline-none bg-white">
                        <option value="">Básico (Padrão)</option>
                        <option value="">Executivo</option>
                        </select>
                </div>
                <div class="col-span-4">
                    <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Tipo</label>
                    <select id="select-tipo-agenda" class="w-full border border-slate-300 rounded px-3 py-1.5 text-sm focus:border-blue-500 outline-none bg-white">
                        <option value="1">Consulta</option>
                        <option value="2">Exame / Procedimento</option>
                    </select>
                </div>

                <div class="col-span-12">
                    <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Observações / Queixa Principal</label>
                    <textarea id="txt-obs-agenda" rows="3" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:border-blue-500 outline-none resize-none"></textarea>
                </div>
            </div>
        </div>

        <div class="bg-slate-50 px-6 py-4 flex justify-end gap-3 border-t border-slate-200 shrink-0">
            <button onclick="fecharModalAgendamento()" class="px-5 py-2 bg-white border border-slate-300 text-slate-600 font-bold hover:bg-slate-50 rounded shadow-sm transition">Cancelar</button>
            <button onclick="confirmarAgendamento()" class="px-6 py-2 bg-blue-700 hover:bg-blue-800 text-white font-bold rounded shadow-sm transition flex items-center gap-2">
                Confirmar Agendamento
            </button>
        </div>
    </div>
</div>

<div id="modal-cadastro-paciente" class="fixed inset-0 bg-black/50 hidden z-[60] flex items-center justify-center backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-4xl h-[90vh] flex flex-col animate-in zoom-in-95 duration-200">
        <div class="bg-slate-800 px-6 py-4 flex justify-between items-center shrink-0">
            <h3 class="text-white font-bold text-lg"><i class="fa-solid fa-user-plus mr-2"></i>Ficha Cadastral do Paciente</h3>
            <button onclick="fecharModalCadastro()" class="text-white/70 hover:text-white"><i class="fa-solid fa-xmark"></i></button>
        </div>

        <div class="flex-1 overflow-y-auto p-6 bg-slate-50">
            <form id="form-cadastro-paciente" class="space-y-6">
                <input type="hidden" name="cd_pessoa_fisica" id="cad-id">

                <div class="bg-white p-4 rounded-lg shadow-sm border border-slate-200">
                    <h4 class="text-blue-600 font-bold text-sm border-b pb-2 mb-4">1. IDENTIFICAÇÃO PESSOAL</h4>
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                        <div class="col-span-2">
                            <label class="lbl-form">Nome Completo *</label>
                            <input type="text" name="nome" id="cad-nome" class="input-form" required>
                        </div>
                        <div class="col-span-2">
                            <label class="lbl-form">Nome Social</label>
                            <input type="text" name="nome_social" id="cad-nome-social" class="input-form">
                        </div>
                        <div>
                            <label class="lbl-form">CPF *</label>
                            <input type="text" name="cpf" id="cad-cpf" class="input-form" placeholder="000.000.000-00">
                        </div>
                        <div>
                            <label class="lbl-form">Data Nascimento</label>
                            <input type="date" name="nascimento" id="cad-nasc" class="input-form">
                        </div>
                        <div>
                            <label class="lbl-form">Sexo</label>
                            <select name="sexo" id="cad-sexo" class="input-form">
                                <option value="M">Masculino</option>
                                <option value="F">Feminino</option>
                            </select>
                        </div>
                        <div>
                            <label class="lbl-form">Altura (cm)</label>
                            <input type="number" name="altura" id="cad-altura" class="input-form">
                        </div>
                        <div>
                            <label class="lbl-form">Peso (kg)</label>
                            <input type="number" name="peso" id="cad-peso" class="input-form">
                        </div>
                    </div>
                </div>

                <div class="bg-white p-4 rounded-lg shadow-sm border border-slate-200">
                    <h4 class="text-blue-600 font-bold text-sm border-b pb-2 mb-4">2. CONTATO</h4>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label class="lbl-form">Celular / WhatsApp *</label>
                            <input type="text" name="telefone" id="cad-tel" class="input-form" placeholder="(00) 00000-0000">
                        </div>
                        <div class="col-span-2">
                            <label class="lbl-form">E-mail</label>
                            <input type="email" name="email" id="cad-email" class="input-form">
                        </div>
                    </div>
                </div>

                <div class="bg-white p-4 rounded-lg shadow-sm border border-slate-200">
                    <h4 class="text-blue-600 font-bold text-sm border-b pb-2 mb-4">3. ENDEREÇO</h4>
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                        <div>
                            <label class="lbl-form">CEP</label>
                            <input type="text" name="cep" id="cad-cep" class="input-form" onblur="buscarCep(this.value)">
                        </div>
                        <div class="col-span-2">
                            <label class="lbl-form">Logradouro</label>
                            <input type="text" name="endereco" id="cad-logradouro" class="input-form">
                        </div>
                        <div>
                            <label class="lbl-form">Número</label>
                            <input type="text" name="numero" id="cad-numero" class="input-form">
                        </div>
                        <div>
                            <label class="lbl-form">Bairro</label>
                            <input type="text" name="bairro" id="cad-bairro" class="input-form">
                        </div>
                        <div>
                            <label class="lbl-form">Cidade</label>
                            <input type="text" name="cidade" id="cad-cidade" class="input-form">
                        </div>
                        <div>
                            <label class="lbl-form">UF</label>
                            <input type="text" name="uf" id="cad-uf" class="input-form">
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <div class="bg-white px-6 py-4 flex justify-end gap-3 border-t border-slate-200 shrink-0">
            <button onclick="fecharModalCadastro()" class="btn-secondary">Cancelar</button>
            <button onclick="salvarCadastroPaciente()" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded-lg font-bold shadow-sm transition">
                <i class="fa-solid fa-save mr-2"></i>Salvar Ficha & Selecionar
            </button>
        </div>
    </div>
</div>

<style>
    .lbl-form { @apply block text-[10px] font-bold text-slate-500 uppercase mb-1; }
    .input-form { @apply w-full border border-slate-300 rounded px-3 py-1.5 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition; }
    .btn-secondary { @apply px-4 py-2 text-slate-500 font-bold hover:bg-slate-100 rounded-lg transition; }
</style>

<div id="modal-orientacao" class="fixed inset-0 bg-black/60 z-[90] hidden flex items-center justify-center backdrop-blur-sm">
    <div class="bg-white rounded-lg shadow-2xl w-[600px] max-h-[80vh] flex flex-col overflow-hidden animate-in fade-in zoom-in duration-200 border border-slate-200">
        
        <div class="bg-blue-600 text-white px-5 py-4 flex justify-between items-center shrink-0">
            <h3 class="font-bold text-sm uppercase flex items-center gap-2 tracking-wide">
                <i class="fa-solid fa-circle-info"></i> Orientação da Agenda
            </h3>
            <button onclick="fecharModalOrientacao()" class="text-white/70 hover:text-white transition p-1 hover:bg-white/10 rounded">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>
        
        <div class="p-6 overflow-y-auto custom-scrollbar flex-1 bg-white">
            <div id="conteudo-orientacao" class="text-sm text-slate-700 space-y-3 leading-relaxed">
                <div class="flex flex-col items-center justify-center py-10 text-slate-300">
                    <i class="fa-solid fa-spinner fa-spin text-2xl mb-2"></i>
                    <span>Carregando...</span>
                </div>
            </div>
        </div>

        <div class="bg-slate-50 px-4 py-3 border-t border-slate-200 text-right flex justify-between items-center">
            <span class="text-[10px] text-slate-400 italic">Dados extraídos do Tasy</span>
            <button onclick="fecharModalOrientacao()" class="px-4 py-2 bg-slate-200 hover:bg-slate-300 text-slate-700 text-xs font-bold rounded transition">
                Fechar
            </button>
        </div>
    </div>
</div>