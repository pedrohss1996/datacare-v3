<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<div id="chat-empty" class="absolute inset-0 flex flex-col items-center justify-center bg-slate-100 z-10 transition-opacity">
    <div class="w-24 h-24 bg-slate-200 rounded-full flex items-center justify-center text-slate-400 mb-4 animate-pulse">
        <i class="fa-brands fa-whatsapp text-4xl"></i>
    </div>
    <h3 class="text-slate-600 font-bold text-lg">DataCare Chat</h3>
    <p class="text-slate-400 text-sm">Selecione um atendimento para começar.</p>
</div>

<header id="chat-header" class="h-14 bg-white border-b flex items-center px-4 justify-between hidden shrink-0 shadow-sm z-20">

    

    <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-slate-200 flex items-center justify-center text-slate-500 font-bold text-sm" id="chat-avatar">?</div>
        
        <div>
            <div class="flex items-center gap-2">
                <h3 class="font-bold text-slate-800 text-sm leading-tight" id="chat-nome">
                    Nome do Contato
                </h3>

                <button id="chat-id-display" 
                        onclick="copiarTicketId()" 
                        title="Clique para copiar o ID"
                        class="bg-slate-100 hover:bg-slate-200 text-slate-500 text-[10px] px-1.5 py-0.5 rounded border border-slate-200 font-mono font-medium transition cursor-pointer flex items-center gap-1">
                    <i class="fa-solid fa-hashtag text-[8px]"></i>
                    <span id="ticket-id-val">...</span>
                </button>
            </div>
            
            <p class="text-[10px] text-slate-500 leading-tight">Online - Whatsapp</p>
        </div>
    </div>



    <div class="flex gap-2">
        <button onclick="abrirModalTransferencia()" class="bg-amber-50 text-amber-600 hover:bg-amber-600 hover:text-white border border-amber-200 px-3 py-1 rounded text-xs font-bold transition flex items-center gap-2">
            <i class="fa-solid fa-arrow-right-arrow-left"></i> Transferir
        </button>

        <button onclick="finalizarAtendimento()" class="bg-red-50 text-red-600 hover:bg-red-600 hover:text-white border border-red-200 px-3 py-1 rounded text-xs font-bold transition flex items-center gap-2">
            <i class="fa-solid fa-check"></i> Finalizar
        </button>
    </div>
</header>

<div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-2 hidden custom-scrollbar bg-[#efeae2] bg-opacity-50">
    </div>

<footer id="chat-input" class="p-3 bg-white border-t hidden shrink-0 z-20">
    <div class="flex gap-2 items-center">
        <button class="p-2 text-slate-400 hover:text-slate-600 transition"><i class="fa-solid fa-paperclip"></i></button>
        <input type="text" id="input-msg" class="flex-1 border border-slate-200 rounded-full px-4 py-2 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm bg-slate-50" placeholder="Digite sua mensagem..." onkeypress="handleEnter(event)">
        <button onclick="enviarMensagem()" class="p-2 bg-blue-600 text-white rounded-full w-10 h-10 hover:bg-blue-700 flex items-center justify-center shadow-sm transition hover:scale-105 active:scale-95 transform">
            <i class="fa-solid fa-paper-plane text-lg"></i>
        </button>
    </div>
</footer>

<div id="modal-transferencia" class="fixed inset-0 bg-slate-900/60 z-[60] hidden flex items-center justify-center backdrop-blur-sm transition-opacity duration-300">
    
    <div class="bg-white rounded-xl shadow-2xl w-[500px] overflow-hidden transform transition-all scale-100 animate-in fade-in zoom-in duration-200 ring-1 ring-slate-900/5">
        
        <div class="bg-gradient-to-r from-slate-800 to-slate-900 text-white px-6 py-4 flex justify-between items-center border-b border-slate-700">
            <div>
                <h3 class="font-bold text-base tracking-wide flex items-center gap-2">
                    <i class="fa-solid fa-arrow-right-arrow-left text-amber-400"></i> 
                    Transferir / Transbordo
                </h3>
                <p class="text-[10px] text-slate-400 mt-0.5 font-light">Encaminhar atendimento para continuidade</p>
            </div>
            <button onclick="fecharModalTransferencia()" class="text-slate-400 hover:text-white hover:bg-white/10 rounded-full w-8 h-8 flex items-center justify-center transition">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>

        <div class="p-6 space-y-5 bg-white">
            
            <div class="bg-amber-50 border border-amber-100 rounded-lg p-3 flex gap-3 items-start">
                <i class="fa-solid fa-circle-exclamation text-amber-500 mt-0.5 text-sm"></i>
                <p class="text-xs text-amber-700 leading-relaxed">
                    <strong>Atenção:</strong> Certifique-se de que as validações da agenda foram salvas no Tasy antes de transferir o paciente.
                </p>
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-2">
                    Destino (Atendente/Fila)
                </label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fa-solid fa-user-clock text-slate-400 group-focus-within:text-blue-600 transition-colors"></i>
                    </div>
                    <select id="transfer-atendente-id" class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-300 rounded-lg bg-slate-50 text-slate-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:bg-white outline-none appearance-none transition-all shadow-sm">
                        <option value="" disabled selected>Carregando lista de atendentes...</option>
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-slate-500">
                        <i class="fa-solid fa-chevron-down text-xs"></i>
                    </div>
                </div>
            </div>

            <div>
                <div class="flex justify-between items-end mb-2">
                    <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider">
                        Anotações
                    </label>
                </div>
                <div class="relative">
                    <textarea 
                        id="transfer-obs" 
                        rows="4" 
                        class="w-full p-3 text-sm border border-slate-300 rounded-lg bg-slate-50 text-slate-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:bg-white outline-none resize-none transition-all shadow-inner placeholder:text-slate-400" 
                        placeholder="Preencha com alguma informacão relevante para o colega que receberá o atendimento..."
                    ></textarea>
                    <div class="absolute bottom-2 right-2 text-slate-300 text-xs">
                        <i class="fa-solid fa-clipboard-check"></i>
                    </div>
                </div>
                <p class="text-[10px] text-slate-400 mt-1.5 ml-1">
                    * Informe o status da validação do agendamento.
                </p>
            </div>
        </div>

        <div class="bg-slate-50 px-6 py-4 flex justify-between items-center border-t border-slate-200">
            <button onclick="fecharModalTransferencia()" class="text-slate-500 hover:text-slate-700 text-xs font-bold px-4 py-2 rounded hover:bg-slate-200 transition">
                Cancelar
            </button>
            <button onclick="confirmarTransferencia()" id="btn-transfer-confirm" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold px-6 py-2.5 rounded-lg shadow-md hover:shadow-lg transform active:scale-95 transition-all flex items-center gap-2">
                <span>Confirmar Transferência</span>
                <i class="fa-solid fa-share text-[10px]"></i>
            </button>
        </div>
    </div>
</div>

<script>
    // --- LÓGICA DO MODAL DE TRANSFERÊNCIA (Versão Mockada) ---

    async function abrirModalTransferencia() {
        if (!activeTicketId) return;

        const modal = document.getElementById('modal-transferencia');
        const select = document.getElementById('transfer-atendente-id');
        
        // 1. Abre o modal
        modal.classList.remove('hidden');
        select.innerHTML = '<option value="" disabled selected>Carregando atendentes...</option>';
        select.disabled = true;

        try {
            // ============================================================
            // TODO: Descomentar quando a rota '/api/usuarios/atendentes' existir
            // const res = await fetch('/api/usuarios/atendentes'); 
            // const atendentes = await res.json();
            // ============================================================

            // SIMULAÇÃO DE DADOS (MOCK)
            // Simula um delay de rede de 300ms para parecer real
            await new Promise(resolve => setTimeout(resolve, 300));
            
            const atendentes = [
                { id: 101, nome: 'Veronica', online: true },
                { id: 102, nome: 'Marlon', online: true },
                { id: 103, nome: 'Pedro', online: false },
                { id: 104, nome: 'Clayton', online: true },
            ];

            // 3. Popula o Select
            select.innerHTML = '<option value="" disabled selected>Selecione um colega...</option>';
            
            atendentes.forEach(user => {
                const statusIcon = user.online ? '🟢' : '⚪';
                // Cria o option
                select.innerHTML += `<option value="${user.id}">${statusIcon} ${user.nome}</option>`;
            });

        } catch (e) {
            console.error(e);
            select.innerHTML = '<option value="" disabled selected>Erro ao carregar lista</option>';
        } finally {
            select.disabled = false;
        }
    }

    function fecharModalTransferencia() {
        document.getElementById('modal-transferencia').classList.add('hidden');
        document.getElementById('transfer-obs').value = ''; 
    }

    async function confirmarTransferencia() {
        const novoAtendenteId = document.getElementById('transfer-atendente-id').value;
        const motivo = document.getElementById('transfer-obs').value;
        const btn = document.getElementById('btn-transfer-confirm');

        if (!novoAtendenteId) {
            alert('Por favor, selecione um atendente da lista.');
            return;
        }

        // Estado de Loading
        const textoOriginal = btn.innerHTML;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Transferindo...';
        btn.disabled = true;

        try {
            // Aqui mantive a chamada para a rota de transferir, 
            // mas se essa rota TAMBÉM não existir, vai cair no catch/alert.
            const res = await fetch('/api/chat/transferir', {
                method: 'POST', 
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ 
                    ticketId: activeTicketId, 
                    novoAtendenteId: novoAtendenteId, 
                    motivo: motivo 
                })
            });
            
            const data = await res.json();

            if (data.success) {
                sucessoTransferencia();
            } else {
                alert('Erro: ' + (data.error || 'Falha ao transferir'));
            }

        } catch (e) {
            console.error(e);
            // COMO AINDA NÃO TEM BACKEND, VAMOS SIMULAR O SUCESSO AQUI PARA VOCÊ VER A UI:
            // Remova este bloco "sucessoTransferencia()" quando o backend estiver pronto
            console.warn("Backend falhou ou não existe, simulando sucesso visual...");
            sucessoTransferencia(); 
        } finally {
            btn.innerHTML = textoOriginal;
            btn.disabled = false;
        }
    }

    // Função auxiliar para limpar a tela após sucesso (DRY)
    function sucessoTransferencia() {
        fecharModalTransferencia();
                
        // Esconde chat ativo
        document.getElementById('chat-empty').classList.remove('hidden');
        document.getElementById('chat-header').classList.add('hidden');
        document.getElementById('chat-messages').classList.add('hidden');
        document.getElementById('chat-input').classList.add('hidden');
        
        // Remove card da lista lateral
        const card = document.querySelector(`.ticket-card[data-id="${activeTicketId}"]`);
        if(card) {
            card.style.transition = 'opacity 0.3s';
            card.style.opacity = '0';
            setTimeout(() => card.remove(), 300);
        }
        
        activeTicketId = null;

        if(typeof Swal !== 'undefined') {
            Swal.fire({
                title: 'Transferência Realizada',
                text: 'O atendimento foi movido para o colega selecionado.',
                icon: 'success',
                timer: 2000,
                showConfirmButton: false
            });
        } else {
            alert('Transferência realizada com sucesso!');
        }
    }
</script>