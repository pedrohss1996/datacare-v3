<div id="chat-empty" class="absolute inset-0 flex flex-col items-center justify-center bg-slate-100 z-10">
    <div class="w-24 h-24 bg-slate-200 rounded-full flex items-center justify-center text-slate-400 mb-4">
        <i class="fa-brands fa-whatsapp text-4xl"></i>
    </div>
    <h3 class="text-slate-600 font-bold">DataCare Chat</h3>
    <p class="text-slate-400 text-sm">Selecione um atendimento para começar.</p>
</div>

<header id="chat-header" class="h-14 bg-white border-b flex items-center px-4 justify-between hidden shrink-0">
    <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-slate-200 flex items-center justify-center text-slate-500 font-bold text-sm" id="chat-avatar">?</div>
        <div>
            <h3 class="font-bold text-slate-800 text-sm leading-tight" id="chat-nome">Nome do Contato</h3>
            <p class="text-[10px] text-slate-500 leading-tight">Online - Whatsapp</p>
        </div>
    </div>
    <div class="flex gap-2">
        <button onclick="finalizarAtendimento()" class="bg-red-50 text-red-600 hover:bg-red-600 hover:text-white border border-red-200 px-3 py-1 rounded text-xs font-bold transition flex items-center gap-2">
            <i class="fa-solid fa-check"></i> Finalizar
        </button>
    </div>
</header>

<div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-2 hidden custom-scrollbar bg-[url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png')] bg-repeat">
    </div>

<footer id="chat-input" class="p-3 bg-white border-t hidden shrink-0">
    <div class="flex gap-2 items-center">
        <button class="p-2 text-slate-400 hover:text-slate-600"><i class="fa-solid fa-paperclip"></i></button>
        <input type="text" id="input-msg" class="flex-1 border border-slate-200 rounded-full px-4 py-2 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm bg-slate-50" placeholder="Digite sua mensagem (Enter para enviar)..." onkeypress="handleEnter(event)">
        <button onclick="enviarMensagem()" class="p-2 bg-blue-600 text-white rounded-full w-10 h-10 hover:bg-blue-700 flex items-center justify-center shadow-sm transition">
            <i class="fa-solid fa-paper-plane text-xs"></i>
        </button>
    </div>
</footer>