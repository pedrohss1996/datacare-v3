<script src="/socket.io/socket.io.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    window.DATA_CARE = {
        userId: "<%= user ? user.id : '' %>",
        userName: "<%= user ? user.nome : 'Virtual' %>"
    };
</script>

<div class="flex h-[calc(100vh-64px)] bg-slate-100 overflow-hidden font-sans">
    
    <aside class="w-[320px] bg-white border-r border-slate-200 flex flex-col z-10 shrink-0">
        <%- include('./partials/lista-chats') %> 
    </aside>

    <main class="flex-1 flex flex-col bg-[#efeae2] relative min-w-[400px] border-r border-slate-300 shadow-inner">
        <%- include('./partials/area-chat') %> 
    </main>

    <%- include('./partials/agenda-sidebar') %>

</div>

<div id="modal-ativo" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center backdrop-blur-sm">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-md mx-4 overflow-hidden animate-in fade-in zoom-in duration-200">
        <div class="bg-slate-50 px-6 py-4 border-b flex justify-between items-center">
            <h3 class="font-bold text-lg text-slate-800">Iniciar Novo Atendimento</h3>
            <button onclick="fecharModalAtivo()" class="text-slate-400 hover:text-red-500 transition">
                <i class="fa-solid fa-times text-xl"></i>
            </button>
        </div>
        <div class="p-6 space-y-4">
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">WhatsApp do Paciente</label>
                <input type="text" id="ativo-telefone" placeholder="Ex: 62999998888 (Apenas números)" class="w-full border border-slate-300 rounded p-2 focus:ring-2 focus:ring-blue-500 outline-none">
                <p class="text-[10px] text-slate-400 mt-1">Digite com DDD. Ex: 629...</p>
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Nome do Paciente</label>
                <input type="text" id="ativo-nome" placeholder="Nome Completo" class="w-full border border-slate-300 rounded p-2 focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Mensagem Inicial</label>
                <textarea id="ativo-msg" rows="3" placeholder="Olá, gostaria de confirmar..." class="w-full border border-slate-300 rounded p-2 focus:ring-2 focus:ring-blue-500 outline-none"></textarea>
            </div>
        </div>
        <div class="bg-slate-50 px-6 py-4 border-t flex justify-end gap-2">
            <button onclick="fecharModalAtivo()" class="px-4 py-2 text-sm text-slate-600 hover:bg-slate-200 rounded transition">Cancelar</button>
            <button onclick="confirmarContatoAtivo()" id="btn-enviar-ativo" class="px-4 py-2 text-sm bg-green-600 hover:bg-green-700 text-white rounded font-bold transition flex items-center gap-2">
                <i class="fa-regular fa-paper-plane"></i> Enviar
            </button>
        </div>
    </div>
</div>

<script src="/js/chat-app.js"></script>