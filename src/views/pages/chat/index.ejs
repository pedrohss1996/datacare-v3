<script src="/socket.io/socket.io.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="flex h-[calc(100vh-64px)] bg-slate-100 overflow-hidden font-sans">
    
    <aside class="w-[320px] bg-white border-r border-slate-200 flex flex-col z-10 shrink-0">
        <%- include('./partials/lista-chats') %> 
    </aside>

    <main class="flex-1 flex flex-col bg-[#efeae2] relative min-w-[400px] border-r border-slate-300">
        <%- include('./partials/area-chat') %> 
    </main>

    <aside class="w-[480px] bg-white flex flex-col shadow-xl z-20 border-l border-slate-200">
        
        <div class="h-14 bg-slate-800 text-white flex items-center px-4 gap-2 shadow-sm shrink-0">
            <i class="fa-solid fa-hospital-user"></i>
            <h2 class="font-bold text-sm tracking-wide">Integração Agenda</h2>
        </div>
        

        <div class="p-4 bg-slate-50 border-b border-slate-200 space-y-3 shrink-0">
            
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">1. Tipo de Agenda</label>
                <select id="tasy-unidade" class="w-full text-xs border border-slate-300 rounded h-9 px-2 bg-white text-slate-700 focus:ring-1 focus:ring-blue-500 outline-none transition" onchange="verificarFluxoAgenda()">
                    <option value="">Carregando...</option>
                </select>
            </div>

            <div id="container-especialidade" class="animate-in fade-in slide-in-from-top-1 duration-300">
                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">2. Especialidade</label>
                <select id="tasy-especialidade" class="w-full text-xs border border-slate-300 rounded h-9 px-2 bg-white text-slate-700 focus:ring-1 focus:ring-blue-500 outline-none disabled:bg-slate-100 disabled:text-slate-400 transition" disabled onchange="carregarConvenios()">
                    <option value="">Selecione o Tipo...</option>
                </select>
            </div>

            <div id="container-convenio" class="animate-in fade-in slide-in-from-top-2 duration-500">
                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">3. Convênio</label>
                <select id="tasy-convenio" class="w-full text-xs border border-slate-300 rounded h-9 px-2 bg-white text-slate-700 focus:ring-1 focus:ring-blue-500 outline-none disabled:bg-slate-100 disabled:text-slate-400 transition" disabled onchange="carregarRecursos()">
                    <option value="">Selecione a Especialidade...</option>
                </select>
            </div>

            <div class="animate-in fade-in slide-in-from-top-3 duration-700">
                <label id="label-recurso" class="block text-[10px] font-bold text-slate-500 uppercase mb-1">4. Profissional</label>
                <select id="tasy-recurso" class="w-full text-xs border border-slate-300 rounded h-9 px-2 bg-white text-slate-700 focus:ring-1 focus:ring-blue-500 outline-none disabled:bg-slate-100 disabled:text-slate-400 transition">
                    <option value="">Aguardando filtros...</option>
                </select>
            </div>

            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">DATA</label>
                <div class="flex gap-2">
                    <input type="date" id="tasy-data" class="flex-1 text-xs border border-slate-300 rounded h-9 px-2 text-slate-700 focus:ring-1 focus:ring-blue-500 outline-none shadow-sm">
                    <button onclick="buscarAgenda()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 rounded h-9 text-xs font-bold flex items-center gap-2 transition shadow-sm active:scale-95">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </div>
            </div>
        </div>



        <div class="bg-slate-100 py-1 px-4 border-b border-slate-200 text-center">
            <p class="text-[10px] text-slate-500"><i class="fa-solid fa-mouse-pointer mr-1"></i> Botão direito p/ ações</p>
        </div>

        <div class="flex-1 overflow-y-auto bg-white relative">
            <div class="sticky top-0 bg-slate-100 border-b border-slate-200 flex px-4 py-2 text-xs font-bold text-slate-600 z-10">
                <div class="w-16">Hora</div>
                <div class="flex-1">Paciente</div>
                <div class="w-16">Status</div>
            </div>
            <div id="lista-agenda" class="divide-y divide-slate-100">
                <div class="flex flex-col items-center justify-center h-40 text-slate-400">
                    <i class="fa-regular fa-calendar text-2xl mb-2"></i>
                    <span class="text-xs">Selecione os filtros</span>
                </div>
            </div>
        </div>
    </aside>

    <div id="context-menu" class="fixed hidden bg-white border border-slate-200 shadow-xl rounded-lg w-56 py-2 z-50 text-sm flex flex-col">
        
        <button onclick="acaoAgenda('agendar')" class="text-left px-4 py-2 hover:bg-slate-50 text-slate-700 flex items-center gap-3 transition">
            <div class="w-5 text-center"><i class="fa-regular fa-calendar-plus text-blue-600"></i></div>
            <span>Agendar</span>
        </button>

        <button onclick="acaoAgenda('confirmar')" class="text-left px-4 py-2 hover:bg-slate-50 text-slate-700 flex items-center gap-3 transition">
            <div class="w-5 text-center"><i class="fa-solid fa-check-double text-green-600"></i></div>
            <span>Confirmar</span>
        </button>

        <button onclick="acaoAgenda('transferir')" class="text-left px-4 py-2 hover:bg-slate-50 text-slate-700 flex items-center gap-3 transition">
            <div class="w-5 text-center"><i class="fa-solid fa-arrow-right-arrow-left text-orange-500"></i></div>
            <span>Transferir</span>
        </button>

        <div class="border-t border-slate-100 my-1"></div>

        <button onclick="acaoAgenda('bloquear')" class="text-left px-4 py-2 hover:bg-slate-50 text-slate-700 flex items-center gap-3 transition">
            <div class="w-5 text-center"><i class="fa-solid fa-ban text-red-500"></i></div>
            <span>Bloquear</span>
        </button>

        <button onclick="acaoAgenda('cancelar')" class="text-left px-4 py-2 hover:bg-red-50 text-red-600 flex items-center gap-3 transition">
            <div class="w-5 text-center"><i class="fa-regular fa-calendar-xmark"></i></div>
            <span>Cancelar</span>
        </button>
    </div>

    <div id="modal-agendamento" class="fixed inset-0 bg-black/50 z-[60] hidden flex items-center justify-center backdrop-blur-sm">
        <div class="bg-white rounded-lg shadow-2xl w-[400px] overflow-hidden transform transition-all scale-100">
            <div class="bg-slate-800 text-white px-4 py-3 flex justify-between items-center">
                <h3 class="font-bold text-sm"><i class="fa-regular fa-calendar-check mr-2"></i> Confirmar Agendamento</h3>
                <button onclick="fecharModal()" class="text-slate-400 hover:text-white"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="p-6 space-y-4">
                <input type="hidden" id="modal-agenda-id">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Paciente</label>
                    <input type="text" id="modal-paciente-nome" class="w-full border border-slate-300 rounded px-3 py-2 text-sm bg-slate-50 font-bold text-slate-700 focus:ring-2 focus:ring-blue-500 outline-none" placeholder="Digite o nome do paciente...">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Observação / Convênio</label>
                    <textarea id="modal-obs" rows="3" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none" placeholder="Ex: Particular, Unimed..."></textarea>
                </div>
            </div>
            <div class="bg-slate-50 px-6 py-3 flex justify-end gap-2 border-t border-slate-200">
                <button onclick="fecharModal()" class="px-4 py-2 text-xs font-bold text-slate-600 hover:bg-slate-200 rounded">Cancelar</button>
                <button onclick="confirmarAgendamento()" id="btn-confirmar" class="px-4 py-2 text-xs font-bold text-white bg-green-600 hover:bg-green-700 rounded shadow-sm flex items-center gap-2">
                    <i class="fa-solid fa-check"></i> Confirmar
                </button>
            </div>
        </div>
    </div>



    <div id="modal-ativo" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center backdrop-blur-sm">
        <div class="bg-white rounded-lg shadow-xl w-full max-w-md mx-4 overflow-hidden animate-in fade-in zoom-in duration-200">
            
            <div class="bg-slate-50 px-6 py-4 border-b flex justify-between items-center">
                <h3 class="font-bold text-lg text-slate-800">Iniciar Novo Atendimento</h3>
                <button onclick="fecharModalAtivo()" class="text-slate-400 hover:text-red-500 transition">
                    <i class="fa-solid fa-times text-xl"></i>
                </button>
            </div>

            <div class="p-6 space-y-4">
                
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-1">WhatsApp do Paciente</label>
                    <input type="text" id="ativo-telefone" placeholder="Ex: 62999998888 (Apenas números)" 
                        class="w-full border border-slate-300 rounded p-2 focus:ring-2 focus:ring-blue-500 outline-none">
                    <p class="text-[10px] text-slate-400 mt-1">Digite com DDD. Ex: 629...</p>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Nome do Paciente</label>
                    <input type="text" id="ativo-nome" placeholder="Nome Completo" 
                        class="w-full border border-slate-300 rounded p-2 focus:ring-2 focus:ring-blue-500 outline-none">
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Mensagem Inicial</label>
                    <textarea id="ativo-msg" rows="3" placeholder="Olá, gostaria de confirmar..." 
                            class="w-full border border-slate-300 rounded p-2 focus:ring-2 focus:ring-blue-500 outline-none"></textarea>
                </div>

            </div>

            <div class="bg-slate-50 px-6 py-4 border-t flex justify-end gap-2">
                <button onclick="fecharModalAtivo()" class="px-4 py-2 text-sm text-slate-600 hover:bg-slate-200 rounded transition">Cancelar</button>
                <button onclick="confirmarContatoAtivo()" id="btn-enviar-ativo" class="px-4 py-2 text-sm bg-green-600 hover:bg-green-700 text-white rounded font-bold transition flex items-center gap-2">
                    <i class="fa-regular fa-paper-plane"></i> Enviar
                </button>
            </div>
        </div>
    </div>







</div>

<script>
    // --- 1. CONFIGURAÇÃO GERAL E SOCKET ---
    const socket = io(); 
    let activeTicketId = null;
    const meuIdAtual = "<%= user ? user.id : '' %>"; 

    // --- FUNÇÕES UTILITÁRIAS (Helpers) ---
    
    // Formata a data (Ex: "14:30" ou "10/01 14:30")
    function formatarDataHora(dataString) {
        if (!dataString) return '';
        const data = new Date(dataString);
        const hoje = new Date();

        const isHoje = data.getDate() === hoje.getDate() &&
                       data.getMonth() === hoje.getMonth() &&
                       data.getFullYear() === hoje.getFullYear();

        const opcoesHora = { hour: '2-digit', minute: '2-digit' };
        
        if (isHoje) {
            return data.toLocaleTimeString('pt-BR', opcoesHora);
        }
        return data.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' }) + ' ' + 
               data.toLocaleTimeString('pt-BR', opcoesHora);
    }

    // Rola o chat para o final (Auto-Scroll)
    function rolarParaBaixo() {
        const areaMsg = document.getElementById('chat-messages');
        if (areaMsg) {
            setTimeout(() => {
                areaMsg.scrollTop = areaMsg.scrollHeight;
            }, 50);
        }
    }

    // --- INICIALIZAÇÃO ---

    document.addEventListener('DOMContentLoaded', () => {
        // Inicializa filtros da agenda
        const inputData = document.getElementById('tasy-data');
        if(inputData) inputData.valueAsDate = new Date();
        carregarUnidades();

        socket.on('connect', () => console.log('🟢 DataCare Socket Conectado:', socket.id));
        
        // 1.1 OUVINTE: Novas mensagens (Real-time)
        socket.on('nova_mensagem', (msg) => {
            const idDaMsg = msg.ticket_id || msg.ticketId;
            // Só renderiza se estiver com o chat desse ticket aberto
            if (activeTicketId && idDaMsg == activeTicketId) {
                renderizarMensagemNaTela(msg);
                rolarParaBaixo(); // ✅ Rola para baixo quando chega mensagem nova
            }
        });

        // 1.2 OUVINTE: Novo ticket entrando na fila
        socket.on('novo_ticket_fila', (ticket) => {
            adicionarTicketAFila(ticket);
        });

        
        
        // 1.3 OUVINTE: Movimentação de Ticket (Transbordo e Contato Ativo)
        socket.on('ticket_assumido_fila', (data) => {
            // Tenta achar o card na fila (caso venha de lá)
            const cardOriginal = document.querySelector(`.ticket-card[data-id="${data.ticketId}"]`);
            
            // Se for MEU ticket (ou eu assumi, ou eu criei ativo)
            if (data.atendenteId == meuIdAtual) {
                
                const listaMeus = document.getElementById('lista-meus');
                
                // Remove mensagem de "Vazio" se tiver
                const emptyMeus = document.getElementById('empty-meus');
                if (emptyMeus) emptyMeus.remove();

                // DADOS DO PACIENTE:
                // Se o card já existia (veio da fila), pega de lá. 
                // Se não (Contato Ativo), usa os dados que vieram no evento socket.
                let nome = data.nomePaciente || 'Paciente';
                if (cardOriginal) {
                    nome = cardOriginal.querySelector('h3').innerText;
                }
                const iniciais = nome.charAt(0).toUpperCase();

                // HTML DO NOVO CARD (Na aba Meus)
                const novoCardHtml = `
                    <div onclick="abrirChat(${data.ticketId})" 
                        class="ticket-card cursor-pointer p-4 border-b border-slate-50 hover:bg-slate-50 transition flex gap-3 items-center group relative animate-in fade-in" 
                        data-id="${data.ticketId}">
                        
                        <div class="w-12 h-12 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-lg shrink-0">
                            ${iniciais}
                        </div>
                        
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between">
                                <h3 class="font-bold text-slate-800 text-sm truncate">${nome}</h3>
                                <span class="text-[10px] text-slate-400">Online</span>
                            </div>
                            <p class="text-xs text-slate-500 truncate last-msg">
                                ${data.ultima_mensagem || 'Conversa iniciada...'}
                            </p>
                        </div>
                    </div>
                `;

                // Remove da fila se estava lá
                if (cardOriginal) cardOriginal.remove();

                // Adiciona no topo da lista "Meus"
                if (listaMeus) {
                    // Verifica se já não existe na lista meus (pra não duplicar visualmente)
                    const jaExiste = listaMeus.querySelector(`.ticket-card[data-id="${data.ticketId}"]`);
                    if (!jaExiste) {
                        listaMeus.insertAdjacentHTML('afterbegin', novoCardHtml);
                    }
                }

                // Se fui eu que criei o ativo agora, já abre o chat e muda a aba
                if (activeTicketId != data.ticketId) {
                    mudarAba('meus');
                    // Opcional: Se quiser abrir o chat automaticamente, descomente abaixo:
                    // abrirChat(data.ticketId); 
                }

            } else {
                // OUTRO ATENDENTE PEGOU: Apenas remove da fila se existir lá
                if (cardOriginal) cardOriginal.remove();
            }
            
            atualizarContadoresUI();
        });


        // 1.4 OUVINTE: Atualiza a lista lateral de "Meus" quando chega msg
        socket.on('atualizar_lista_meus', (data) => {
            // Procura o card na lista "Meus"
            const card = document.querySelector(`#lista-meus .ticket-card[data-id="${data.ticketId}"]`);
            if (card) {
                // Atualiza o texto da última mensagem
                const lastMsgEl = card.querySelector('.last-msg');
                if (lastMsgEl) {
                    lastMsgEl.innerText = data.msg;
                    lastMsgEl.classList.add('font-bold', 'text-slate-800'); // Destaca que é nova
                }
                
                // (Opcional) Poderíamos mover o card para o topo aqui
                const parent = card.parentNode;
                parent.prepend(card); // Move para o topo da lista
            }
        });
    });

    // --- 2. FUNÇÕES DE UI (DOM) ---

    function mudarAba(aba) {
        const isMeus = aba === 'meus';
        document.getElementById('lista-meus').classList.toggle('hidden', !isMeus);
        document.getElementById('lista-fila').classList.toggle('hidden', isMeus);
        
        document.getElementById('tab-meus').classList.toggle('bg-white', isMeus);
        document.getElementById('tab-meus').classList.toggle('shadow', isMeus);
        document.getElementById('tab-fila').classList.toggle('bg-white', !isMeus);
        document.getElementById('tab-fila').classList.toggle('shadow', !isMeus);
    }

    function atualizarContadoresUI() {
        const qtdFila = document.querySelectorAll('#lista-fila .ticket-card').length;
        const badgeFila = document.getElementById('count-fila');
        if (badgeFila) badgeFila.innerText = qtdFila;
    }

    // ✅ RENDERIZADOR AVANÇADO (WhatsApp Style)
    function renderizarMensagemNaTela(msg) {
        const container = document.getElementById('chat-messages');
        if (!container) return;
        
        // Limpa mensagens de "carregando" ou "vazio"
        if (container.innerText.includes('Carregando') || container.innerText.includes('Inicie')) container.innerHTML = '';

        const isMe = msg.remetente === 'ATENDENTE';
        const conteudo = msg.conteudo || msg.texto;
        const horaFormatada = formatarDataHora(msg.criado_em || new Date());

        const htmlMsg = `
            <div class="flex ${isMe ? 'justify-end' : 'justify-start'} mb-4 animate-in fade-in slide-in-from-bottom-2 duration-300">
                <div class="max-w-[70%] ${isMe ? 'bg-green-100 text-slate-800 rounded-tl-lg rounded-tr-none rounded-br-lg rounded-bl-lg' : 'bg-white border border-slate-200 text-slate-800 rounded-tl-none rounded-tr-lg rounded-br-lg rounded-bl-lg'} p-3 shadow-sm relative group">
                    
                    <p class="text-sm whitespace-pre-wrap leading-relaxed">${conteudo}</p>
                    
                    <div class="flex items-center justify-end gap-1 mt-1 opacity-70">
                        <span class="text-[10px] text-slate-500 font-medium">${horaFormatada}</span>
                        ${isMe ? '<i class="fa-solid fa-check-double text-[10px] text-blue-500"></i>' : ''}
                    </div>
                    
                    <div class="absolute top-0 ${isMe ? '-right-2 border-l-green-100' : '-left-2 border-r-white'} w-0 h-0 border-t-[10px] border-t-transparent border-b-[0px] border-b-transparent ${isMe ? 'border-l-[10px]' : 'border-r-[10px]'}"></div>
                </div>
            </div>`;
            
        container.insertAdjacentHTML('beforeend', htmlMsg);
    }

    // --- 3. LÓGICA DE NEGÓCIO (API CALLS) ---

    async function abrirChat(ticketId) {
        activeTicketId = ticketId;
        
        // 1. UI: Remove tela de vazio e mostra componentes do chat
        document.getElementById('chat-empty').classList.add('hidden');
        ['chat-header', 'chat-messages', 'chat-input'].forEach(id => {
            const el = document.getElementById(id);
            if(el) el.classList.remove('hidden');
        });
        
        // 2. Feedback de Carregamento
        const areaMsg = document.getElementById('chat-messages');
        areaMsg.innerHTML = '<div class="text-center text-xs text-slate-400 mt-10"><i class="fa-solid fa-spinner fa-spin"></i> Carregando...</div>';

        // 3. Socket: Entra na sala
        socket.emit('join_ticket', ticketId);

        // 4. HEADER: Preenche Nome, Avatar e o NOVO ID
        const card = document.querySelector(`.ticket-card[data-id="${ticketId}"]`);
        if(card) {
            const nome = card.querySelector('h3').innerText;
            document.getElementById('chat-nome').innerText = nome;
            document.getElementById('chat-avatar').innerText = nome.charAt(0);

            const idDisplay = document.getElementById('ticket-id-val');
            if (idDisplay) idDisplay.innerText = ticketId;
        }

        // 5. Busca Mensagens no Backend
        try {
            const res = await fetch(`/api/chat/mensagens/${ticketId}`);
            const mensagens = await res.json();
            
            areaMsg.innerHTML = mensagens.length ? '' : '<div class="text-center text-xs text-slate-400 mt-10">Inicie a conversa...</div>';
            
            mensagens.forEach(m => renderizarMensagemNaTela(m));
            
            // ✅ Rola para baixo assim que carrega
            rolarParaBaixo();

        } catch (e) {
            console.error(e);
            areaMsg.innerHTML = '<div class="text-center text-xs text-red-400 mt-10">Erro ao carregar histórico.</div>';
        }
    }

    function copiarTicketId() {
        if(!activeTicketId) return;
        navigator.clipboard.writeText(activeTicketId).then(() => {
            const Toast = Swal.mixin({
                toast: true, position: 'top', showConfirmButton: false, timer: 2000,
            });
            Toast.fire({ icon: 'success', title: `ID #${activeTicketId} copiado!` });
        });
    }

    // --- MODAL CONTATO ATIVO ---
    function abrirModalAtivo() {
        document.getElementById('modal-ativo').classList.remove('hidden');
        document.getElementById('ativo-telefone').focus();
    }

    function fecharModalAtivo() {
        document.getElementById('modal-ativo').classList.add('hidden');
        document.getElementById('ativo-telefone').value = '';
        document.getElementById('ativo-nome').value = '';
        document.getElementById('ativo-msg').value = '';
    }

    async function confirmarContatoAtivo() {
        const telefone = document.getElementById('ativo-telefone').value.replace(/\D/g, ''); 
        const nome = document.getElementById('ativo-nome').value;
        const msg = document.getElementById('ativo-msg').value;
        const btn = document.getElementById('btn-enviar-ativo');

        if (telefone.length < 10) return Swal.fire('Erro', 'Telefone inválido. Digite DDD + Número.', 'warning');
        if (!msg) return Swal.fire('Erro', 'Digite uma mensagem inicial.', 'warning');

        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Enviando...';

        try {
            const res = await fetch('/api/chat/iniciar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ telefone, nome, mensagem: msg })
            });

            const data = await res.json();

            if (data.success) {
                fecharModalAtivo();
                Swal.fire({ 
                    toast: true, icon: 'success', title: 'Mensagem enviada!', 
                    position: 'top-end', showConfirmButton: false, timer: 2000 
                });
                // O Socket já vai atualizar a lista e abrir o chat se necessário
            } else {
                throw new Error(data.error);
            }

        } catch (error) {
            console.error(error);
            Swal.fire('Erro', error.message || 'Falha ao iniciar contato.', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-regular fa-paper-plane"></i> Enviar';
        }
    }

    async function assumirTicket(ticketId) {
        try {
            await fetch('/api/chat/assumir', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ticketId })
            });
        } catch (e) { 
            console.error(e);
            Swal.fire('Erro', 'Não foi possível assumir este ticket.', 'error');
        }
    }

    async function enviarMensagem() {
        const input = document.getElementById('input-msg');
        const conteudo = input.value.trim();
        if (!conteudo || !activeTicketId) return;
        input.value = ''; input.focus();

        try {
            // Renderiza imediatamente (Otimista)
            // renderizarMensagemNaTela({ remetente: 'ATENDENTE', conteudo: conteudo, criado_em: new Date() });
            // rolarParaBaixo();
            
            await fetch('/api/chat/enviar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ticketId: activeTicketId, conteudo: conteudo })
            });
        } catch (e) { console.error("Erro ao enviar mensagem", e); }
    }

    function handleEnter(e) { if (e.key === 'Enter') enviarMensagem(); }

    function adicionarTicketAFila(ticket) {
        const containerFila = document.getElementById('lista-fila');
        if (containerFila) {
            if (containerFila.innerText.includes('vazia')) containerFila.innerHTML = '';
            const cardHtml = `
                <div class="ticket-card p-4 border-b border-slate-100 flex justify-between items-center bg-white mb-1 animate-in slide-in-from-left" data-id="${ticket.id}">
                    <div>
                        <h3 class="font-bold text-slate-700 text-sm">${ticket.nome_contato}</h3>
                        <p class="text-xs text-slate-400">${ticket.numero_whatsapp}</p>
                    </div>
                    <button onclick="assumirTicket(${ticket.id})" class="bg-green-600 hover:bg-green-700 text-white text-xs px-3 py-1.5 rounded font-bold transition active:scale-95">
                        Atender
                    </button>
                </div>`;
            containerFila.insertAdjacentHTML('afterbegin', cardHtml);
            atualizarContadoresUI();
        }
        Swal.fire({ toast: true, position: 'top-end', icon: 'info', title: 'Novo Paciente na Fila', showConfirmButton: false, timer: 3000 });
    }

    // --- 4. INTEGRAÇÃO TASY (Agenda) ---

    // Gatilho Principal (Unificado)
    async function verificarTipoAgenda() {
        const select = document.getElementById('tasy-unidade');
        const tipoId = select.value;
        const tipoTexto = select.options[select.selectedIndex].text.toUpperCase();
        
        // Elementos visuais
        const boxEsp = document.getElementById('box-especialidade');
        const boxConv = document.getElementById('box-convenio');
        const labelRecurso = document.getElementById('label-recurso');
        
        // Reset Geral
        resetSelect('tasy-especialidade', 'Carregando...');
        resetSelect('tasy-convenio', 'Carregando...');
        resetSelect('tasy-recurso', 'Aguardando...');

        if(!tipoId) return;

        const ehExame = tipoId == '2' || tipoTexto.includes('EXAME') || tipoTexto.includes('SADT');

        if (ehExame) {
            // --- MODO EXAME ---
            boxEsp.classList.add('hidden');
            boxConv.classList.add('hidden');
            labelRecurso.innerText = "2. Exame / Sala";
            carregarRecursosDiretoPorTipo(tipoId);
        } else {
            // --- MODO CONSULTA ---
            boxEsp.classList.remove('hidden');
            boxConv.classList.remove('hidden');
            labelRecurso.innerText = "4. Profissional";
            carregarEspecialidades(); 
        }
    }

    // [NOVA FUNÇÃO] Carrega recursos direto (para Exames)
    async function carregarRecursosDiretoPorTipo(tipoId) {
        const target = document.getElementById('tasy-recurso');
        target.innerHTML = '<option>Carregando Exames...</option>';
        
        try {
            const res = await fetch(`/api/tasy/recursos-simples/${tipoId}`); // Corrigi a rota para bater com a que criamos antes
            const dados = await res.json();

            if(dados.length > 0) {
                target.innerHTML = '<option value="">Selecione o Exame...</option>' + 
                    dados.map(d => `<option value="${d.CD_AGENDA}">${d.DS_AGENDA}</option>`).join('');
                target.disabled = false;
            } else {
                target.innerHTML = '<option value="">Nenhum exame disponível</option>';
            }
        } catch (e) {
            console.error(e);
            target.innerHTML = '<option>Erro ao buscar</option>';
        }
    }

    async function carregarUnidades() {
        const select = document.getElementById('tasy-unidade');
        try {
            const res = await fetch('/api/tasy/unidades');
            const dados = await res.json();
            select.innerHTML = '<option value="">Selecione...</option>' + 
                dados.map(d => `<option value="${d.CD_TIPO}">${d.DS_TIPO}</option>`).join('');
        } catch (e) { select.innerHTML = '<option>Erro ao carregar</option>'; }
    }

    async function carregarEspecialidades() {
        const idPai = document.getElementById('tasy-unidade').value;
        const target = document.getElementById('tasy-especialidade');
        resetSelect('tasy-especialidade', 'Carregando...');
        resetSelect('tasy-convenio', 'Aguardando Especialidade...');
        resetSelect('tasy-recurso', 'Aguardando Convênio...');

        if(!idPai) return resetSelect('tasy-especialidade', 'Selecione o Tipo...');
        carregarSelectGenerico(`/api/tasy/especialidades/${idPai}`, target, 'CD_ESPECIALIDADE', 'DS_ESPECIALIDADE');
    }

    async function carregarConvenios() {
        const idPai = document.getElementById('tasy-especialidade').value;
        const target = document.getElementById('tasy-convenio');
        resetSelect('tasy-convenio', 'Carregando...');
        resetSelect('tasy-recurso', 'Aguardando Convênio...');

        if(!idPai) return resetSelect('tasy-convenio', 'Selecione a Especialidade...');
        carregarSelectGenerico(`/api/tasy/convenios/${idPai}`, target, 'CD_CONVENIO', 'DS_CONVENIO');
    }

    async function carregarRecursos() {
        const idConvenio = document.getElementById('tasy-convenio').value;
        const idEspecialidade = document.getElementById('tasy-especialidade').value;
        const target = document.getElementById('tasy-recurso');

        target.innerHTML = '<option>Carregando...</option>';
        target.disabled = true;

        if(!idConvenio || !idEspecialidade) return resetSelect('tasy-recurso', 'Selecione os filtros...');

        const url = `/api/tasy/recursos?especialidade=${idEspecialidade}&convenio=${idConvenio}`;

        try {
            const res = await fetch(url);
            const dados = await res.json();
            
            if(dados.length > 0) {
                target.innerHTML = '<option value="">Selecione...</option>' + 
                    dados.map(d => `<option value="${d.CD_AGENDA}">${d.DS_AGENDA}</option>`).join('');
                target.disabled = false;
            } else {
                target.innerHTML = '<option value="">Nenhum médico encontrado</option>';
            }
        } catch (e) {
            console.error(e);
            target.innerHTML = '<option>Erro ao buscar</option>';
        }
    }

    // --- Helpers Genéricos ---
    function resetSelect(id, texto) {
        const el = document.getElementById(id);
        el.innerHTML = `<option value="">${texto}</option>`;
        el.disabled = true;
    }

    async function carregarSelectGenerico(url, elemento, campoValor, campoTexto) {
        try {
            const res = await fetch(url);
            const dados = await res.json();
            
            if(dados.length > 0) {
                elemento.innerHTML = '<option value="">Selecione...</option>' + 
                    dados.map(d => `<option value="${d[campoValor]}">${d[campoTexto]}</option>`).join('');
                elemento.disabled = false;
            } else {
                elemento.innerHTML = '<option value="">Vazio / Não encontrado</option>';
                elemento.disabled = true;
            }
        } catch (e) {
            console.error(e);
            elemento.innerHTML = '<option>Erro na busca</option>';
        }
    }

    async function buscarAgenda() {
        const recurso = document.getElementById('tasy-recurso').value;
        const data = document.getElementById('tasy-data').value;
        const container = document.getElementById('lista-agenda');
        if(!recurso || !data) return Swal.fire('Filtros', 'Selecione a agenda e a data', 'info');

        container.innerHTML = '<div class="p-8 text-center text-xs text-slate-500"><i class="fa-solid fa-spinner fa-spin"></i></div>';
        try {
            const res = await fetch('/api/tasy/agenda', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ recurso, data })
            });
            const agenda = await res.json();
            
            container.innerHTML = agenda.length ? '' : '<div class="p-8 text-center text-xs text-slate-400">Nenhum horário disponível.</div>';
            
            agenda.forEach(slot => {
                const statusClass = slot.IE_STATUS === 'L' ? 'bg-green-100 text-green-700' : 'bg-blue-100 text-blue-700';
                container.innerHTML += 
                    `<div class="flex items-center px-4 py-3 border-b border-slate-50 cursor-pointer hover:bg-slate-50 group transition" oncontextmenu="abrirMenuContexto(event, ${slot.ID})">
                        <div class="w-14 font-bold text-slate-600 text-xs">${slot.HORA}</div>
                        
                        <div class="flex-1 flex items-center gap-2 min-w-0">
                            <span class="truncate font-bold text-slate-800 text-xs">${slot.PACIENTE || 'Livre'}</span>
                            ${slot.CONVENIO ? `<span class="shrink-0 text-[10px] text-slate-400 font-medium">(${slot.CONVENIO})</span>` : ''}
                        </div>

                        <span class="text-[9px] px-1.5 py-0.5 rounded font-bold uppercase ${statusClass}">
                            ${slot.STATUS_DESC || slot.IE_STATUS}
                        </span>
                    </div>`;
            });
        } catch (e) { container.innerHTML = 'Erro na consulta do Tasy.'; }
    }

    // --- 5. MENU DE CONTEXTO E MODAL ---
    let agendaIdSelecionado = null;

    function abrirMenuContexto(e, idAgenda) {
        e.preventDefault(); 
        agendaIdSelecionado = idAgenda;
        const menu = document.getElementById('context-menu');
        menu.style.top = `${e.clientY}px`;
        menu.style.left = `${e.clientX}px`;
        menu.classList.remove('hidden');
    }

    document.addEventListener('click', () => {
        const menu = document.getElementById('context-menu');
        if(menu) menu.classList.add('hidden');
    });

    async function acaoAgenda(acao) {
        document.getElementById('context-menu').classList.add('hidden');
        
        if (acao === 'agendar') return abrirModalAgendamento();

        const configs = {
            confirmar: { titulo: 'Confirmar Agendamento?', cor: '#16a34a', endpoint: '/api/tasy/confirmar' },
            cancelar: { titulo: 'Cancelar Agendamento?', cor: '#dc2626', endpoint: '/api/tasy/cancelar' },
            bloquear: { titulo: 'Bloquear Horário?', cor: '#ea580c', endpoint: '/api/tasy/bloquear' }
        };

        const config = configs[acao];

        const result = await Swal.fire({
            title: config.titulo,
            text: "Deseja replicar essa alteração no Tasy (Oracle)?",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: config.cor,
            cancelButtonColor: '#64748b',
            confirmButtonText: 'Sim, processar',
            cancelButtonText: 'Voltar',
            reverseButtons: true
        });

        if (result.isConfirmed) {
            const toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 2000 });
            toast.fire({ icon: 'info', title: 'Processando no Tasy...' });

            fetch(config.endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ agendaId: agendaIdSelecionado })
            }).then(res => res.json()).then(data => {
                if (data.success) {
                    toast.fire({ icon: 'success', title: 'Atualizado!' });
                    buscarAgenda(); 
                }
            });
        }
    }

    async function confirmarAgendamento() {
        const id = document.getElementById('modal-agenda-id').value;
        const paciente = document.getElementById('modal-paciente-nome').value;
        const obs = document.getElementById('modal-obs').value;
        const btn = document.getElementById('btn-confirmar');

        if(!paciente) return Swal.fire('Atenção', 'Digite o nome do paciente.', 'warning');

        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Salvando...';

        try {
            const res = await fetch('/api/tasy/agendar', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ agendaId: id, pacienteNome: paciente, obs: obs })
            });
            const data = await res.json();
            if(data.success) {
                fecharModal();
                buscarAgenda();
                Swal.fire('Sucesso', 'Paciente agendado no Tasy!', 'success');
            }
        } catch (e) { 
            Swal.fire('Erro', 'Falha ao salvar no Oracle.', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-check"></i> Confirmar';
        }
    }

    function fecharModal() { document.getElementById('modal-agendamento').classList.add('hidden'); }
    function abrirModalAgendamento() {
        document.getElementById('modal-agenda-id').value = agendaIdSelecionado;
        document.getElementById('modal-agendamento').classList.remove('hidden');
    }
</script>