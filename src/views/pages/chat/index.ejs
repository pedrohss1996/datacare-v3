<script src="/socket.io/socket.io.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="flex h-[calc(100vh-64px)] bg-slate-100 overflow-hidden font-sans">
    
    <aside class="w-[320px] bg-white border-r border-slate-200 flex flex-col z-10 shrink-0">
        <%- include('./partials/lista-chats') %> 
    </aside>

    <main class="flex-1 flex flex-col bg-[#efeae2] relative min-w-[400px] border-r border-slate-300">
        <%- include('./partials/area-chat') %> 
    </main>

    <aside class="w-[400px] bg-white flex flex-col shadow-xl z-20 border-l border-slate-200">
        
        <div class="h-14 bg-slate-800 text-white flex items-center px-4 gap-2 shadow-sm shrink-0">
            <i class="fa-solid fa-hospital-user"></i>
            <h2 class="font-bold text-sm tracking-wide">Integração Agenda</h2>
        </div>

        <div class="p-4 bg-slate-50 border-b border-slate-200 space-y-3 shrink-0">
            
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Tipo de Agenda</label>
                <select id="tasy-unidade" class="w-full text-xs border border-slate-300 rounded h-9 px-2 bg-white text-slate-700 focus:ring-1 focus:ring-blue-500 outline-none" onchange="carregarRecursos()">
                    <option value="">Carregando Agendas...</option>
                </select>
            </div>

            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">AGENDA</label>
                <select id="tasy-recurso" class="w-full text-xs border border-slate-300 rounded h-9 px-2 bg-white text-slate-700 focus:ring-1 focus:ring-blue-500 outline-none">
                    <option value="">Selecione a Agenda primeiro</option>
                </select>
            </div>

            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">DATA</label>
                <div class="flex gap-2">
                    <input type="date" id="tasy-data" class="flex-1 text-xs border border-slate-300 rounded h-9 px-2 text-slate-700 focus:ring-1 focus:ring-blue-500 outline-none">
                    <button onclick="buscarAgenda()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 rounded h-9 text-xs font-bold flex items-center gap-2 transition">
                        <i class="fa-solid fa-rotate"></i> Listar
                    </button>
                </div>
            </div>
        </div>

        <div class="bg-slate-100 py-1 px-4 border-b border-slate-200 text-center">
            <p class="text-[10px] text-slate-500"><i class="fa-solid fa-mouse-pointer mr-1"></i> Botão direito p/ ações</p>
        </div>

        <div class="flex-1 overflow-y-auto bg-white relative">
            <div class="sticky top-0 bg-slate-100 border-b border-slate-200 flex px-4 py-2 text-xs font-bold text-slate-600 z-10">
                <div class="w-16">Hora</div>
                <div class="flex-1">Paciente / Status</div>
            </div>
            <div id="lista-agenda" class="divide-y divide-slate-100">
                <div class="flex flex-col items-center justify-center h-40 text-slate-400">
                    <i class="fa-regular fa-calendar text-2xl mb-2"></i>
                    <span class="text-xs">Selecione os filtros</span>
                </div>
            </div>
        </div>
    </aside>

    <div id="context-menu" class="fixed hidden bg-white border border-slate-200 shadow-xl rounded-lg w-56 py-2 z-50 text-sm flex flex-col">
        
        <button onclick="acaoAgenda('agendar')" class="text-left px-4 py-2 hover:bg-slate-50 text-slate-700 flex items-center gap-3 transition">
            <div class="w-5 text-center"><i class="fa-regular fa-calendar-plus text-blue-600"></i></div>
            <span>Agendar</span>
        </button>

        <button onclick="acaoAgenda('confirmar')" class="text-left px-4 py-2 hover:bg-slate-50 text-slate-700 flex items-center gap-3 transition">
            <div class="w-5 text-center"><i class="fa-solid fa-check-double text-green-600"></i></div>
            <span>Confirmar</span>
        </button>

        <button onclick="acaoAgenda('transferir')" class="text-left px-4 py-2 hover:bg-slate-50 text-slate-700 flex items-center gap-3 transition">
            <div class="w-5 text-center"><i class="fa-solid fa-arrow-right-arrow-left text-orange-500"></i></div>
            <span>Transferir</span>
        </button>

        <div class="border-t border-slate-100 my-1"></div>

        <button onclick="acaoAgenda('bloquear')" class="text-left px-4 py-2 hover:bg-slate-50 text-slate-700 flex items-center gap-3 transition">
            <div class="w-5 text-center"><i class="fa-solid fa-ban text-red-500"></i></div>
            <span>Bloquear</span>
        </button>

        <button onclick="acaoAgenda('cancelar')" class="text-left px-4 py-2 hover:bg-red-50 text-red-600 flex items-center gap-3 transition">
            <div class="w-5 text-center"><i class="fa-regular fa-calendar-xmark"></i></div>
            <span>Cancelar</span>
        </button>
    </div>

    <div id="modal-agendamento" class="fixed inset-0 bg-black/50 z-[60] hidden flex items-center justify-center backdrop-blur-sm">
        <div class="bg-white rounded-lg shadow-2xl w-[400px] overflow-hidden transform transition-all scale-100">
            <div class="bg-slate-800 text-white px-4 py-3 flex justify-between items-center">
                <h3 class="font-bold text-sm"><i class="fa-regular fa-calendar-check mr-2"></i> Confirmar Agendamento</h3>
                <button onclick="fecharModal()" class="text-slate-400 hover:text-white"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="p-6 space-y-4">
                <input type="hidden" id="modal-agenda-id">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Paciente</label>
                    <input type="text" id="modal-paciente-nome" class="w-full border border-slate-300 rounded px-3 py-2 text-sm bg-slate-50 font-bold text-slate-700 focus:ring-2 focus:ring-blue-500 outline-none" placeholder="Digite o nome do paciente...">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Observação / Convênio</label>
                    <textarea id="modal-obs" rows="3" class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none" placeholder="Ex: Particular, Unimed..."></textarea>
                </div>
            </div>
            <div class="bg-slate-50 px-6 py-3 flex justify-end gap-2 border-t border-slate-200">
                <button onclick="fecharModal()" class="px-4 py-2 text-xs font-bold text-slate-600 hover:bg-slate-200 rounded">Cancelar</button>
                <button onclick="confirmarAgendamento()" id="btn-confirmar" class="px-4 py-2 text-xs font-bold text-white bg-green-600 hover:bg-green-700 rounded shadow-sm flex items-center gap-2">
                    <i class="fa-solid fa-check"></i> Confirmar
                </button>
            </div>
        </div>
    </div>

</div>

<script>
    // --- 1. CONFIGURAÇÃO GERAL E SOCKET ---
    const socket = io(); 
    let activeTicketId = null;

    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('tasy-data').valueAsDate = new Date();
        carregarUnidades();

        socket.on('connect', () => console.log('🟢 Socket Conectado:', socket.id));
        
        socket.on('nova_mensagem', (msg) => {
            if (activeTicketId && (msg.ticket_id == activeTicketId || msg.ticketId == activeTicketId)) {
                renderizarMensagem(msg);
                scrollParaBaixo();
            } else {
                console.log('Nova mensagem em outro ticket:', msg);
            }
        });
    });

    // --- 2. FUNÇÕES DO CHAT ---

    function mudarAba(aba) {
        if(aba === 'meus') {
            document.getElementById('lista-meus').classList.remove('hidden');
            document.getElementById('lista-fila').classList.add('hidden');
            document.getElementById('tab-meus').classList.add('bg-white', 'shadow', 'text-slate-800');
            document.getElementById('tab-meus').classList.remove('text-slate-500');
            document.getElementById('tab-fila').classList.remove('bg-white', 'shadow', 'text-slate-800');
            document.getElementById('tab-fila').classList.add('text-slate-500');
        } else {
            document.getElementById('lista-meus').classList.add('hidden');
            document.getElementById('lista-fila').classList.remove('hidden');
            document.getElementById('tab-fila').classList.add('bg-white', 'shadow', 'text-slate-800');
            document.getElementById('tab-fila').classList.remove('text-slate-500');
            document.getElementById('tab-meus').classList.remove('bg-white', 'shadow', 'text-slate-800');
            document.getElementById('tab-meus').classList.add('text-slate-500');
        }
    }

    async function abrirChat(ticketId) {
        activeTicketId = ticketId;
        
        document.getElementById('chat-empty').classList.add('hidden');
        document.getElementById('chat-header').classList.remove('hidden');
        document.getElementById('chat-messages').classList.remove('hidden');
        document.getElementById('chat-input').classList.remove('hidden');
        
        const areaMsg = document.getElementById('chat-messages');
        areaMsg.innerHTML = '<div class="text-center text-xs text-slate-400 mt-4"><i class="fa-solid fa-spinner fa-spin"></i> Carregando histórico...</div>';

        socket.emit('join_ticket', ticketId);

        const card = document.querySelector(`.ticket-card[data-id="${ticketId}"]`);
        if(card) {
            const nome = card.querySelector('h3').innerText;
            document.getElementById('chat-nome').innerText = nome;
            document.getElementById('chat-avatar').innerText = nome.charAt(0);
        }

        try {
            const res = await fetch(`/api/chat/mensagens/${ticketId}`);
            const mensagens = await res.json();
            
            areaMsg.innerHTML = ''; 
            
            if(mensagens.length === 0) {
                areaMsg.innerHTML = '<div class="text-center text-xs text-slate-400 mt-4">Inicie a conversa...</div>';
            }

            mensagens.forEach(m => renderizarMensagem(m));
            scrollParaBaixo();
        } catch (e) {
            areaMsg.innerHTML = '<div class="text-center text-xs text-red-400 mt-4">Erro ao carregar mensagens.</div>';
        }
    }

    function renderizarMensagem(msg) {
        const area = document.getElementById('chat-messages');
        const isMe = msg.remetente === 'ATENDENTE';
        
        const html = `
            <div class="flex ${isMe ? 'justify-end' : 'justify-start'}">
                <div class="max-w-[75%] p-2 px-3 rounded-lg text-sm shadow-sm relative ${isMe ? 'bg-[#d9fdd3] text-slate-800 rounded-tr-none' : 'bg-white text-slate-800 rounded-tl-none'}">
                    <p class="mb-1">${msg.conteudo || msg.texto}</p>
                    <span class="text-[9px] opacity-60 block text-right float-right ml-2 mt-1">
                        ${new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})} 
                        ${isMe ? '<i class="fa-solid fa-check-double text-blue-400 ml-1"></i>' : ''}
                    </span>
                </div>
            </div>
        `;
        area.innerHTML += html;
    }

    async function enviarMensagem() {
        const input = document.getElementById('input-msg');
        const texto = input.value.trim();
        if(!texto || !activeTicketId) return;

        input.value = ''; 
        input.focus();

        renderizarMensagem({ remetente: 'ATENDENTE', conteudo: texto });
        scrollParaBaixo();

        try {
            await fetch('/api/whatsapp/enviar', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ ticketId: activeTicketId, conteudo: texto })
            });
        } catch (e) {
            alert('Erro ao enviar mensagem');
        }
    }

    async function finalizarAtendimento() {
        if(!activeTicketId) return;
        if(!confirm('Deseja finalizar este atendimento? O ticket será fechado.')) return;

        try {
            const res = await fetch('/api/chat/finalizar', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ ticketId: activeTicketId })
            });
            const data = await res.json();

            if(data.success) {
                document.getElementById('chat-empty').classList.remove('hidden');
                document.getElementById('chat-header').classList.add('hidden');
                document.getElementById('chat-messages').classList.add('hidden');
                document.getElementById('chat-input').classList.add('hidden');
                
                const card = document.querySelector(`.ticket-card[data-id="${activeTicketId}"]`);
                if(card) card.remove();

                activeTicketId = null;
                alert('Atendimento finalizado com sucesso!');
            }
        } catch (e) {
            alert('Erro ao finalizar');
        }
    }

    function handleEnter(e) {
        if(e.key === 'Enter') enviarMensagem();
    }

    function scrollParaBaixo() {
        const div = document.getElementById('chat-messages');
        div.scrollTop = div.scrollHeight;
    }

    // --- 3. FUNÇÕES DO TASY (Agenda) ---
    
    async function carregarUnidades() {
        const select = document.getElementById('tasy-unidade');
        try {
            const res = await fetch('/api/tasy/unidades');
            const unidades = await res.json();
            
            select.innerHTML = '<option value="">Selecione...</option>';
            unidades.forEach(u => {
                select.innerHTML += `<option value="${u.CD_TIPO}">${u.DS_TIPO}</option>`;
            });
        } catch (e) { 
            console.error('Erro ao carregar unidades Tasy');
            select.innerHTML = '<option value="">Erro ao carregar</option>';
        }
    }

    async function carregarRecursos() {
        const unidadeId = document.getElementById('tasy-unidade').value;
        const select = document.getElementById('tasy-recurso');
        
        if(!unidadeId) {
            select.innerHTML = '<option value="">Selecione a tipo da agenda</option>';
            return;
        }

        try {
            select.innerHTML = '<option>Carregando...</option>';
            const res = await fetch(`/api/tasy/recursos/${unidadeId}`);
            const recursos = await res.json();
            
            select.innerHTML = '';
            recursos.forEach(r => {
                select.innerHTML += `<option value="${r.CD_AGENDA}">${r.DS_AGENDA}</option>`;
            });
        } catch (e) { console.error('Erro ao selecionar a Agenda no Tasy', e); }
    }

    async function buscarAgenda() {
        const recurso = document.getElementById('tasy-recurso').value;
        const data = document.getElementById('tasy-data').value;
        const container = document.getElementById('lista-agenda');

        if(!recurso || !data) return alert('Preencha os filtros da agenda');

        container.innerHTML = '<div class="p-4 text-center text-xs text-slate-500"><i class="fa-solid fa-spinner fa-spin"></i> Carregando Horários...</div>';

        try {
            const res = await fetch('/api/tasy/agenda', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ recurso, data })
            });
            const agenda = await res.json();

            container.innerHTML = ''; 

            if(!agenda || agenda.length === 0) {
                container.innerHTML = '<div class="p-4 text-center text-xs text-slate-400">Nenhum horário encontrado.</div>';
                return;
            }

            agenda.forEach(slot => {
                let bgClass = '', statusClass = '', statusTexto = slot.STATUS_DESC || slot.IE_STATUS;

                if(slot.IE_STATUS === 'L') { 
                    bgClass = 'hover:bg-slate-50'; statusClass = 'bg-green-100 text-green-700'; 
                } else if (slot.IE_STATUS === 'A') { 
                    bgClass = 'bg-blue-50/50 hover:bg-blue-50'; statusClass = 'bg-blue-100 text-blue-700'; 
                } else if (slot.IE_STATUS === 'C') {
                    bgClass = 'bg-green-50/30'; statusClass = 'bg-green-600 text-white';
                } else {
                    bgClass = 'bg-slate-50 opacity-70'; statusClass = 'bg-red-100 text-red-700';
                }

                // AQUI FOI ADICIONADO O ONCONTEXTMENU
                const html = `
                    <div class="flex items-center px-4 py-3 border-b border-slate-50 cursor-pointer ${bgClass} group transition" oncontextmenu="abrirMenuContexto(event, ${slot.ID})">
                        <div class="w-14 font-bold text-slate-600 text-xs">${slot.HORA}</div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-center mb-0.5">
                                <span class="font-bold text-slate-800 text-xs truncate">
                                    ${slot.PACIENTE || 'Livre'}
                                </span>
                                <span class="text-[9px] px-1.5 py-0.5 rounded font-bold uppercase ${statusClass}">
                                    ${statusTexto}
                                </span>
                            </div>
                        </div>
                    </div>
                `;
                container.innerHTML += html;
            });

        } catch (e) {
            container.innerHTML = '<div class="p-4 text-center text-xs text-red-500">Erro na consulta.</div>';
        }
    }

    // --- 4. MENU DE CONTEXTO E MODAL ---

    let agendaIdSelecionado = null; // Guarda o ID do horário clicado

    // Fecha o menu se clicar fora
    document.addEventListener('click', (e) => {
        if (!e.target.closest('#context-menu')) {
            document.getElementById('context-menu').classList.add('hidden');
        }
    });

    function abrirMenuContexto(e, idAgenda) {
        e.preventDefault(); 
        agendaIdSelecionado = idAgenda;
        const menu = document.getElementById('context-menu');
        menu.style.top = `${e.clientY}px`;
        menu.style.left = `${e.clientX}px`;
        menu.classList.remove('hidden');
    }

    async function acaoAgenda(acao) {
        document.getElementById('context-menu').classList.add('hidden'); // Fecha menu
        
        // 1. AGENDAR (Abre o Modal HTML que já fizemos - Esse continua igual)
        if(acao === 'agendar') {
            abrirModalAgendamento();
            return;
        }

        // Configurações visuais para cada tipo de ação
        let titulo = '';
        let texto = '';
        let corBotao = '';
        let icone = '';
        let inputType = null; // Para o caso de Transferir
        let endpoint = '';
        let body = { agendaId: agendaIdSelecionado };

        switch(acao) {
            case 'confirmar':
                titulo = 'Confirmar Agendamento?';
                texto = 'O status mudará para Confirmado.';
                corBotao = '#16a34a'; // Green-600
                icone = 'question';
                endpoint = '/api/tasy/confirmar';
                break;

            case 'cancelar':
                titulo = 'Cancelar Agendamento?';
                texto = 'O horário ficará livre e o histórico será guardado.';
                corBotao = '#dc2626'; // Red-600
                icone = 'warning';
                endpoint = '/api/tasy/cancelar';
                break;

            case 'bloquear':
                titulo = 'Bloquear Horário?';
                texto = 'Ninguém poderá agendar neste horário.';
                corBotao = '#ea580c'; // Orange-600
                icone = 'error'; // X vermelho
                endpoint = '/api/tasy/bloquear';
                break;

            case 'transferir':
                titulo = 'Transferir Paciente';
                texto = 'Digite o ID da Agenda de DESTINO:';
                corBotao = '#2563eb'; // Blue-600
                icone = 'info';
                inputType = 'text'; // Habilita o campo de digitação
                endpoint = '/api/tasy/transferir';
                break;
        }

        // --- 2. MOSTRA O MODAL DE CONFIRMAÇÃO (SweetAlert) ---
        const result = await Swal.fire({
            title: titulo,
            text: inputType ? texto : texto, 
            icon: icone,
            input: inputType, // Só aparece se for 'transferir'
            inputPlaceholder: inputType ? 'Ex: 123456' : '',
            showCancelButton: true,
            confirmButtonColor: corBotao,
            cancelButtonColor: '#64748b', // Slate-500
            confirmButtonText: 'Sim, confirmar',
            cancelButtonText: 'Cancelar',
            reverseButtons: true, // Botão de cancelar na esquerda (UX melhor)
            showLoaderOnConfirm: true, // Mostra spinner ao clicar
            preConfirm: async (inputValue) => {
                // Se for Transferir, valida se digitou algo
                if (acao === 'transferir') {
                    if (!inputValue) {
                        Swal.showValidationMessage('Você precisa digitar o ID de destino!');
                        return false;
                    }
                    body.novoId = inputValue;
                }

                // --- 3. EXECUTA A REQUISIÇÃO DENTRO DO MODAL ---
                try {
                    const response = await fetch(endpoint, {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify(body)
                    });
                    
                    const data = await response.json();
                    
                    if (!response.ok || !data.success) {
                        throw new Error(data.error || 'Erro desconhecido');
                    }
                    
                    return data;

                } catch (error) {
                    Swal.showValidationMessage(`Erro: ${error.message}`);
                }
            },
            allowOutsideClick: () => !Swal.isLoading()
        });

        // --- 4. FEEDBACK FINAL ---
        if (result.isConfirmed) {
            await Swal.fire({
                title: 'Sucesso!',
                text: 'Ação realizada com sucesso.',
                icon: 'success',
                timer: 2000,
                showConfirmButton: false
            });
            
            // Atualiza a lista do Tasy
            buscarAgenda();
        }
    }

    function abrirModalAgendamento() {
        document.getElementById('modal-paciente-nome').value = '';
        document.getElementById('modal-obs').value = '';
        document.getElementById('modal-agenda-id').value = agendaIdSelecionado;
        document.getElementById('modal-agendamento').classList.remove('hidden');
        document.getElementById('modal-paciente-nome').focus();
    }

    function fecharModal() {
        document.getElementById('modal-agendamento').classList.add('hidden');
    }

    async function confirmarAgendamento() {
        const id = document.getElementById('modal-agenda-id').value;
        const paciente = document.getElementById('modal-paciente-nome').value;
        const obs = document.getElementById('modal-obs').value;
        const btn = document.getElementById('btn-confirmar');

        if(!paciente) return alert('Digite o nome do paciente.');

        const textoOriginal = btn.innerHTML;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Salvando...';
        btn.disabled = true;

        try {
            const res = await fetch('/api/tasy/agendar', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ agendaId: id, pacienteNome: paciente, obs: obs })
            });

            const data = await res.json();

            if(data.success) {
                fecharModal();
                buscarAgenda(); // Atualiza a lista
                alert('Agendamento realizado com sucesso!');
            } else {
                alert('Erro ao agendar: ' + (data.error || 'Desconhecido'));
            }

        } catch (e) {
            console.error(e);
            alert('Erro de comunicação.');
        } finally {
            btn.innerHTML = textoOriginal;
            btn.disabled = false;
        }
    }

    async function assumirTicket(ticketId) {
        try {
            const response = await fetch('/api/chat/assumir', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ticketId })
            });
            
            const data = await response.json();

            if (data.success) {
                // Recarrega para mover o card da 'Fila' para 'Meus' e abrir o chat
                window.location.reload(); 
            } else {
                Swal.fire('Ops!', data.error, 'warning');
            }
        } catch (error) {
            console.error(error);
            Swal.fire('Erro', 'Não foi possível assumir este atendimento.', 'error');
        }
    }

    socket.on('novo_ticket_fila', (ticket) => {
    
        // 1. Atualiza o contador na aba FILA (HTML que você mandou antes)
        const countBadge = document.getElementById('count-fila');
        if (countBadge) {
            let atual = parseInt(countBadge.innerText) || 0;
            countBadge.innerText = atual + 1;
        }

        // 2. Injeta o Card na lista de Fila (lista-chat.ejs)
        const containerFila = document.getElementById('lista-fila');
        if (containerFila) {
            // Limpa a mensagem de "Fila vazia" se existir
            if (containerFila.innerText.includes('Fila vazia')) {
                containerFila.innerHTML = '';
            }

            // Template do card conforme seu estilo
            const cardHtml = `
                <div class="p-4 border-b border-slate-100 flex justify-between items-center bg-white mb-1 animate-in fade-in slide-in-from-left duration-500">
                    <div>
                        <h3 class="font-bold text-slate-700 text-sm">${ticket.nome_contato}</h3>
                        <p class="text-xs text-slate-400">${ticket.numero_whatsapp}</p>
                    </div>
                    <button onclick="assumirTicket(${ticket.id})" class="bg-green-600 hover:bg-green-700 text-white text-xs px-3 py-1.5 rounded font-bold shadow-sm transition transform active:scale-95">
                        Atender
                    </button>
                </div>
            `;
            
            containerFila.insertAdjacentHTML('afterbegin', cardHtml);
        }

        // 3. Notificação Visual (SweetAlert)
        Swal.fire({
            toast: true,
            position: 'top-end',
            icon: 'info',
            title: 'Novo Paciente na Fila',
            text: ticket.nome_contato,
            showConfirmButton: false,
            timer: 4000
        });
    });


    async function assumirTicket(ticketId) {
        try {
            const res = await fetch('/api/chat/assumir', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ticketId })
            });

            const data = await res.json();

            if (data.success) {
                // Em vez de reload, vamos ser elegantes:
                Swal.fire({
                    icon: 'success',
                    title: 'Ticket Assumido!',
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 2000
                });

                // Recarrega para mover o card de coluna (ou você pode mover via JS)
                window.location.reload(); 
            } else {
                Swal.fire('Ops!', data.error, 'warning');
            }
        } catch (e) {
            console.error(e);
        }
    }
</script>