<div class="max-w-[85rem] mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full bg-slate-50 min-h-screen">
    <div class="space-y-10">

        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200 flex flex-col md:flex-row items-center justify-between gap-4">

            <%
            // --- FUNÇÃO PARA FORMATAR O NOME ---
            function capitalizeName(texto) {
                if (!texto) return 'Usuário'; 
                const str = String(texto);
                return str.toLowerCase().split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
            }
            
            // --- LÓGICA INTELIGENTE DE SELEÇÃO DE NOME ---
            // 1. Pega o objeto user (se existir)
            const u = (typeof user !== 'undefined' && user) ? user : {};
            
            // 2. Tenta achar o nome em TODAS as variações possíveis que seu sistema gera
            // username: é como está vindo agora (do token JWT)
            // name: é como salvamos na sessão
            // nome: é como vem do banco as vezes
            const nomeParaMostrar = u.name || u.nome || u.username || u.nm_usuario || u.login || 'Visitante';
            %>

            <div>
                <h1 class="text-xl font-bold text-slate-800">
                    Olá,
                    <span class="text-blue-600">
                        <%= capitalizeName(nomeParaMostrar) %>
                    </span>
                </h1>
                <p class="text-slate-500 text-sm mt-1">
                    Bem-vindo ao DataCare.
                </p>
            </div>
            
            <div class="flex items-center gap-6">
                <div class="flex items-center gap-2 px-3 py-1.5 bg-emerald-50 text-emerald-700 rounded-md border border-emerald-100 shadow-sm">
                    <span class="relative flex h-2.5 w-2.5">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                    </span>
                    <span class="text-xs font-semibold tracking-wide">Online</span>
                </div>
                <div class="hidden md:block text-slate-400 text-sm font-medium">
                    <%= new Date().toLocaleDateString('pt-BR') %>
                </div>
            </div>
        </div>

        <div>
            <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-8">
                <h2 class="text-xl font-bold text-slate-800 tracking-tight">
                    Administrador
                </h2>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-x-4 gap-y-12">

                <a href="/indicadores" class="group flex flex-col items-center text-center">
                    <div class="w-[4.5rem] h-[4.5rem] bg-white rounded-2xl border border-blue-200 flex items-center justify-center shadow-sm group-hover:bg-blue-600 group-hover:border-blue-600 group-hover:shadow-lg group-hover:-translate-y-1 transition-all duration-300 ease-out">
                        <svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                        </svg>
                    </div>
                    <span class="mt-3 text-sm font-medium text-slate-600 group-hover:text-blue-700 transition-colors px-1 leading-tight">
                        Construtor de<br>Indicadores
                    </span>
                </a>

                <a href="/pessoas" class="group flex flex-col items-center text-center">
                    <div class="w-[4.5rem] h-[4.5rem] bg-white rounded-2xl border border-blue-200 flex items-center justify-center shadow-sm group-hover:bg-blue-600 group-hover:border-blue-600 group-hover:shadow-lg group-hover:-translate-y-1 transition-all duration-300 ease-out">
                        <svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                    </div>
                    <span class="mt-3 text-sm font-medium text-slate-600 group-hover:text-blue-700 transition-colors px-1 leading-tight">
                        Cadastro de<br>Pessoas
                    </span>
                </a>

                <a href="/indicadores/visualizar" class="group flex flex-col items-center text-center">
                    <div class="w-[4.5rem] h-[4.5rem] bg-white rounded-2xl border border-blue-200 flex items-center justify-center shadow-sm group-hover:bg-blue-600 group-hover:border-blue-600 group-hover:shadow-lg group-hover:-translate-y-1 transition-all duration-300 ease-out">
                        <svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                    </div>
                    <span class="mt-3 text-sm font-medium text-slate-600 group-hover:text-blue-700 transition-colors px-1 leading-tight">
                        Visualizar<br>Indicadores
                    </span>
                </a>

                <a href="/ia-builder" class="group flex flex-col items-center text-center">
                    <div class="w-[4.5rem] h-[4.5rem] bg-white rounded-2xl border border-blue-200 flex items-center justify-center shadow-sm group-hover:bg-blue-600 group-hover:border-blue-600 group-hover:shadow-lg group-hover:-translate-y-1 transition-all duration-300 ease-out">
                        <svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                    </div>
                    <span class="mt-3 text-sm font-medium text-slate-600 group-hover:text-blue-700 transition-colors px-1 leading-tight">
                        Construtor<br>IA
                    </span>
                </a>

                <a href="/permissoes" class="group flex flex-col items-center text-center">
                    <div class="w-[4.5rem] h-[4.5rem] bg-white rounded-2xl border border-blue-200 flex items-center justify-center shadow-sm group-hover:bg-blue-600 group-hover:border-blue-600 group-hover:shadow-lg group-hover:-translate-y-1 transition-all duration-300 ease-out">
                        <svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                    </div>
                    <span class="mt-3 text-sm font-medium text-slate-600 group-hover:text-blue-700 transition-colors px-1 leading-tight">
                        Gerenciar<br>Permissões
                    </span>
                </a>

                <a href="/chat" class="group flex flex-col items-center text-center"> 
                    <div class="w-[4.5rem] h-[4.5rem] bg-white rounded-2xl border border-blue-200 flex items-center justify-center shadow-sm group-hover:bg-blue-600 group-hover:border-blue-600 group-hover:shadow-lg group-hover:-translate-y-1 transition-all duration-300 ease-out">
                        
                        <svg
                            class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors duration-300"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M8 10h8M8 14h5M21 12c0 3.866-3.582 7-8 7a8.96 8.96 0 01-4-.9L3 19l1.3-3.9A6.77 6.77 0 013 12c0-3.866 3.582-7 8-7s8 3.134 8 7z"
                            />
                        </svg>

                    </div>
                    <span class="mt-3 text-sm font-medium text-slate-600 group-hover:text-blue-700 transition-colors px-1 leading-tight">
                        Chat<br>Atendimento
                    </span>
                </a>

            </div>
        </div>

        <div>
            <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-8">
                <h2 class="text-xl font-bold text-slate-800 tracking-tight">
                    Assitencial
                </h2>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-x-4 gap-y-12">

                <a href="/indicadores" class="group flex flex-col items-center text-center">
                    <div class="w-[4.5rem] h-[4.5rem] bg-white rounded-2xl border border-blue-200 flex items-center justify-center shadow-sm group-hover:bg-blue-600 group-hover:border-blue-600 group-hover:shadow-lg group-hover:-translate-y-1 transition-all duration-300 ease-out">
                        <svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                        </svg>
                    </div>
                    <span class="mt-3 text-sm font-medium text-slate-600 group-hover:text-blue-700 transition-colors px-1 leading-tight">
                        Construtor de<br>Indicadores
                    </span>
                </a>


                <a href="/indicadores/visualizar" class="group flex flex-col items-center text-center">
                    <div class="w-[4.5rem] h-[4.5rem] bg-white rounded-2xl border border-blue-200 flex items-center justify-center shadow-sm group-hover:bg-blue-600 group-hover:border-blue-600 group-hover:shadow-lg group-hover:-translate-y-1 transition-all duration-300 ease-out">
                        <svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                    </div>
                    <span class="mt-3 text-sm font-medium text-slate-600 group-hover:text-blue-700 transition-colors px-1 leading-tight">
                        Visualizar<br>Indicadores
                    </span>
                </a>

            </div>
        </div>

    </div>
</div>