<%
function capitalizeName(texto) {
    if (!texto) return 'Usuário';
    const str = String(texto);
    return str.toLowerCase().split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
}
const u = (typeof user !== 'undefined' && user) ? user : {};
const nomeParaMostrar = u.name || u.nome || u.username || u.nm_usuario || u.login || 'Visitante';
const isAdmin = u.cd_perfil_inicial === 3 || u.grupo_id === 1 || (String(u.nm_usuario || '').toLowerCase() === 'pedrosantos');
%>
<div class="min-h-0 bg-gradient-to-b from-slate-50 to-slate-100/80">
    <div class="max-w-[90rem] mx-auto px-4 sm:px-6 lg:px-8 py-3 lg:py-4">
        <!-- Hero / Boas-vindas -->
        <header class="mb-3 rounded-xl border border-slate-200/80 shadow-md bg-gradient-to-r from-indigo-600 via-blue-600 to-indigo-700 text-white p-4 glass-panel">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                <div class="space-y-0.5">
                    <p class="text-xs font-medium text-indigo-200 uppercase tracking-wider">DataCare</p>
                    <h1 class="text-lg sm:text-xl font-bold tracking-tight">
                        Olá, <span class="text-white"><%= capitalizeName(nomeParaMostrar) %></span>
                    </h1>
                    <p class="text-xs text-indigo-100">Selecione uma opção abaixo para começar</p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="px-3 py-1 rounded-lg bg-white/10 text-xs font-medium">
                        <i class="fas fa-circle text-emerald-400 mr-1.5 text-[10px]"></i>Online
                    </span>
                    <time class="text-xs text-indigo-100"><%= new Date().toLocaleDateString('pt-BR', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' }) %></time>
                </div>
            </div>
        </header>

        <!-- Administrador (apenas para admins) -->
        <% if (isAdmin) { %>
        <section class="mb-3">
            <div class="flex items-center gap-2 mb-2">
                <div class="w-12 h-12 rounded-xl bg-slate-800 text-white flex items-center justify-center shrink-0">
                    <i class="fas fa-user-shield text-xl"></i>
                </div>
                <div>
                    <h2 class="text-base font-bold text-slate-800">Administrador</h2>
                    <p class="text-xs text-slate-500">Cadastro de pessoas, usuários, grupos e liberação de módulos</p>
                </div>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-2">
                <a href="/pessoas" class="group flex flex-col items-center p-3 rounded-xl bg-white border border-slate-200 shadow-sm glass-card hover:border-slate-400 hover:shadow-md transition-all duration-200">
                    <div class="w-12 h-12 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-colors shrink-0">
                        <i class="fas fa-user-friends text-xl"></i>
                    </div>
                    <span class="mt-2 font-medium text-slate-800 text-center text-sm block">Cadastrar Pessoas</span>
                </a>
                <a href="/pessoas/novo" class="group flex flex-col items-center p-3 rounded-xl bg-white border border-slate-200 shadow-sm glass-card hover:border-slate-400 hover:shadow-md transition-all duration-200">
                    <div class="w-12 h-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center group-hover:bg-emerald-600 group-hover:text-white transition-colors shrink-0">
                        <i class="fas fa-user-plus text-xl"></i>
                    </div>
                    <span class="mt-2 font-medium text-slate-800 text-center text-sm block">Criar Usuários</span>
                </a>
                <a href="/admin" class="group flex flex-col items-center p-3 rounded-xl bg-white border border-slate-200 shadow-sm glass-card hover:border-slate-400 hover:shadow-md transition-all duration-200">
                    <div class="w-12 h-12 rounded-xl bg-slate-100 text-slate-600 flex items-center justify-center group-hover:bg-slate-700 group-hover:text-white transition-colors shrink-0">
                        <i class="fas fa-users-cog text-xl"></i>
                    </div>
                    <span class="mt-2 font-medium text-slate-800 text-center text-sm block">Painel Admin</span>
                </a>
                <a href="/permissoes" class="group flex flex-col items-center p-3 rounded-xl bg-white border border-slate-200 shadow-sm glass-card hover:border-slate-400 hover:shadow-md transition-all duration-200">
                    <div class="w-12 h-12 rounded-xl bg-slate-100 text-slate-600 flex items-center justify-center group-hover:bg-slate-700 group-hover:text-white transition-colors shrink-0">
                        <i class="fas fa-shield-alt text-xl"></i>
                    </div>
                    <span class="mt-2 font-medium text-slate-800 text-center text-sm block">Permissões</span>
                </a>
            </div>
        </section>
        <% } %>

        <!-- Analytics -->
        <section class="mb-3">
            <div class="flex items-center gap-2 mb-2">
                <div class="w-12 h-12 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center shrink-0">
                    <i class="fas fa-chart-line text-xl"></i>
                </div>
                <div>
                    <h2 class="text-base font-bold text-slate-800">Analytics (BI)</h2>
                    <p class="text-xs text-slate-500">Dashboards e Business Intelligence</p>
                </div>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
                <a href="/indicadores/visualizar" class="group flex flex-col items-center p-3 rounded-xl bg-white border border-slate-200 shadow-sm glass-card hover:border-blue-300 hover:shadow-md transition-all duration-200">
                    <div class="w-12 h-12 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-colors shrink-0">
                        <i class="fas fa-chart-pie text-xl"></i>
                    </div>
                    <span class="mt-2 font-medium text-slate-800 text-center text-sm block">Visualizar Indicadores</span>
                </a>
                <a href="/analytics" class="group flex flex-col items-center p-3 rounded-xl bg-white border border-slate-200 shadow-sm glass-card hover:border-blue-300 hover:shadow-md transition-all duration-200">
                    <div class="w-12 h-12 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center group-hover:bg-indigo-600 group-hover:text-white transition-colors shrink-0">
                        <i class="fas fa-robot text-xl"></i>
                    </div>
                    <span class="mt-2 font-medium text-slate-800 text-center text-sm block">Construtor IA</span>
                </a>
            </div>
        </section>

        <!-- Atendimento -->
        <section class="mb-3">
            <div class="flex items-center gap-2 mb-2">
                <div class="w-12 h-12 rounded-xl bg-teal-100 text-teal-600 flex items-center justify-center shrink-0">
                    <i class="fas fa-headset text-xl"></i>
                </div>
                <div>
                    <h2 class="text-base font-bold text-slate-800">Atendimento</h2>
                    <p class="text-xs text-slate-500">Abertura Zero Toque e atendimento</p>
                </div>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
                <a href="/smart" class="group flex flex-col items-center p-3 rounded-xl bg-white border border-slate-200 shadow-sm glass-card hover:border-teal-300 hover:shadow-md transition-all duration-200">
                    <div class="w-12 h-12 rounded-xl bg-teal-50 text-teal-600 flex items-center justify-center group-hover:bg-teal-600 group-hover:text-white transition-colors shrink-0">
                        <i class="fas fa-file-medical text-xl"></i>
                    </div>
                    <span class="mt-2 font-medium text-slate-800 text-center text-sm block">Smart</span>
                </a>
            </div>
        </section>

        <!-- Connect -->
        <section class="mb-3">
            <div class="flex items-center gap-2 mb-2">
                <div class="w-12 h-12 rounded-xl bg-emerald-100 text-emerald-600 flex items-center justify-center shrink-0">
                    <i class="fas fa-comments text-xl"></i>
                </div>
                <div>
                    <h2 class="text-base font-bold text-slate-800">Connect</h2>
                    <p class="text-xs text-slate-500">Chat e comunicação</p>
                </div>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
                <a href="/chat" class="group flex flex-col items-center p-3 rounded-xl bg-white border border-slate-200 shadow-sm glass-card hover:border-emerald-300 hover:shadow-md transition-all duration-200">
                    <div class="w-12 h-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center group-hover:bg-emerald-600 group-hover:text-white transition-colors shrink-0">
                        <i class="fas fa-comments text-xl"></i>
                    </div>
                    <span class="mt-2 font-medium text-slate-800 text-center text-sm block">Chat</span>
                </a>
            </div>
        </section>

        <!-- Quality -->
        <section class="mb-3">
            <div class="flex items-center gap-2 mb-2">
                <div class="w-12 h-12 rounded-xl bg-amber-100 text-amber-600 flex items-center justify-center shrink-0">
                    <i class="fas fa-award text-xl"></i>
                </div>
                <div>
                    <h2 class="text-base font-bold text-slate-800">Quality</h2>
                    <p class="text-xs text-slate-500">Qualidade e indicadores assistenciais</p>
                </div>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
                <div class="flex flex-col items-center p-3 rounded-xl bg-slate-50 border-2 border-dashed border-slate-200 text-slate-400">
                    <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center shrink-0">
                        <i class="fas fa-hourglass-half text-xl"></i>
                    </div>
                    <span class="mt-2 font-medium text-slate-500 text-center text-sm block">Em breve</span>
                </div>
            </div>
        </section>

        <!-- Staff -->
        <section class="mb-3">
            <div class="flex items-center gap-2 mb-2">
                <div class="w-12 h-12 rounded-xl bg-violet-100 text-violet-600 flex items-center justify-center shrink-0">
                    <i class="fas fa-users-cog text-xl"></i>
                </div>
                <div>
                    <h2 class="text-base font-bold text-slate-800">Staff</h2>
                    <p class="text-xs text-slate-500">Escalas e equipes</p>
                </div>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
                <a href="/consultorios" class="group flex flex-col items-center p-3 rounded-xl bg-white border border-slate-200 shadow-sm glass-card hover:border-violet-300 hover:shadow-md transition-all duration-200">
                    <div class="w-12 h-12 rounded-xl bg-violet-50 text-violet-600 flex items-center justify-center group-hover:bg-violet-600 group-hover:text-white transition-colors shrink-0">
                        <i class="fas fa-stethoscope text-xl"></i>
                    </div>
                    <span class="mt-2 font-medium text-slate-800 text-center text-sm block">Consultórios</span>
                </a>
                <a href="/staff/escalas" class="group flex flex-col items-center p-3 rounded-xl bg-white border border-slate-200 shadow-sm glass-card hover:border-violet-300 hover:shadow-md transition-all duration-200">
                    <div class="w-12 h-12 rounded-xl bg-violet-50 text-violet-600 flex items-center justify-center group-hover:bg-violet-600 group-hover:text-white transition-colors shrink-0">
                        <i class="fas fa-calendar-alt text-xl"></i>
                    </div>
                    <span class="mt-2 font-medium text-slate-800 text-center text-sm block">Escalas</span>
                </a>
            </div>
        </section>

    </div>
</div>
