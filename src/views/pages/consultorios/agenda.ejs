<script>
// Variável para armazenar a data atual selecionada
let dataAtual = new Date();
let filtroStatusAtual = 'todos';
let consultasCache = [];

// Função para formatar data
function formatarData(data) {
    return data.toLocaleDateString('pt-BR', { 
        day: '2-digit', 
        month: 'long', 
        year: 'numeric' 
    });
}

function formatarDiaSemana(data) {
    return data.toLocaleDateString('pt-BR', { weekday: 'long' });
}

function formatarDataISO(data) {
    return data.toISOString().split('T')[0];
}

// Função para buscar consultas do banco
async function buscarConsultas() {
    try {
        const dataISO = formatarDataISO(dataAtual);
        const response = await fetch(`/api/consultorios/agenda/consultas?data=${dataISO}&status=${filtroStatusAtual}`);
        const resultado = await response.json();

        if (resultado.success) {
            consultasCache = resultado.data;
            renderizarConsultas(resultado.data);
            atualizarEstatisticas(resultado.estatisticas);
        } else {
            console.error('Erro ao buscar consultas:', resultado.error);
            mostrarEstadoVazio();
        }
    } catch (error) {
        console.error('Erro ao buscar consultas:', error);
        mostrarEstadoVazio();
    }
}

// Função para renderizar consultas
function renderizarConsultas(consultas) {
    const container = document.getElementById('listaConsultas');
    
    if (consultas.length === 0) {
        mostrarEstadoVazio();
        return;
    }

    // Remove o estado vazio se existir
    const estadoVazio = document.getElementById('estadoVazio');
    if (estadoVazio) {
        estadoVazio.classList.add('hidden');
    }

    // Mapeia status para badges
    const getBadgeStatus = (status) => {
        const badges = {
            'A': { cor: 'emerald', texto: 'Agendado' },
            'E': { cor: 'amber', texto: 'Em Atendimento' },
            'C': { cor: 'blue', texto: 'Concluído' },
            'G': { cor: 'slate', texto: 'Aguardando' },
            'X': { cor: 'red', texto: 'Cancelado' }
        };
        return badges[status] || { cor: 'slate', texto: status };
    };

    // Gera HTML das consultas
    const html = consultas.map(consulta => {
        const badge = getBadgeStatus(consulta.status);
        return `
            <div class="bg-white rounded-xl border border-slate-200/80 shadow-sm hover:shadow-md transition-all duration-200">
                <div class="p-6">
                    <div class="flex flex-col lg:flex-row lg:items-center gap-6">
                        
                        <!-- Horário -->
                        <div class="flex items-center gap-4">
                            <div class="text-center">
                                <div class="text-2xl font-bold text-blue-600">${consulta.horario || 'N/A'}</div>
                                <div class="text-xs text-slate-500">30 min</div>
                            </div>
                            <div class="h-14 w-px bg-slate-200"></div>
                        </div>

                        <!-- Info do Paciente -->
                        <div class="flex-1">
                            <div class="flex items-start justify-between gap-4 mb-3">
                                <div>
                                    <h3 class="text-lg font-bold text-slate-800 mb-1">${consulta.paciente.nome}</h3>
                                    <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500">
                                        <span class="flex items-center gap-1">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                            Prontuário #${consulta.cd_agenda || consulta.id_agenda}
                                        </span>
                                    </div>
                                </div>
                                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-${badge.cor}-50 text-${badge.cor}-700 border border-${badge.cor}-100 text-sm font-medium">
                                    <span class="w-2 h-2 rounded-full bg-${badge.cor}-500"></span>
                                    ${badge.texto}
                                </span>
                            </div>
                            
                            <div class="flex flex-wrap items-center gap-4 text-sm">
                                <span class="inline-flex items-center gap-1.5 text-slate-600">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                    ${consulta.convenio || 'Não informado'}
                                </span>
                            </div>
                        </div>

                        <!-- Ações -->
                        <div class="flex lg:flex-col gap-2">
                            <a href="/consultorios/prontuario?cd_pessoa_fisica=${consulta.paciente.cd_pessoa_fisica || ''}&cd_agenda=${consulta.cd_agenda || ''}" class="flex-1 lg:flex-initial inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-medium transition-colors text-sm">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                Ver Prontuário
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        `;
    }).join('');

    // Mantém o mock no início e adiciona as consultas reais
    const mockCard = container.children[0];
    container.innerHTML = html;
}

// Função para mostrar estado vazio
function mostrarEstadoVazio() {
    const container = document.getElementById('listaConsultas');
    container.innerHTML = `
        <div class="bg-white rounded-xl border border-slate-200/80 shadow-sm p-12 text-center">
            <div class="flex flex-col items-center justify-center">
                <div class="flex items-center justify-center w-20 h-20 rounded-full bg-slate-100 text-slate-400 mb-4">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                </div>
                <h3 class="text-lg font-bold text-slate-800 mb-2">Nenhuma consulta agendada</h3>
