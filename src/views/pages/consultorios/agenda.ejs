// Função para atualizar estatísticas
function atualizarEstatisticas(stats) {
    if (stats) {
        document.getElementById('totalAgendadas').textContent = stats.total || 0;
        document.getElementById('emAtendimento').textContent = stats.em_atendimento || 0;
        document.getElementById('concluidas').textContent = stats.concluidas || 0;
        document.getElementById('aguardando').textContent = stats.aguardando || 0;
    }
}

// Função para atualizar a exibição da data
function atualizarData() {
    document.getElementById('dataAtual').textContent = formatarData(dataAtual);
    document.getElementById('diaSemana').textContent = formatarDiaSemana(dataAtual);
    buscarConsultas();
}

// Função para ver detalhes
function verDetalhes(idAgenda) {
    window.location.href = `/consultorios/atendimento/${idAgenda}`;
}

// Navegação de datas
document.getElementById('btnDiaAnterior')?.addEventListener('click', () => {
    dataAtual.setDate(dataAtual.getDate() - 1);
    atualizarData();
});

document.getElementById('btnProximoDia')?.addEventListener('click', () => {
    dataAtual.setDate(dataAtual.getDate() + 1);
    atualizarData();
});

document.getElementById('btnHoje')?.addEventListener('click', () => {
    dataAtual = new Date();
    atualizarData();
});

// Filtros
document.getElementById('filtroStatus')?.addEventListener('change', (e) => {
    filtroStatusAtual = e.target.value;
    buscarConsultas();
});

document.getElementById('buscarPaciente')?.addEventListener('input', (e) => {
    const termo = e.target.value.toLowerCase();
    if (termo === '') {
        renderizarConsultas(consultasCache);
    } else {
        const filtradas = consultasCache.filter(c => 
            c.paciente.nome.toLowerCase().includes(termo)
        );
        renderizarConsultas(filtradas);
    }
});

// Toggle de visualização
document.getElementById('btnVistaLista')?.addEventListener('click', function() {
    this.classList.add('bg-blue-100', 'text-blue-600');
    this.classList.remove('bg-slate-100', 'text-slate-600');
    document.getElementById('btnVistaGrade').classList.remove('bg-blue-100', 'text-blue-600');
    document.getElementById('btnVistaGrade').classList.add('bg-slate-100', 'text-slate-600');
});

document.getElementById('btnVistaGrade')?.addEventListener('click', function() {
    this.classList.add('bg-blue-100', 'text-blue-600');
    this.classList.remove('bg-slate-100', 'text-slate-600');
    document.getElementById('btnVistaLista').classList.remove('bg-blue-100', 'text-blue-600');
    document.getElementById('btnVistaLista').classList.add('bg-slate-100', 'text-slate-600');
});

// Botão Nova Consulta
document.getElementById('btnNovaConsulta')?.addEventListener('click', () => {
    alert('Funcionalidade de agendamento será implementada em breve!');
});

// Inicializar ao carregar a página
document.addEventListener('DOMContentLoaded', () => {
    buscarConsultas();
});
</script>
