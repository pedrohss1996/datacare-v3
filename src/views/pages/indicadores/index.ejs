<div class="w-full p-6 bg-gray-100 min-h-screen">
    <h1 class="text-3xl font-bold text-gray-800 mb-8">Dashboard Executivo</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% indicadores.forEach(ind => { %>
            <div class="bg-white p-4 rounded-xl shadow-lg border border-gray-100 h-96 flex flex-col">
                <h3 class="text-lg font-bold text-gray-700 mb-2"><%= ind.titulo %></h3>
                <div id="grafico-<%= ind.id %>" data-id="<%= ind.id %>" class="flex-1 w-full">
                    <p class="text-gray-400 text-sm mt-10 text-center">Carregando...</p>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('[id^="grafico-"]').forEach(el => {
            carregarGrafico(el.dataset.id, el.id);
        });
    });

    async function carregarGrafico(id, elementId) {
        try {
            const res = await fetch(`/api/indicadores/${id}/dados`);
            const dados = await res.json();
            
            const options = {
                chart: { type: dados.tipo || 'bar', height: '100%' },
                series: dados.series,
                labels: dados.labels,
                colors: ['#3b82f6', '#10b981', '#f59e0b']
            };
            
            document.getElementById(elementId).innerHTML = ''; // Limpa loading
            new ApexCharts(document.querySelector(`#${elementId}`), options).render();
        } catch (e) {
            console.error(e);
        }
    }
</script>