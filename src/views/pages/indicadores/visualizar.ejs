<style>
    /* Transições suaves */
    .card-hover { transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); }
    .card-hover:hover { transform: translateY(-4px); box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.1), 0 8px 8px -6px rgba(0, 0, 0, 0.05); }
    
    .fade-in { animation: fadeIn 0.3s ease-in-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div id="loadingOverlay" class="fixed inset-0 z-[100] bg-white/80 backdrop-blur-sm hidden flex-col justify-center items-center transition-all duration-300">
    <div class="relative">
        <div class="w-12 h-12 rounded-full border-4 border-slate-200"></div>
        <div class="w-12 h-12 rounded-full border-4 border-indigo-600 border-t-transparent animate-spin absolute top-0 left-0"></div>
    </div>
    <span class="mt-4 font-semibold text-slate-600 text-sm tracking-widest uppercase">Processando...</span>
</div>

<div class="w-full max-w-[1600px] mx-auto p-6 lg:p-10 min-h-[calc(100vh-80px)]">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-6">
        <div>
            <h1 class="text-3xl font-bold text-slate-900 tracking-tight flex items-center gap-3">
                <div class="p-2 bg-indigo-600 text-white rounded-lg shadow-sm shadow-indigo-200">
                    <i class="fa-solid fa-chart-pie text-lg"></i>
                </div>
                Central de Indicadores
            </h1>
            <p class="text-slate-500 text-sm mt-2 ml-1">
                Selecione uma área abaixo para visualizar as métricas de performance (KPIs).
            </p>
        </div>

        <div class="flex items-center gap-3 w-full md:w-auto">
            <div class="relative w-full md:w-72 group">
                <i class="fa-solid fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-600 transition-colors"></i>
                <input type="text" id="searchInput" placeholder="Filtrar indicadores..." 
                       class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-200 bg-white text-sm text-slate-700 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all shadow-sm">
            </div>
            
            <% if (user && user.grupo_id === 1) { %> 
                <a href="/indicadores/gerenciar" class="flex items-center gap-2 p-2.5 bg-slate-800 text-white border border-slate-700 hover:bg-slate-700 rounded-xl transition-all shadow-sm text-sm font-medium" title="Gerenciar Indicadores">
                    <i class="fa-solid fa-cog"></i>
                    <span class="hidden md:inline">Administrar</span>
                </a>
            <% } %>
        </div>
    </div>

    <% if (typeof aviso !== 'undefined' && aviso) { %>
        <div class="mb-8 p-4 bg-amber-50 border border-amber-200 rounded-xl flex items-center gap-3 text-amber-800">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span class="text-sm font-medium"><%= aviso %></span>
        </div>
    <% } %>

    <main class="relative">

        <div id="viewGroups" class="fade-in">
            <div class="flex items-center gap-2 mb-6">
                <span class="px-3 py-1 bg-indigo-50 text-indigo-700 rounded-full text-xs font-bold uppercase tracking-wider border border-indigo-100">
                    Áreas de Negócio Disponíveis
                </span>
            </div>
            
            <% if (pastas && pastas.length > 0) { %>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                    <% pastas.forEach(pasta => { %>
                        <div onclick="openFolder('<%= pasta.id %>', '<%= pasta.nome %>')" 
                             class="card-hover bg-white border border-slate-200 rounded-2xl p-6 cursor-pointer relative overflow-hidden group">
                            
                            <div class="absolute top-0 left-0 w-full h-1.5" style="background-color: <%= pasta.cor_hex || '#6366f1' %>;"></div>

                            <div class="flex justify-between items-start mb-4 mt-2">
                                <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl transition-colors bg-slate-50 text-slate-400 group-hover:text-white"
                                     style="background-color: transparent;"
                                     onmouseover="this.style.backgroundColor='<%= pasta.cor_hex || '#6366f1' %>'"
                                     onmouseout="this.style.backgroundColor='transparent'">
                                    <i class="<%= pasta.icone || 'fa-solid fa-folder' %>"></i>
                                </div>
                                
                                <div class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-300 group-hover:text-indigo-600 transition-colors">
                                    <i class="fa-solid fa-chevron-right text-xs"></i>
                                </div>
                            </div>

                            <h3 class="font-bold text-slate-800 text-lg mb-1 group-hover:text-indigo-600 transition-colors">
                                <%= pasta.nome %>
                            </h3>
                            <p class="text-sm text-slate-500 line-clamp-2 min-h-[2.5em]">
                                <%= pasta.descricao || 'Clique para visualizar os indicadores desta pasta.' %>
                            </p>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-20 bg-white rounded-2xl border border-dashed border-slate-200">
                    <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 text-slate-300 text-2xl">
                        <i class="fa-regular fa-folder-open"></i>
                    </div>
                    <h3 class="text-lg font-medium text-slate-900">Nenhuma pasta disponível</h3>
                    <p class="text-slate-500 text-sm mt-1">Seu grupo de acesso não possui permissões ou não há pastas cadastradas.</p>
                </div>
            <% } %>
        </div>

        <div id="viewList" class="hidden fade-in">
            <div class="flex items-center justify-between mb-8 pb-6 border-b border-slate-100">
                <div class="flex items-center gap-4">
                    <button onclick="showGroups()" class="group flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-600 bg-white border border-slate-200 rounded-lg hover:border-indigo-300 hover:text-indigo-600 transition-all shadow-sm">
                        <i class="fa-solid fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                        Voltar
                    </button>
                    <div>
                        <h2 id="folderTitle" class="text-2xl font-bold text-slate-900"></h2>
                        <span class="text-xs text-slate-400 font-medium uppercase tracking-wide">Pasta de Indicadores</span>
                    </div>
                </div>
            </div>

            <div id="indicatorsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"></div>
        </div>

        <div id="viewChart" class="hidden fade-in">
            <div class="flex justify-between items-center mb-6">
                <button onclick="backToFolder()" class="flex items-center gap-2 text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors group">
                    <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center group-hover:bg-indigo-50 transition-colors">
                        <i class="fa-solid fa-chevron-left"></i>
                    </div>
                    Voltar para lista
                </button>
                
                <div class="flex gap-2">
                    <button onclick="window.print()" class="text-slate-400 hover:text-slate-600 p-2" title="Imprimir">
                        <i class="fa-solid fa-print"></i>
                    </button>
                </div>
            </div>

            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden flex flex-col min-h-[600px]">
                <div class="px-8 py-6 border-b border-slate-100 bg-slate-50/50 flex justify-between items-start">
                    <div>
                        <div class="flex items-center gap-3 mb-2">
                            <span class="p-2 bg-indigo-100 text-indigo-700 rounded-lg text-sm">
                                <i class="fa-solid fa-chart-simple"></i>
                            </span>
                            <h3 id="chartTitle" class="text-2xl font-bold text-slate-900 tracking-tight"></h3>
                        </div>
                        <div class="flex items-center gap-4 text-sm text-slate-500 ml-1">
                            <span class="flex items-center gap-1.5">
                                <i class="fa-regular fa-user-circle"></i>
                                <span id="chartResp">Responsável</span>
                            </span>
                            <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                            <span class="text-slate-400">Atualizado em tempo real</span>
                        </div>
                    </div>
                </div>

                <div class="flex-grow p-6 relative w-full bg-white flex items-center justify-center">
                    <div class="w-full h-full min-h-[450px] relative">
                        <canvas id="mainCanvas"></canvas>
                    </div>
                </div>
            </div>
        </div>

    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>

<script>
    // --- CONFIGURAÇÕES GLOBAIS ---
    Chart.defaults.font.family = "'Inter', sans-serif";
    Chart.defaults.color = '#64748b';
    Chart.register(ChartDataLabels);

    let currentChart = null;
    let currentFolderId = null;

    // Utilitário de Loading
    const loading = (show) => {
        const el = document.getElementById('loadingOverlay');
        if(show) {
            el.classList.remove('hidden');
            el.classList.add('flex');
        } else {
            el.classList.add('hidden');
            el.classList.remove('flex');
        }
    };

    // --- NAVEGAÇÃO ---

    // 1. Abrir Pasta
    async function openFolder(id, name) {
        loading(true);
        currentFolderId = id;

        try {
            const response = await fetch(`/indicadores/api/pasta/${id}`);
            if(!response.ok) throw new Error('Erro ao carregar indicadores');
            
            const indicadores = await response.json();
            renderIndicators(name, indicadores);
            
            document.getElementById('viewGroups').classList.add('hidden');
            document.getElementById('viewList').classList.remove('hidden');
            document.getElementById('viewChart').classList.add('hidden');
            
        } catch (error) {
            console.error(error);
            alert('Não foi possível abrir esta pasta. Tente novamente.');
        } finally {
            loading(false);
        }
    }

    // 2. Voltar para Home
    function showGroups() {
        document.getElementById('viewGroups').classList.remove('hidden');
        document.getElementById('viewList').classList.add('hidden');
        document.getElementById('viewChart').classList.add('hidden');
        document.getElementById('searchInput').value = '';
        filterItems('');
    }

    // 3. Voltar para Pasta
    function backToFolder() {
        document.getElementById('viewGroups').classList.add('hidden');
        document.getElementById('viewList').classList.remove('hidden');
        document.getElementById('viewChart').classList.add('hidden');
    }

    // --- RENDERIZAÇÃO ---
    function renderIndicators(folderName, list) {
        document.getElementById('folderTitle').innerText = folderName;
        const grid = document.getElementById('indicatorsGrid');
        
        if(list.length === 0) {
            grid.innerHTML = `
                <div class="col-span-full text-center py-12 bg-slate-50 rounded-xl border border-dashed border-slate-200">
                    <p class="text-slate-500">Nenhum indicador cadastrado nesta pasta.</p>
                </div>`;
            return;
        }

        grid.innerHTML = list.map(ind => `
            <div onclick="openChart('${ind.id}')" 
                 class="search-item bg-white border border-slate-200 rounded-xl p-6 hover:shadow-lg hover:-translate-y-1 transition-all cursor-pointer group flex flex-col justify-between h-full min-h-[180px]">
                
                <div>
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-10 h-10 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center text-lg group-hover:bg-indigo-600 group-hover:text-white transition-colors">
                            <i class="fa-solid fa-chart-column"></i>
                        </div>
                        <span class="bg-green-50 text-green-700 text-[10px] font-bold uppercase px-2 py-1 rounded border border-green-100">Ativo</span>
                    </div>

                    <h4 class="font-bold text-slate-800 text-lg leading-tight mb-2 group-hover:text-indigo-600 transition-colors">
                        ${ind.titulo}
                    </h4>
                    <p class="text-xs text-slate-500 line-clamp-2">
                        ${ind.descricao || 'Clique para visualizar a análise gráfica.'}
                    </p>
                </div>

                <div class="mt-4 pt-4 border-t border-slate-100 flex items-center justify-between">
                    <span class="text-[10px] text-slate-400 font-mono uppercase">ID: ${ind.id}</span>
                    <i class="fa-solid fa-arrow-right text-slate-300 group-hover:text-indigo-600 transition-colors"></i>
                </div>
            </div>
        `).join('');
    }

    // 4. Abrir Gráfico
    async function openChart(indId) {
        loading(true);
        try {
            const response = await fetch(`/indicadores/api/dados/${indId}`);
            if(!response.ok) throw new Error('Erro ao buscar dados');

            const payload = await response.json();
            renderChartCanvas(payload);

            document.getElementById('viewList').classList.add('hidden');
            document.getElementById('viewChart').classList.remove('hidden');

        } catch (error) {
            console.error(error);
            alert('Erro ao carregar dados do gráfico.');
        } finally {
            loading(false);
        }
    }

    function renderChartCanvas(payload) {
        document.getElementById('chartTitle').innerText = payload.config.titulo;
        document.getElementById('chartResp').innerText = payload.config.responsavel || 'Equipe Geral';

        if(currentChart) currentChart.destroy();

        const ctx = document.getElementById('mainCanvas').getContext('2d');
        const labels = payload.data.map(d => d.x);
        const values = payload.data.map(d => d.y);
        
        const gradient = ctx.createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(79, 70, 229, 0.8)'); 
        gradient.addColorStop(1, 'rgba(79, 70, 229, 0.1)');

        currentChart = new Chart(ctx, {
            type: payload.config.tipo || 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: payload.config.titulo,
                    data: values,
                    backgroundColor: payload.config.tipo === 'line' ? 'transparent' : gradient,
                    borderColor: '#4f46e5',
                    borderWidth: 2,
                    borderRadius: 6,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#4f46e5',
                    pointRadius: 5,
                    pointHoverRadius: 7,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    datalabels: {
                        anchor: 'end', align: 'top', color: '#64748b', font: { weight: 'bold' },
                        formatter: (val) => val
                    },
                    tooltip: {
                        backgroundColor: '#1e293b', padding: 12, titleFont: { size: 13 }, bodyFont: { size: 13 }, displayColors: false
                    }
                },
                scales: {
                    y: { beginAtZero: true, grid: { borderDash: [4, 4], color: '#f1f5f9' }, border: { display: false } },
                    x: { grid: { display: false } }
                }
            }
        });
    }

    // --- BUSCA ---
    document.getElementById('searchInput').addEventListener('input', (e) => {
        filterItems(e.target.value.toLowerCase());
    });

    function filterItems(term) {
        if(!document.getElementById('viewGroups').classList.contains('hidden')) {
            const items = document.querySelectorAll('#viewGroups .card-hover');
            items.forEach(el => {
                const text = el.innerText.toLowerCase();
                el.style.display = text.includes(term) ? 'block' : 'none';
            });
        }
        else if(!document.getElementById('viewList').classList.contains('hidden')) {
            const items = document.querySelectorAll('.search-item');
            items.forEach(el => {
                const text = el.innerText.toLowerCase();
                el.style.display = text.includes(term) ? 'flex' : 'none';
            });
        }
    }
</script>