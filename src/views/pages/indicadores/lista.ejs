<div class="min-h-screen bg-gray-50 py-10">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center mb-10 gap-4">
            
            <div>
                <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">
                    Central de Indicadores
                </h1>
                <p class="mt-2 text-sm text-gray-500">
                    Gerencie e visualize métricas estratégicas em tempo real.
                </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-3 w-full lg:w-auto">
                
                <div class="relative w-full sm:w-64 group">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-gray-400 group-focus-within:text-indigo-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                    <input 
                        type="text" 
                        id="searchIndicator" 
                        onkeyup="filterIndicators()"
                        class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg leading-5 bg-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm shadow-sm transition-shadow duration-200" 
                        placeholder="Buscar..."
                    >
                </div>

                <a href="/indicadores/novo" class="inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors whitespace-nowrap">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    Novo Indicador
                </a>
            </div>
        </div>

        <div id="indicatorsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            
            <% if (!indicadores || indicadores.length === 0) { %>
                <div class="col-span-full flex flex-col items-center justify-center py-20 bg-white rounded-3xl shadow-sm border border-dashed border-gray-300">
                    <svg class="h-12 w-12 text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <p class="text-gray-500 font-medium">Nenhum indicador configurado.</p>
                </div>
            <% } %>

            <% indicadores.forEach(function(item) { 
                let iconColor = "text-blue-600";
                let bgIcon = "bg-blue-100";
                let iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />';
                
                if (item.slug.includes('fatur') || item.slug.includes('financeiro')) {
                    iconColor = "text-emerald-600";
                    bgIcon = "bg-emerald-100";
                    iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />';
                } else if (item.slug.includes('pessoa') || item.slug.includes('paciente')) {
                    iconColor = "text-purple-600";
                    bgIcon = "bg-purple-100";
                    iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />';
                }
            %>
            
            <div class="indicator-card group relative bg-white rounded-2xl shadow-sm hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 border border-gray-100 overflow-hidden">
                
                <div class="absolute top-0 left-0 w-full h-1 <%= bgIcon.replace('bg-', 'bg-gradient-to-r from-white to-') %>"></div>

                <div class="p-6">
                    <div class="flex items-start justify-between mb-4">
                        <div class="p-3 rounded-xl <%= bgIcon %> <%= iconColor %>">
                            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <%- iconSvg %>
                            </svg>
                        </div>
                        
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                            Ativo
                        </span>
                    </div>

                    <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-indigo-600 transition-colors">
                        <%= item.titulo %>
                    </h3>
                    <p class="text-gray-500 text-sm mb-6 line-clamp-2 h-10">
                        <%= item.descricao || 'Visualize os dados detalhados desta métrica.' %>
                    </p>

                    <div class="pt-4 border-t border-gray-50 flex items-center justify-between">
                        <div class="text-xs text-gray-400 font-medium">
                            ID: <span class="font-mono"><%= item.slug %></span>
                        </div>
                        
                        <div class="flex space-x-2">
                            <a href="/indicadores/editar/<%= item.id %>" class="p-2 rounded-full text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors" title="Editar Configurações">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                            </a>

                            <% if (item.slug) { %>
                                <a href="/indicadores/<%= item.slug %>" class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-gray-50 text-gray-600 group-hover:bg-indigo-600 group-hover:text-white transition-all duration-300" title="Ver Dashboard">
                                    <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                    </svg>
                                </a>
                            <% } else { %>
                                <span class="text-xs text-red-400">Sem Link</span>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>

        <div id="noResults" class="hidden text-center py-20">
            <p class="text-gray-400 text-lg">Nenhum indicador encontrado para sua busca.</p>
        </div>

    </div>
</div>

<script>
    function filterIndicators() {
        const input = document.getElementById('searchIndicator');
        const filter = input.value.toLowerCase();
        const grid = document.getElementById('indicatorsGrid');
        const cards = grid.getElementsByClassName('indicator-card');
        let visibleCount = 0;

        for (let i = 0; i < cards.length; i++) {
            const title = cards[i].getElementsByTagName("h3")[0];
            const txtValue = title.textContent || title.innerText;
            
            if (txtValue.toLowerCase().indexOf(filter) > -1) {
                cards[i].style.display = ""; 
                visibleCount++;
            } else {
                cards[i].style.display = "none"; 
            }
        }

        const noResults = document.getElementById('noResults');
        if (visibleCount === 0) {
            noResults.classList.remove('hidden');
        } else {
            noResults.classList.add('hidden');
        }
    }
</script>