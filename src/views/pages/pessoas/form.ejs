<div class="min-h-screen bg-gradient-to-b from-slate-50 to-slate-100/80">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-10">
        
        <!-- Header -->
        <div class="mb-8">
            <div class="flex items-center gap-4 mb-4">
                <a href="/pessoas" class="flex items-center justify-center w-10 h-10 rounded-lg bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-800 transition-colors shadow-sm border border-slate-200">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                </a>
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-slate-800">
                        <%= modo === 'criar' ? 'Novo Usuário' : 'Editar Usuário' %>
                    </h1>
                    <p class="text-slate-500 mt-1">Preencha os dados abaixo</p>
                </div>
            </div>
        </div>

        <!-- Alertas -->
        <% if (erro) { %>
        <div class="bg-red-50 border border-red-200 text-red-800 px-6 py-4 rounded-xl flex items-center gap-3 shadow-sm mb-6">
            <svg class="w-5 h-5 text-red-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="font-medium"><%= erro %></span>
        </div>
        <% } %>

        <!-- Formulário -->
        <form action="<%= modo === 'criar' ? '/pessoas/cadastrar' : '/pessoas/atualizar/' + dados.cd_usuario %>" method="POST">
            
            <!-- Dados de Acesso -->
            <div class="bg-white rounded-xl border border-slate-200/80 shadow-sm p-6 mb-6">
                <div class="flex items-center gap-3 mb-6">
                    <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-blue-100 text-blue-600">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                        </svg>
                    </div>
                    <h2 class="text-lg font-bold text-slate-800">Dados de Acesso</h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">
                            Usuário (Login) <span class="text-red-500">*</span>
                        </label>
                        <input type="text" name="usuario" value="<%= dados.nm_usuario || '' %>" required
                               class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                               placeholder="nome.sobrenome">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">
                            Senha <%= modo === 'editar' ? '(deixe em branco para manter)' : '' %> <span class="text-red-500"><%= modo === 'criar' ? '*' : '' %></span>
                        </label>
                        <input type="password" name="senha" <%= modo === 'criar' ? 'required' : '' %>
                               class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                               placeholder="••••••••">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">
                            Perfil
                        </label>
                        <select name="perfil" 
                                class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                            <option value="1" <%= (dados.cd_perfil_inicial == 1 || !dados.cd_perfil_inicial) ? 'selected' : '' %>>Usuário</option>
                            <option value="2" <%= dados.cd_perfil_inicial == 2 ? 'selected' : '' %>>Médico</option>
                            <option value="3" <%= dados.cd_perfil_inicial == 3 ? 'selected' : '' %>>Administrador</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">
                            Situação
                        </label>
                        <select name="situacao" 
                                class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                            <option value="A" <%= (dados.ie_situacao === 'A' || !dados.ie_situacao) ? 'selected' : '' %>>Ativo</option>
                            <option value="I" <%= dados.ie_situacao === 'I' ? 'selected' : '' %>>Inativo</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">
                            Grupo
                        </label>
                        <select name="grupo_id" 
                                class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                            <% if (grupos && grupos.length) { %>
                            <% grupos.forEach(g => { %>
                            <option value="<%= g.id %>" <%= (dados.grupo_id || 2) == g.id ? 'selected' : '' %>><%= g.nome %></option>
                            <% }); %>
                            <% } else { %>
                            <option value="2">Usuário Padrão</option>
                            <option value="1">Administrador</option>
                            <% } %>
                        </select>
                        <p class="text-xs text-slate-500 mt-1">Define acesso aos módulos (Analytics, Connect, Quality, Staff)</p>
                    </div>
                </div>
            </div>

            <!-- Dados Pessoais -->
            <div class="bg-white rounded-xl border border-slate-200/80 shadow-sm p-6 mb-6">
                <div class="flex items-center gap-3 mb-6">
                    <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-emerald-100 text-emerald-600">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </div>
                    <h2 class="text-lg font-bold text-slate-800">Dados Pessoais</h2>
                </div>

                <div class="grid grid-cols-1 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">
                            Nome Completo <span class="text-red-500">*</span>
                        </label>
                        <input type="text" name="nome" value="<%= dados.nm_pessoa_fisica || dados.ds_usuario || '' %>" required
                               class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">
                                CPF
                            </label>
                            <input type="text" name="cpf" value="<%= dados.nr_cpf || dados.cpf_pessoa || '' %>"
                                   class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                                   placeholder="000.000.000-00" maxlength="14">
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2 flex items-center gap-2">
                                Código Médico (TASY)
                                <span class="text-xs text-slate-500 font-normal">• Para módulo Consultórios</span>
                            </label>
                            <input type="number" name="cd_medico_tasy" value="<%= dados.cd_medico_tasy || '' %>"
                                   class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                                   placeholder="Ex: 12345">
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">
                                RG
                            </label>
                            <input type="text" name="rg" value="<%= dados.nr_identidade || '' %>"
                                   class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">
                                Órgão Emissor
                            </label>
                            <input type="text" name="orgao_rg" value="<%= dados.ds_orgao_emissor_ci || '' %>"
                                   class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                                   placeholder="SSP">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">
                                Data de Nascimento
                            </label>
                            <input type="date" name="dt_nascimento" value="<%= dados.dt_nascimento ? new Date(dados.dt_nascimento).toISOString().split('T')[0] : '' %>"
                                   class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">
                                Sexo
                            </label>
                            <select name="sexo" 
                                    class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                                <option value="">Selecione</option>
                                <option value="M" <%= dados.ie_sexo === 'M' ? 'selected' : '' %>>Masculino</option>
                                <option value="F" <%= dados.ie_sexo === 'F' ? 'selected' : '' %>>Feminino</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contato -->
            <div class="bg-white rounded-xl border border-slate-200/80 shadow-sm p-6 mb-6">
                <div class="flex items-center gap-3 mb-6">
                    <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-purple-100 text-purple-600">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <h2 class="text-lg font-bold text-slate-800">Contato</h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">
                            Telefone/Celular
                        </label>
                        <input type="text" name="telefone" value="<%= dados.nr_telefone_celular || '' %>"
                               class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                               placeholder="(00) 00000-0000">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">
                            E-mail
                        </label>
                        <input type="email" name="email" value="<%= dados.ds_email || '' %>"
                               class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                               placeholder="email@exemplo.com">
                    </div>
                </div>
            </div>

            <!-- Endereço -->
            <div class="bg-white rounded-xl border border-slate-200/80 shadow-sm p-6 mb-6">
                <div class="flex items-center gap-3 mb-6">
                    <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-amber-100 text-amber-600">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <h2 class="text-lg font-bold text-slate-800">Endereço</h2>
                </div>

                <div class="grid grid-cols-1 gap-6">
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">
                                CEP
                            </label>
                            <input type="text" name="cep" value="<%= dados.cd_cep || '' %>"
                                   class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                                   placeholder="00000-000" maxlength="9">
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-slate-700 mb-2">
                                Endereço
                            </label>
                            <input type="text" name="endereco" value="<%= dados.ds_endereco || '' %>"
                                   class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">
                                Número
                            </label>
                            <input type="text" name="numero" value="<%= dados.nr_endereco || '' %>"
                                   class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">
                                Complemento
                            </label>
                            <input type="text" name="complemento" value="<%= dados.ds_complemento || '' %>"
                                   class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">
                                Bairro
                            </label>
                            <input type="text" name="bairro" value="<%= dados.ds_bairro || '' %>"
                                   class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">
                                Cidade
                            </label>
                            <input type="text" name="municipio" value="<%= dados.ds_municipio || '' %>"
                                   class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">
                                UF
                            </label>
                            <input type="text" name="uf" value="<%= dados.sg_estado || '' %>" maxlength="2"
                                   class="w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                                   placeholder="SP">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botões -->
            <div class="flex items-center justify-end gap-3">
                <a href="/pessoas" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium transition-colors">
                    Cancelar
                </a>
                <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-medium shadow-md hover:shadow-lg transition-all duration-200">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <%= modo === 'criar' ? 'Criar Usuário' : 'Salvar Alterações' %>
                </button>
            </div>

        </form>

    </div>
</div>

<script>
// Máscara de CPF
document.querySelector('input[name="cpf"]')?.addEventListener('input', function(e) {
    let value = e.target.value.replace(/\D/g, '');
    if (value.length <= 11) {
        value = value.replace(/(\d{3})(\d)/, '$1.$2');
        value = value.replace(/(\d{3})(\d)/, '$1.$2');
        value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
        e.target.value = value;
    }
});

// Máscara de CEP
document.querySelector('input[name="cep"]')?.addEventListener('input', function(e) {
    let value = e.target.value.replace(/\D/g, '');
    if (value.length <= 8) {
        value = value.replace(/(\d{5})(\d)/, '$1-$2');
        e.target.value = value;
    }
});

// Máscara de Telefone
document.querySelector('input[name="telefone"]')?.addEventListener('input', function(e) {
    let value = e.target.value.replace(/\D/g, '');
    if (value.length <= 11) {
        value = value.replace(/(\d{2})(\d)/, '($1) $2');
        value = value.replace(/(\d{5})(\d)/, '$1-$2');
        e.target.value = value;
    }
});
</script>
