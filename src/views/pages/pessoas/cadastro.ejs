<div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold mb-6 text-gray-800">Cadastro de Pessoa Física</h2>

    <div class="bg-white shadow px-4 py-5 sm:rounded-lg sm:p-6">
        <form action="/pessoas/cadastrar" method="POST">

            <% if (locals.erro) { %>
                <div class="alert alert-danger mb-4 p-4 bg-red-100 border-l-4 border-red-500 text-red-700">
                    <p class="font-bold">Atenção:</p>
                    <p><%= erro %></p>
                </div>
            <% } %>
            
            <div class="mb-6 border-b pb-4">
                <h3 class="text-lg font-medium leading-6 text-gray-900 mb-4">Dados Pessoais</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    
                    <div class="col-span-1 md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700">Nome Completo *</label>
                        <input type="text" name="nome" required 
                               value="<%= locals.dados?.nome || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2 focus:ring-blue-500 focus:border-blue-500">
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">Prontuário</label>
                        <input type="text" name="prontuario" 
                               value="<%= locals.dados?.prontuario || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">CPF</label>
                        <input type="text" name="cpf" placeholder="000.000.000-00" 
                               value="<%= locals.dados?.cpf || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">RG</label>
                        <input type="text" name="rg" 
                               value="<%= locals.dados?.rg || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">Orgão Emissor</label>
                        <input type="text" name="orgao_rg" 
                               value="<%= locals.dados?.orgao_rg || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">Data Nascimento</label>
                        <input type="date" name="dt_nascimento" 
                               value="<%= locals.dados?.dt_nascimento || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">Sexo</label>
                        <select name="sexo" class="mt-1 block w-full bg-white border border-gray-300 rounded-md shadow-sm p-2">
                            <option value="">Selecione</option>
                            <option value="M" <%= locals.dados?.sexo == 'M' ? 'selected' : '' %>>Masculino</option>
                            <option value="F" <%= locals.dados?.sexo == 'F' ? 'selected' : '' %>>Feminino</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="mb-6 border-b pb-4">
                <h3 class="text-lg font-medium leading-6 text-gray-900 mb-4">Contato e Endereço</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    
                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">Email</label>
                        <input type="email" name="email" 
                               value="<%= locals.dados?.email || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">Celular</label>
                        <input type="text" name="telefone" 
                               value="<%= locals.dados?.telefone || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">CEP</label>
                        <input type="text" name="cep" 
                               value="<%= locals.dados?.cep || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>

                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-gray-700">Endereço</label>
                        <input type="text" name="endereco" 
                               value="<%= locals.dados?.endereco || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">Número</label>
                        <input type="text" name="numero" 
                               value="<%= locals.dados?.numero || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>

                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">Bairro</label>
                        <input type="text" name="bairro" 
                               value="<%= locals.dados?.bairro || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>
                    
                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">Cidade</label>
                        <input type="text" name="municipio" 
                               value="<%= locals.dados?.municipio || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>
                    
                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">UF</label>
                        <input type="text" name="uf" maxlength="2" 
                               value="<%= locals.dados?.uf || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>
                </div>
            </div>

            <div class="bg-gray-50 p-4 rounded-md border border-gray-200">
                <div class="flex items-center mb-4">
                    <input id="criar_usuario" name="criar_usuario" type="checkbox" 
                           <%= locals.dados?.criar_usuario === 'on' ? 'checked' : '' %>
                           class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
                    <label for="criar_usuario" class="ml-2 block text-sm font-medium text-gray-900">
                        Criar acesso de usuário para esta pessoa?
                    </label>
                </div>

                <div id="area-usuario" class="grid grid-cols-1 md:grid-cols-3 gap-6 hidden">
                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">Login (Usuário) *</label>
                        <input type="text" name="modal_usuario" 
                               value="<%= locals.dados?.modal_usuario || '' %>"
                               class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>
                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">Senha *</label>
                        <input type="password" name="modal_senha" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2">
                    </div>
                    <div class="col-span-1">
                        <label class="block text-sm font-medium text-gray-700">Perfil</label>
                        <select name="modal_perfil" class="mt-1 block w-full bg-white border border-gray-300 rounded-md shadow-sm p-2">
                            <option value="1" <%= locals.dados?.modal_perfil == '1' ? 'selected' : '' %>>Administrador</option>
                            <option value="2" <%= locals.dados?.modal_perfil == '2' ? 'selected' : '' %>>Usuário Padrão</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="mt-6 flex justify-end">
                <a href="/pessoas" class="bg-gray-200 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-300 mr-2">Cancelar</a>
                <button type="submit" class="bg-blue-600 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    Salvar Cadastro
                </button>
            </div>

        </form>
    </div>
</div>

<script>
    const checkUser = document.getElementById('criar_usuario');
    const divUser = document.getElementById('area-usuario');

    function toggleUserArea() {
        if (checkUser.checked) {
            divUser.classList.remove('hidden');
        } else {
            divUser.classList.add('hidden');
        }
    }

    // Ouve o clique
    checkUser.addEventListener('change', toggleUserArea);

    // Executa ao carregar a página (para caso de erro no form onde o checkbox volta marcado)
    toggleUserArea();
</script>