<div class="max-w-5xl mx-auto pb-12">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        
        <div class="p-6 bg-slate-50 border-b border-slate-200">
            <h1 class="text-2xl font-bold text-slate-800">Cadastro Completo de Pessoa Física</h1>
            <p class="text-sm text-slate-500">Preencha todos os dados civis, documentos e endereço.</p>
        </div>

        <form action="/pessoas/cadastrar" method="POST" id="form-pessoa" class="p-8 space-y-10">
            
            <div>
                <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    Dados Pessoais & Biometria
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="md:col-span-2">
                        <label class="form-label">Nome Completo *</label>
                        <input type="text" name="nome" required class="form-input uppercase" placeholder="EX: MARLON BRAGA">
                    </div>
                    <div>
                        <label class="form-label">Data Nascimento</label>
                        <input type="date" name="dt_nascimento" class="form-input">
                    </div>
                    <div>
                        <label class="form-label">Sexo Biológico</label>
                        <select name="sexo" class="form-select">
                            <option value="">Selecione...</option>
                            <option value="M">Masculino</option>
                            <option value="F">Feminino</option>
                            <option value="I">Indefinido</option>
                            <option value="O">Outro</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Estado Civil</label>
                        <select name="estado_civil" class="form-select">
                            <option value="">Selecione...</option>
                            <option value="S">Solteiro(a)</option>
                            <option value="C">Casado(a)</option>
                            <option value="V">Viúvo(a)</option>
                            <option value="D">Divorciado(a)</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Nacionalidade (Cód.)</label>
                        <select name="cd_nacionalidade" class="form-select">
                            <option value="">Selecione...</option>
                            <option value="1">1 - Brasileira (Exemplo)</option>
                            <option value="2">2 - Outra</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Altura (cm)</label>
                        <input type="number" name="altura" class="form-input" placeholder="Ex: 175">
                    </div>
                    <div>
                        <label class="form-label">Peso (kg)</label>
                        <input type="number" step="0.001" name="peso" class="form-input" placeholder="Ex: 80.500">
                    </div>
                     <div>
                        <label class="form-label">Religião (Cód.)</label>
                         <select name="cd_religiao" class="form-select"><option value="">Selecione...</option><option value="1">1 - Exemplo</option></select>
                    </div>
                    <div>
                        <label class="form-label">Profissão (Cód.)</label>
                        <select name="cd_profissao" class="form-select"><option value="">Selecione...</option><option value="1">1 - Exemplo</option></select>
                    </div>
                </div>
            </div>

            <hr class="border-slate-100">

            <div>
                <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    Documentação
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="form-label">CPF</label>
                        <input type="text" name="cpf" class="form-input" placeholder="000.000.000-00">
                    </div>
                    <div>
                        <label class="form-label">RG (Identidade)</label>
                        <input type="text" name="rg" class="form-input uppercase">
                    </div>
                    <div>
                        <label class="form-label">Órgão Emissor / UF</label>
                        <input type="text" name="orgao_rg" class="form-input uppercase" placeholder="Ex: SSP/GO">
                    </div>
                </div>
            </div>

             <hr class="border-slate-100">

            <div>
                <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    Contato e Endereço
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                     <div>
                        <label class="form-label">Celular</label>
                        <input type="text" name="telefone" class="form-input">
                    </div>
                    <div class="md:col-span-2">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-input lowercase">
                    </div>
                </div>

                <div class="p-4 bg-slate-50 rounded-xl border border-slate-200 grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="form-label">CEP</label>
                        <input type="text" name="cep" class="form-input" placeholder="00000-000">
                        </div>
                    <div class="md:col-span-2">
                        <label class="form-label">Logradouro (Rua, Av.)</label>
                        <input type="text" name="endereco" class="form-input uppercase">
                    </div>
                    <div>
                        <label class="form-label">Número</label>
                        <input type="text" name="numero" class="form-input uppercase">
                    </div>
                    <div class="md:col-span-2">
                        <label class="form-label">Complemento</label>
                        <input type="text" name="complemento" class="form-input uppercase" placeholder="Ex: Apto 101, Bloco B">
                    </div>
                    <div>
                        <label class="form-label">Bairro</label>
                        <input type="text" name="bairro" class="form-input uppercase">
                    </div>
                     <div>
                        <label class="form-label">Município</label>
                        <input type="text" name="municipio" class="form-input uppercase">
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                         <div>
                            <label class="form-label">UF</label>
                            <select name="uf" class="form-select">
                                <option value="">..</option>
                                <option value="GO">GO</option><option value="SP">SP</option><option value="RJ">RJ</option>
                                </select>
                        </div>
                         <div>
                            <label class="form-label">Cód. IBGE</label>
                            <input type="number" name="ibge" class="form-input">
                        </div>
                    </div>
                </div>
            </div>

            <hr class="border-slate-100 my-8">

            <div class="flex items-center gap-4 p-5 bg-blue-50 rounded-xl border border-blue-100 hover:bg-blue-100 transition-colors">
                <input id="chk-usuario" name="criar_usuario" type="checkbox" class="h-5 w-5 rounded border-slate-300 text-blue-600 focus:ring-blue-600">
                <div>
                    <label for="chk-usuario" class="font-bold text-slate-900 cursor-pointer select-none text-lg">Criar acesso ao sistema?</label>
                    <p class="text-slate-600">Se esta pessoa for um funcionário que usará o software, marque aqui.</p>
                </div>
            </div>

            <input type="hidden" name="modal_usuario" id="hidden_usuario">
            <input type="hidden" name="modal_senha" id="hidden_senha">
            <input type="hidden" name="modal_perfil" id="hidden_perfil">

            <div class="flex justify-end pt-6">
                <button type="submit" class="inline-flex items-center gap-2 bg-blue-600 text-white px-8 py-4 rounded-xl hover:bg-blue-700 font-bold text-lg shadow-lg shadow-blue-200/50 transition-all hover:-translate-y-1">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    Finalizar Cadastro Completo
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .form-label { @apply block text-sm font-semibold text-slate-700 mb-1; }
    .form-input { @apply w-full rounded-lg border-slate-300 focus:ring-blue-500 focus:border-blue-500 shadow-sm; }
    .form-select { @apply w-full rounded-lg border-slate-300 focus:ring-blue-500 focus:border-blue-500 shadow-sm bg-white; }
</style>

<%- include('../../partials/modal_usuario') %>