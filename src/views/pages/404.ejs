<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-100 flex items-center justify-center h-screen">
    <div class="text-center">
        <h1 class="text-9xl font-black text-gray-300">404</h1>
        <p class="text-2xl font-bold tracking-tight text-gray-900 sm:text-4xl">
            Ops! Página não encontrada.
        </p>
        <p class="mt-4 text-gray-500">
            A URL que você tentou acessar não existe ou foi movida.
        </p>
        <a href="/" class="mt-6 inline-block rounded bg-indigo-600 px-5 py-3 text-sm font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring">
            Voltar para o Início
        </a>
    </div>
</body>
</html>