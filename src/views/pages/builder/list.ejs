<div class="max-w-6xl mx-auto">
    
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Minhas Páginas</h1>
            <p class="text-slate-500">Gerencie as páginas criadas com IA</p>
        </div>
        <a href="/page-builder" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium flex items-center gap-2 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Nova Página
        </a>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase text-slate-500 font-semibold tracking-wider">
                    <th class="px-6 py-4">Página</th>
                    <th class="px-6 py-4">Link (Slug)</th>
                    <th class="px-6 py-4">Data Criação</th>
                    <th class="px-6 py-4 text-right">Ações</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% if (paginas.length === 0) { %>
                    <tr>
                        <td colspan="4" class="px-6 py-12 text-center text-slate-400">
                            Nenhuma página criada ainda.
                        </td>
                    </tr>
                <% } else { %>
                    <% paginas.forEach(pagina => { %>
                        <tr class="hover:bg-slate-50 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="font-medium text-slate-800"><%= pagina.titulo %></div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 bg-blue-50 text-blue-700 rounded text-xs font-mono">/p/<%= pagina.slug %></span>
                            </td>
                            <td class="px-6 py-4 text-slate-500 text-sm">
                                <%= new Date(pagina.criado_em).toLocaleDateString('pt-BR') %>
                            </td>
                            <td class="px-6 py-4 text-right flex items-center justify-end gap-2">
                                <a href="/p/<%= pagina.slug %>" target="_blank" class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="Visualizar">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                </a>
                                <button onclick="deletePage(<%= pagina.id %>)" class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Excluir">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
    async function deletePage(id) {
        if(!confirm('Tem certeza que deseja excluir esta página?')) return;

        try {
            const response = await fetch(`/pages/${id}`, { method: 'DELETE' });
            const data = await response.json();

            if(data.success) {
                window.location.reload();
            } else {
                alert('Erro ao excluir: ' + data.error);
            }
        } catch (error) {
            alert('Erro de conexão.');
        }
    }
</script>